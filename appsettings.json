{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "RuntimeMode": "Production",
      "Global": {
        "Id": "e1d81128-b18a-45f2-93a5-84608d044693",
        "DefaultUILanguage": "de-de",
        "UseHttps": true,
        "Smtp": {
          "From": "tickets@redants.ch"
        }
      },
      "Hosting": {
        "LocalTempStorageLocation": "EnvironmentTemp"
      },
      "Examine": {
        "LuceneDirectoryFactory": "SyncedTempFileSystemDirectoryFactory"
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "https://tickets.redants.ch"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        },
        "LoginBackgroundImage": "img/login-bg.jpg",
        "LoginLogoImage": "img/logo-redants.png",
        "LoginLogoImageAlternative": "img/logo-redants.png"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Imaging": {
        "HMACSecretKey": ""
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
  },
  "Brevo": {
    "ApiKey": "",
    "SenderName": "Red Ants Ticketing",
    "SenderEmail": "tickets@redants.ch",
    "AdminBcc": ""
  },
  "Payrexx": {
    "Instance": "",
    "ApiSecret": ""
  },
  "Turnstile": {
    "SiteKey": "",
    "SecretKey": ""
  }
}