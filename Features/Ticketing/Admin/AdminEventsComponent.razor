@using RedAnts.Domain.Ticketing.Sales

<section class="ta-page">
    <h1 class="ta-page-title">Anlässe</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="seasonSelect">Saison</label>
                    <select id="seasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadEventsAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                @if (_createEventUrl is not null)
                {
                    <a class="ta-btn ta-btn-ghost" href="@_createEventUrl"
                       title="Öffnet das Backoffice-Content mit einem neuen Anlass in der gewählten Saison">Anlass im Content erstellen</a>
                }
            </div>
        </div>

        @if (_events.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Anlässe erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
            <table class="ta-table">
                <thead>
                    <tr>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("name")'>Anlass <span class="ta-sort-ind">@Ind("name")</span></th>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("date")'>Datum <span class="ta-sort-ind">@Ind("date")</span></th>
                        <th rowspan="2">Zeit</th>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("status")'>Verkaufsstatus <span class="ta-sort-ind">@Ind("status")</span></th>
                        <th rowspan="2" class="ta-num">Einlass&shy;kontingent</th>
                        <th rowspan="2" class="ta-num">Verkaufs&shy;kontingent</th>
                        <th rowspan="2" class="ta-num">Verkaufte<br />@TicketType.EventTicket.DisplayName()</th>
                        <th rowspan="2" class="ta-num">Bisherige<br />Einlässe</th>
                        <th rowspan="2" class="ta-num" title="Erwartete Personenzahl am Anlass: verkaufte Spieltickets + gültige Saisonkartenbesitzer + Mitglieder + bisherige Freieinlässe. Rot bei Überschreitung des Einlasskontingents; Hinweis bei möglicher Überbuchung.">Erwartete<br />Zutritte</th>
                        <th colspan="5" class="ta-group">Eingelöste Zutritte</th>
                        <th rowspan="2"></th>
                        <th rowspan="2" class="ta-col-actions"></th>
                    </tr>
                    <tr>
                        <th class="ta-num ta-group-col">@TicketType.EventTicket.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonSingle.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonPass.DisplayName()</th>
                        <th class="ta-num">@TicketType.MemberCard.DisplayName()</th>
                        <th class="ta-num">@TicketType.FreeEntry.DisplayName()</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Sorted())
                    {
                        var c = Counts(e.Id);
                        <tr>
                            <td class="ta-cell-name">
                                <InlineTextEdit Value="@e.Name" FieldLabel="Bezeichnung" MaxLength="200"
                                                Save="@(v => SaveNameAsync(e, v))" />
                            </td>
                            <td>
                                <InlineDateEdit Value="@e.Date" FieldLabel="Datum"
                                                Save="@(d => SaveDateAsync(e, d))" />
                            </td>
                            <td>
                                @if (e.TimeUnknown)
                                {
                                    <span class="ta-muted-text">—</span>
                                }
                                else
                                {
                                    <InlineTimeEdit Value="@e.StartTime" FieldLabel="Zeit"
                                                    Save="@(t => SaveTimeAsync(e, t))" />
                                }
                            </td>
                            <td>
                                <InlineSelectEdit TValue="EventStatus" Value="@e.Status" Options="_statuses" FieldLabel="Verkaufsstatus"
                                                  Label="@(s => StatusLabel(s))"
                                                  Display="StatusBadge"
                                                  Save="@(s => SaveStatusAsync(e, s))" />
                            </td>
                            <td class="ta-num">
                                <InlineNumberEdit Value="@ToDecimal(Quota(e.Id))" FieldLabel="Einlasskontingent"
                                                  Min="0" AllowEmpty="true" EmptyLabel="∞"
                                                  Save="@(v => SaveQuotaAsync(e, v))" />
                            </td>
                            <td class="ta-num">
                                <InlineNumberEdit Value="@ToDecimal(SalesQuota(e.Id))" FieldLabel="Verkaufskontingent"
                                                  Min="0" AllowEmpty="true" EmptyLabel="∞"
                                                  Save="@(v => SaveSalesQuotaAsync(e, v))" />
                            </td>
                            <td class="ta-num">@c.SoldSingleTickets</td>
                            <td class="ta-num @PastClass(e, c)">@c.TotalRedeemed</td>
                            <td class="ta-num @ExpectedClass(e, c)" title="@ExpectedTitle(e, c)">@c.ExpectedAdmissions</td>
                            <td class="ta-num ta-group-col">@c.RedeemedEventTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonSingleTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonPasses</td>
                            <td class="ta-num">@c.RedeemedMemberCards</td>
                            <td class="ta-num">@c.RedeemedFreeEntries</td>
                            <td class="ta-links">
                                <button type="button" class="ta-link-btn" title="Links anzeigen und kopieren"
                                        @onclick="() => OpenLinks(e)">🔗</button>
                            </td>
                            <td class="ta-col-actions">
                                <button type="button" class="ta-icon-btn" title="Preise &amp; Kontingente pro Kategorie"
                                        @onclick="() => OpenPricing(e)">$</button>
                                <button type="button" class="ta-icon-btn" title="Freieintritt-Kontingente bearbeiten"
                                        @onclick="() => OpenEdit(e)">🎟️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <p class="ta-summary">@_events.Count @(_events.Count == 1 ? "Anlass" : "Anlässe")</p>
        }
    }
</section>

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Freieintritt-Kontingente</h2>
            <p class="ta-modal-sub">@_editing.Name · @_editing.Date.ToString("dd.MM.yyyy")</p>

            <div class="ta-freeentry-grid">
                <div class="ta-freeentry-head"></div>
                <div class="ta-freeentry-head">Max. Kontingent</div>
                <div class="ta-freeentry-head">Vorab fix erfasst</div>
                @foreach (var type in FreeEntryTypes)
                {
                    <label class="ta-label ta-freeentry-name">@type.DisplayName()</label>
                    <input type="number" min="0" step="1" class="ta-input" placeholder="Unbegrenzt"
                           value="@(_editQuotas.GetValueOrDefault(type)?.ToString())"
                           @onchange="e => SetQuota(type, e.Value?.ToString())" />
                    <input type="number" min="0" step="1" class="ta-input" placeholder="0"
                           value="@(_editFixed.GetValueOrDefault(type)?.ToString())"
                           @onchange="e => SetFixed(type, e.Value?.ToString())" />
                }
            </div>
            <p class="ta-field-hint">„Max. Kontingent" = maximale Anzahl Freieintritte pro Typ (leer = unbegrenzt). „Vorab fix erfasst" = Personen, die nicht am Eingang scannen (z. B. Spieler:innen, Staff); sie gelten als bereits eingelassen, verbrauchen das Kontingent und zählen zur Hallenbelegung.</p>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEdit" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_pricingEvent is not null)
{
    <div class="ta-overlay" @onmousedown="CancelPricing">
        <div class="ta-modal ta-modal--xwide" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Preise &amp; Kontingente</h2>
            <p class="ta-modal-sub">@_pricingEvent.Name · @_pricingEvent.Date.ToString("dd.MM.yyyy")</p>

            <div style="display:grid; grid-template-columns:1.5fr .7fr 1fr 1fr 1.2fr; gap:.4rem .75rem; align-items:center; margin-top:.5rem;">
                <span class="ta-label">Stufe</span>
                <span class="ta-label" style="text-align:center;">Anbieten</span>
                <span class="ta-label">Preis (CHF)</span>
                <span class="ta-label">Kontingent</span>
                <span class="ta-label">Verkauf bis</span>

                @foreach (var row in _priceRows)
                {
                    <span>@row.Name</span>
                    <span style="text-align:center;">
                        <input type="checkbox" @bind="row.Enabled" />
                    </span>
                    <input type="number" min="0" step="0.01" class="ta-input" @bind="row.Price" @bind:after="() => row.Price = decimal.Round(row.Price, 2)" disabled="@(!row.Enabled)" />
                    <input type="number" min="0" step="1" class="ta-input" placeholder="∞" @bind="row.Quota" disabled="@(!row.Enabled)" />
                    <DateBox @bind-Value="row.AvailableUntil" Disabled="@(!row.Enabled)" />
                }
            </div>
            <p class="ta-field-hint">„Anbieten" abwählen entfernt die Kategorie aus dem Verkauf. Kontingent leer = für diese Kategorie unbegrenzt; das Totalkontingent des Anlasses zählt trotzdem. „Verkauf bis" leer = kein Enddatum; sonst ist die Kategorie nach diesem Tag nicht mehr verkäuflich. Massgebend ist, was zuerst erreicht wird: Kontingent oder Datum.</p>

            @if (_pricingError is not null)
            {
                <p class="ta-modal-error">@_pricingError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelPricing" disabled="@_pricingSaving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SavePricing" disabled="@_pricingSaving">
                    @(_pricingSaving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_linkEvent is not null)
{
    var l = Links(_linkEvent.Id);
    <LinkOverlay Subtitle="@($"{_linkEvent.Name} · {_linkEvent.Date:dd.MM.yyyy}")"
                 PublicUrl="@l.Public" InternUrl="@l.Intern"
                 PublicHint="@PublicLinkHint(_linkEvent.Status)" InternHint="@InternLinkHint(_linkEvent.Status)"
                 OnClose="() => _linkEvent = null" />
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private IEventAdmissionReport AdmissionReport { get; set; } = default!;
    [Inject] private IEventStatusEditor StatusEditor { get; set; } = default!;
    [Inject] private IEventAdmissionQuota QuotaEditor { get; set; } = default!;
    [Inject] private IEventSalesQuota SalesQuotaEditor { get; set; } = default!;
    [Inject] private IEventContentEditor ContentEditor { get; set; } = default!;
    [Inject] private IFreeEntryQuota FreeEntryQuota { get; set; } = default!;
    [Inject] private IEventPrices Prices { get; set; } = default!;
    [Inject] private IPriceTiers PriceTiers { get; set; } = default!;
    [Inject] private IEventLinkReader LinkReader { get; set; } = default!;
    [Inject] private IContentCreateLinks CreateLinks { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Event> _events = [];
    private IReadOnlyDictionary<int, EventAdmissionCounts> _counts = new Dictionary<int, EventAdmissionCounts>();
    private IReadOnlyDictionary<int, int?> _quotas = new Dictionary<int, int?>();
    private IReadOnlyDictionary<int, int?> _salesQuotas = new Dictionary<int, int?>();
    private IReadOnlyDictionary<int, EventLinks> _links = new Dictionary<int, EventLinks>();

    public int SelectedSeasonId { get; set; }

    private string _sortCol = "date";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        _counts = await AdmissionReport.GetCountsByEventAsync();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadEventsAsync();
        _loading = false;
    }

    private EventAdmissionCounts Counts(int eventId) => _counts.TryGetValue(eventId, out var c) ? c : EventAdmissionCounts.Empty;
    private int? Quota(int eventId) => _quotas.TryGetValue(eventId, out var q) ? q : null;
    private int? SalesQuota(int eventId) => _salesQuotas.TryGetValue(eventId, out var q) ? q : null;
    private EventLinks Links(int eventId) => _links.TryGetValue(eventId, out var l) ? l : new EventLinks(null, null);

    private string PastClass(Event e, EventAdmissionCounts c)
    {
        if (Quota(e.Id) is not { } q) return "";
        if (c.TotalRedeemed > q) return "ta-cell-over";
        return q - c.TotalRedeemed <= 10 ? "ta-cell-warn" : "";
    }

    private string ExpectedClass(Event e, EventAdmissionCounts c)
    {
        if (Quota(e.Id) is not { } q) return "";
        if (c.ExpectedAdmissions > q) return "ta-cell-over";
        return PotentialAdmissions(e, c) > q ? "ta-cell-warn" : "";
    }

    private string? ExpectedTitle(Event e, EventAdmissionCounts c)
    {
        if (Quota(e.Id) is not { } q) return null;
        if (c.ExpectedAdmissions > q)
            return $"Erwartete Zutritte ({c.ExpectedAdmissions}) über dem Einlasskontingent ({q}).";
        return PotentialAdmissions(e, c) > q
            ? "Mit den noch verkaufbaren Tickets könnte das Einlasskontingent überschritten werden."
            : null;
    }

    private int PotentialAdmissions(Event e, EventAdmissionCounts c) =>
        SalesQuota(e.Id) is { } sq ? c.ExpectedAdmissions + Math.Max(0, sq - c.SoldSingleTickets) : int.MaxValue;

    private string? _createEventUrl;

    private async Task ReloadEventsAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        if (SelectedSeasonId > 0)
        {
            _events = await Events.GetBySeasonAsync(SelectedSeasonId);
            _quotas = await QuotaEditor.GetAllAsync();
            _salesQuotas = await SalesQuotaEditor.GetAllAsync();
            _links = await LinkReader.GetBySeasonAsync(SelectedSeasonId);
            _createEventUrl = await CreateLinks.CreateEventUrlAsync(SelectedSeasonId);
        }
        else
        {
            _events = [];
            _quotas = new Dictionary<int, int?>();
            _salesQuotas = new Dictionary<int, int?>();
            _links = new Dictionary<int, EventLinks>();
            _createEventUrl = null;
        }
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<Event> Sorted()
    {
        IEnumerable<Event> q = _sortCol switch
        {
            "name" => _events.OrderBy(e => e.Name),
            "status" => _events.OrderBy(e => e.Status),
            _ => _events.OrderBy(e => e.Date).ThenBy(e => e.StartTime),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static string StatusLabel(EventStatus status) => status switch
    {
        EventStatus.Open => "Öffentlich",
        EventStatus.Intern => "Intern",
        EventStatus.Closed => "Geschlossen",
        _ => "Entwurf"
    };

    private Event? _linkEvent;
    private void OpenLinks(Event e) => _linkEvent = e;

    private static string? PublicLinkHint(EventStatus status) => status switch
    {
        EventStatus.Open => null,
        EventStatus.Intern => "Anlass ist intern: der öffentliche Link ist derzeit nicht aktiv.",
        _ => "Anlass ist nicht im Verkauf: der Link ist derzeit nicht aktiv."
    };

    private static string? InternLinkHint(EventStatus status) => status switch
    {
        EventStatus.Open or EventStatus.Intern => null,
        _ => "Anlass ist nicht im Verkauf: der Link ist derzeit nicht aktiv."
    };

    private readonly EventStatus[] _statuses = Enum.GetValues<EventStatus>();

    private RenderFragment<EventStatus> StatusBadge => status =>
        @<span class="ta-badge ta-badge-@status.ToString().ToLowerInvariant()">@StatusLabel(status)</span>;

    private static decimal? ToDecimal(int? value) => value;

    private async Task SaveNameAsync(Event e, string name)
    {
        await ContentEditor.SetNameAsync(e.Id, name);
        await ReloadEventsAsync();
    }

    private async Task SaveDateAsync(Event e, DateOnly? date)
    {
        if (date is null) throw new DomainException("Datum ist erforderlich.");
        await ContentEditor.SetStartAsync(e.Id, date.Value, e.StartTime);
        await ReloadEventsAsync();
    }

    private async Task SaveTimeAsync(Event e, TimeOnly? time)
    {
        if (time is null) throw new DomainException("Zeit ist erforderlich.");
        await ContentEditor.SetStartAsync(e.Id, e.Date, time.Value);
        await ReloadEventsAsync();
    }

    private async Task SaveStatusAsync(Event e, EventStatus status)
    {
        await StatusEditor.SetStatusAsync(e.Id, status);
        await ReloadEventsAsync();
    }

    private async Task SaveQuotaAsync(Event e, decimal? quota)
    {
        await QuotaEditor.SetAsync(e.Id, quota is null ? null : (int)quota.Value);
        await ReloadEventsAsync();
    }

    private async Task SaveSalesQuotaAsync(Event e, decimal? quota)
    {
        await SalesQuotaEditor.SetAsync(e.Id, quota is null ? null : (int)quota.Value);
        await ReloadEventsAsync();
    }

    private static readonly FreeEntryType[] FreeEntryTypes =
        Enum.GetValues<FreeEntryType>().Where(t => t != FreeEntryType.Child).ToArray();

    private Event? _editing;
    private Dictionary<FreeEntryType, int?> _editQuotas = new();
    private Dictionary<FreeEntryType, int?> _editFixed = new();
    private bool _saving;
    private string? _editError;

    private async Task OpenEdit(Event e)
    {
        _editing = e;
        _editQuotas = new Dictionary<FreeEntryType, int?>(await FreeEntryQuota.GetAsync(e.Id));
        _editFixed = new Dictionary<FreeEntryType, int?>(await FreeEntryQuota.GetFixedAsync(e.Id));
        _editError = null;
    }

    private void SetQuota(FreeEntryType type, string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) { _editQuotas[type] = null; return; }
        _editQuotas[type] = int.TryParse(value, out var n) ? Math.Max(0, n) : null;
    }

    private void SetFixed(FreeEntryType type, string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) { _editFixed[type] = null; return; }
        _editFixed[type] = int.TryParse(value, out var n) ? Math.Max(0, n) : null;
    }

    private void CancelEdit() { _editing = null; _editError = null; }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        _saving = true;
        _editError = null;
        try
        {
            await FreeEntryQuota.SetAllAsync(_editing.Id, _editQuotas, _editFixed);
            _editing = null;
            await ReloadEventsAsync();
        }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private sealed class CategoryRow
    {
        public int TierId { get; init; }
        public string Name { get; init; } = "";
        public bool Enabled { get; set; }
        public decimal Price { get; set; }
        public int? Quota { get; set; }
        public DateOnly? AvailableUntil { get; set; }
    }

    private Event? _pricingEvent;
    private EventPrice? _pricingExisting;
    private List<CategoryRow> _priceRows = [];
    private bool _pricingSaving;
    private string? _pricingError;

    private async Task OpenPricing(Event e)
    {
        _pricingEvent = e;
        _pricingError = null;
        _pricingExisting = await Prices.GetByEventAsync(e.Id);
        var byTier = (_pricingExisting?.Categories ?? [])
            .Where(c => c.TierId is not null)
            .ToDictionary(c => c.TierId!.Value);
        var tiers = await PriceTiers.GetBySeasonAsync(SelectedSeasonId);
        var nameById = tiers.ToDictionary(t => t.Id, t => t.Name);
        _priceRows = tiers
            .OrderBy(t => t.SortOrder).ThenBy(t => t.PromoOfTierId ?? 0).ThenBy(t => t.Id)
            .Select(t =>
            {
                var name = t.PromoOfTierId is { } parent && nameById.TryGetValue(parent, out var pn)
                    ? $"{t.Name} (Aktion zu {pn})" : t.Name;
                return byTier.TryGetValue(t.Id, out var existing)
                    ? new CategoryRow { TierId = t.Id, Name = name, Enabled = true, Price = decimal.Round(existing.SalePrice, 2), Quota = existing.Quota, AvailableUntil = existing.AvailableUntil }
                    : new CategoryRow { TierId = t.Id, Name = name, Enabled = false, Price = 0m, Quota = null };
            })
            .ToList();
    }

    private void CancelPricing() { _pricingEvent = null; _pricingError = null; }

    private async Task SavePricing()
    {
        if (_pricingEvent is null) return;
        _pricingSaving = true;
        _pricingError = null;
        try
        {
            var categories = _priceRows
                .Where(r => r.Enabled)
                .Select(r => CategoryPrice.Create(default, decimal.Round(r.Price, 2), r.Quota, r.AvailableUntil, r.TierId))
                .ToList();
            var price = EventPrice.FromPersistence(
                _pricingExisting?.Id ?? 0,
                _pricingEvent.Id,
                _pricingExisting?.TotalSalesQuota,
                _pricingExisting?.AdmissionQuota,
                categories);
            await Prices.SaveAsync(price);
            _pricingEvent = null;
        }
        catch (Exception ex) { _pricingError = ex.Message; }
        finally { _pricingSaving = false; }
    }
}
