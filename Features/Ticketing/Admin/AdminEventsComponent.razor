@using RedAnts.Domain.Ticketing.Sales
@* Anlässe (events) administration: pick a season, list its events.
   The catalog itself is edited in the Umbraco content tree; the only field editable here is the
   event status (inline, via a confirmation overlay), through the narrow IEventStatusEditor write port.
   Column labels for the ticket types come from TicketType.DisplayName() (S2's canonical naming). *@

<section class="ta-page">
    <h1 class="ta-page-title">Anlässe</h1>
    <p class="ta-page-lead">Anlässe (Spiele, Events) einer Saison.</p>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-field">
            <label class="ta-label" for="seasonSelect">Saison</label>
            <select id="seasonSelect" class="ta-select"
                    @bind="SelectedSeasonId" @bind:after="ReloadEventsAsync">
                @foreach (var s in _seasons)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>

        @if (_events.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Anlässe erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
            <table class="ta-table">
                <thead>
                    <tr>
                        <th rowspan="2">Datum</th>
                        <th rowspan="2">Zeit</th>
                        <th rowspan="2">Anlass</th>
                        <th rowspan="2">Status</th>
                        <th rowspan="2" class="ta-num">Einlass&shy;kontingent</th>
                        <th rowspan="2" class="ta-num">Bisherige<br />Einlässe</th>
                        <th rowspan="2" class="ta-num">Verkaufte<br />@TicketType.EventTicket.DisplayName()</th>
                        <th colspan="5" class="ta-group">Eingelöste Zutritte</th>
                    </tr>
                    <tr>
                        <th class="ta-num ta-group-col">@TicketType.EventTicket.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonSingle.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonPass.DisplayName()</th>
                        <th class="ta-num">@TicketType.MemberCard.DisplayName()</th>
                        <th class="ta-num">@TicketType.FreeEntry.DisplayName()</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in _events)
                    {
                        var c = Counts(e.Id);
                        <tr>
                            <td>@e.Date.ToString("dd.MM.yyyy")</td>
                            <td>@e.StartTime.ToString("HH:mm")</td>
                            <td class="ta-cell-name">@e.Name</td>
                            <td>
                                <button type="button"
                                        class="ta-status-btn ta-badge ta-badge-@e.Status.ToString().ToLowerInvariant()"
                                        title="Status ändern" @onclick="() => OpenStatusEdit(e)">
                                    @StatusLabel(e.Status)
                                </button>
                            </td>
                            <td class="ta-num ta-muted" title="Spalte folgt">–</td>
                            <td class="ta-num">@c.TotalRedeemed</td>
                            <td class="ta-num">@c.SoldSingleTickets</td>
                            <td class="ta-num ta-group-col">@c.RedeemedEventTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonSingleTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonPasses</td>
                            <td class="ta-num">@c.RedeemedMemberCards</td>
                            <td class="ta-num ta-muted" title="Spalte folgt">–</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    }
</section>

@if (_editing is not null)
{
    <div class="ta-overlay" @onclick="CancelStatusEdit">
        <div class="ta-modal" @onclick:stopPropagation="true">
            <h2 class="ta-modal-title">Status ändern</h2>
            <p class="ta-modal-sub">
                @_editing.Name · @_editing.Date.ToString("dd.MM.yyyy")
            </p>

            <div class="ta-field">
                <label class="ta-label" for="editStatus">Status</label>
                <select id="editStatus" class="ta-select" @bind="_editStatus">
                    @foreach (var st in Enum.GetValues<EventStatus>())
                    {
                        <option value="@st">@StatusLabel(st)</option>
                    }
                </select>
            </div>

            <p class="ta-modal-hint">
                Von <strong>@StatusLabel(_editing.Status)</strong> auf <strong>@StatusLabel(_editStatus)</strong> ändern?
                Der Anlass wird sofort neu veröffentlicht.
            </p>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn-secondary" @onclick="CancelStatusEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn-primary" @onclick="SaveStatus" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Status ändern")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .ta-field { margin: 0 0 1.5rem; max-width: 360px; }
    .ta-label {
        display: block; margin-bottom: 0.35rem;
        font-size: 0.85rem; font-weight: 700; color: var(--ta-ink);
    }
    .ta-select {
        width: 100%; padding: 0.5rem 0.6rem;
        font-family: var(--ta-font); font-size: 0.95rem; color: var(--ta-ink);
        background: #fff; border: 1px solid var(--ta-border); border-radius: 3px;
    }
    .ta-select:focus { outline: none; border-color: var(--ta-accent); box-shadow: 0 0 0 2px rgba(93,173,226,0.25); }
    .ta-muted-text { color: var(--ta-muted); }

    .ta-table-wrap { overflow-x: auto; }
    .ta-table {
        width: 100%; border-collapse: collapse; background: #fff;
        border: 1px solid var(--ta-border); border-radius: 3px; overflow: hidden;
    }
    .ta-table th.ta-num, .ta-table td.ta-num { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .ta-table td.ta-muted { color: #c2c2c2; }
    .ta-table th {
        text-align: left; font-size: 0.66rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.02em; color: var(--ta-muted); line-height: 1.2;
        padding: 6px 8px; background: #fafafa; border-bottom: 1px solid var(--ta-border);
    }
    /* "Eingelöste Zutritte" group heading: a bit more prominent (accent colour + tint). */
    .ta-table th.ta-group {
        text-align: center; text-transform: uppercase;
        color: var(--ta-accent); background: #eef6fc;
        border-left: 1px solid var(--ta-accent); border-bottom-color: var(--ta-accent);
        font-size: 0.7rem; letter-spacing: 0.04em;
    }
    /* Left edge of the grouped block, carried down to the first sub-column and its cells. */
    .ta-table th.ta-group-col, .ta-table td.ta-group-col { border-left: 1px solid #d7e8f6; }
    .ta-table td {
        padding: 6px 8px; font-size: 0.8rem; border-bottom: 1px solid #f2f2f2;
        white-space: nowrap;
    }
    .ta-table tr:last-child td { border-bottom: none; }
    .ta-table tbody tr:hover { background: #fafbfc; }
    .ta-cell-name { white-space: normal; font-weight: 500; min-width: 150px; }

    .ta-badge {
        display: inline-block; padding: 0.1rem 0.45rem; border-radius: 999px;
        font-size: 0.68rem; font-weight: 700; white-space: nowrap;
    }
    .ta-badge-open { background: #e4f4ea; color: #1c7c43; }
    .ta-badge-draft { background: #efefef; color: #666; }
    .ta-badge-intern { background: #fdf1dc; color: #9a6a12; }
    .ta-badge-closed { background: #f6e2e4; color: #a3283a; }
    /* Status badge doubles as the edit trigger. */
    .ta-status-btn {
        appearance: none; border: 1px solid transparent; cursor: pointer;
        font-family: var(--ta-font); line-height: 1.4;
    }
    .ta-status-btn:hover { filter: brightness(0.96); border-color: rgba(0,0,0,0.15); }

    /* Confirmation overlay (mirrors the Saisonkarten edit modal). */
    .ta-overlay {
        position: fixed; inset: 0; z-index: 1000;
        background: rgba(27, 38, 79, 0.45);
        display: flex; align-items: center; justify-content: center;
        padding: 1.5rem;
    }
    .ta-modal {
        background: #fff; border-radius: 5px; width: 100%; max-width: 420px;
        padding: 1.5rem 1.6rem 1.6rem;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
    }
    .ta-modal-title {
        font-family: var(--ta-font); font-size: 1.2rem; font-weight: 700;
        color: var(--ta-ink); margin: 0 0 0.2rem;
    }
    .ta-modal-sub { color: var(--ta-muted); font-size: 0.82rem; margin: 0 0 1.1rem; }
    .ta-modal .ta-field { max-width: none; }
    .ta-modal-hint { color: var(--ta-muted); font-size: 0.82rem; margin: 0 0 0.4rem; }
    .ta-modal-error {
        color: #a3283a; background: #f6e2e4; border-radius: 3px;
        padding: 0.5rem 0.7rem; font-size: 0.82rem; margin: 0.6rem 0 0;
    }
    .ta-modal-actions {
        display: flex; justify-content: flex-end; gap: 0.6rem; margin-top: 1.4rem;
    }
    .ta-btn-primary, .ta-btn-secondary {
        appearance: none; cursor: pointer; font-family: var(--ta-font);
        font-size: 0.9rem; font-weight: 700; border-radius: 3px;
        padding: 0.5rem 1.1rem; transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .ta-btn-primary { color: #fff; background: var(--ta-accent); border: 1px solid var(--ta-accent); }
    .ta-btn-primary:hover:not(:disabled) { background: #3d97d4; border-color: #3d97d4; }
    .ta-btn-secondary { color: var(--ta-ink); background: #fff; border: 1px solid var(--ta-border); }
    .ta-btn-secondary:hover:not(:disabled) { background: #f4f4f4; }
    .ta-btn-primary:disabled, .ta-btn-secondary:disabled { opacity: 0.6; cursor: default; }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private IEventAdmissionReport AdmissionReport { get; set; } = default!;
    [Inject] private IEventStatusEditor StatusEditor { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Event> _events = [];
    private IReadOnlyDictionary<int, EventAdmissionCounts> _counts =
        new Dictionary<int, EventAdmissionCounts>();

    public int SelectedSeasonId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Newest season first — that is also what an admin most often works with.
        _seasons = (await Seasons.GetAllAsync())
            .OrderByDescending(s => s.StartDate)
            .ToList();

        _counts = await AdmissionReport.GetCountsByEventAsync();

        // Prefer the season remembered across tabs; fall back to the current season on first use.
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadEventsAsync();
        _loading = false;
    }

    private EventAdmissionCounts Counts(int eventId) =>
        _counts.TryGetValue(eventId, out var c) ? c : EventAdmissionCounts.Empty;

    private async Task ReloadEventsAsync()
    {
        // Remember the choice so the other tabs open on the same season.
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _events = SelectedSeasonId > 0
            ? await Events.GetBySeasonAsync(SelectedSeasonId)
            : [];
    }

    /// <summary>The season whose date range contains today; falls back to the most recent already-started one.</summary>
    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static string StatusLabel(EventStatus status) => status switch
    {
        EventStatus.Open => "Öffentlich",
        EventStatus.Intern => "Intern",
        EventStatus.Closed => "Geschlossen",
        _ => "Entwurf"
    };

    // --- Status edit / confirmation overlay ---
    private Event? _editing;
    private EventStatus _editStatus;
    private bool _saving;
    private string? _editError;

    private void OpenStatusEdit(Event e)
    {
        _editing = e;
        _editStatus = e.Status;
        _editError = null;
    }

    private void CancelStatusEdit()
    {
        _editing = null;
        _editError = null;
    }

    private async Task SaveStatus()
    {
        if (_editing is null) return;
        _saving = true;
        _editError = null;
        try
        {
            await StatusEditor.SetStatusAsync(_editing.Id, _editStatus);
            _editing = null;
            await ReloadEventsAsync();
        }
        catch (Exception ex)
        {
            _editError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
