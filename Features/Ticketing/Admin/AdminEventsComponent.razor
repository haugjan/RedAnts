@using RedAnts.Domain.Ticketing.Sales

<section class="ta-page">
    <h1 class="ta-page-title">Anlässe</h1>
    <p class="ta-page-lead">Anlässe (Spiele, Events) einer Saison. Status und Einlasskontingent sind hier bearbeitbar, alles Weitere im Inhaltsbaum.</p>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="seasonSelect">Saison</label>
                    <select id="seasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadEventsAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        @if (_events.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Anlässe erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
            <table class="ta-table">
                <thead>
                    <tr>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("name")'>Anlass <span class="ta-sort-ind">@Ind("name")</span></th>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("date")'>Datum <span class="ta-sort-ind">@Ind("date")</span></th>
                        <th rowspan="2">Zeit</th>
                        <th rowspan="2" class="ta-th-sort" @onclick='() => Sort("status")'>Status <span class="ta-sort-ind">@Ind("status")</span></th>
                        <th rowspan="2" class="ta-num">Einlass&shy;kontingent</th>
                        <th rowspan="2" class="ta-num">Bisherige<br />Einlässe</th>
                        <th rowspan="2" class="ta-num">Verkaufte<br />@TicketType.EventTicket.DisplayName()</th>
                        <th colspan="5" class="ta-group">Eingelöste Zutritte</th>
                        <th rowspan="2">Links</th>
                        <th rowspan="2" class="ta-col-actions"></th>
                    </tr>
                    <tr>
                        <th class="ta-num ta-group-col">@TicketType.EventTicket.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonSingle.DisplayName()</th>
                        <th class="ta-num">@TicketType.SeasonPass.DisplayName()</th>
                        <th class="ta-num">@TicketType.MemberCard.DisplayName()</th>
                        <th class="ta-num">@TicketType.FreeEntry.DisplayName()</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Sorted())
                    {
                        var c = Counts(e.Id);
                        var links = Links(e.Id);
                        <tr>
                            <td class="ta-cell-name">@e.Name</td>
                            <td>@e.Date.ToString("dd.MM.yyyy")</td>
                            <td>@e.StartTime.ToString("HH:mm")</td>
                            <td><span class="ta-badge ta-badge-@e.Status.ToString().ToLowerInvariant()">@StatusLabel(e.Status)</span></td>
                            <td class="ta-num">@QuotaLabel(Quota(e.Id))</td>
                            <td class="ta-num">@c.TotalRedeemed</td>
                            <td class="ta-num">@c.SoldSingleTickets</td>
                            <td class="ta-num ta-group-col">@c.RedeemedEventTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonSingleTickets</td>
                            <td class="ta-num">@c.RedeemedSeasonPasses</td>
                            <td class="ta-num">@c.RedeemedMemberCards</td>
                            <td class="ta-num">@c.RedeemedFreeEntries</td>
                            <td class="ta-links">
                                @if (e.Status == EventStatus.Open)
                                {
                                    <button type="button" class="ta-link-btn"
                                            disabled="@(string.IsNullOrEmpty(links.Public))"
                                            title="@(string.IsNullOrEmpty(links.Public) ? "Noch nicht veröffentlicht" : "Öffentlichen Link kopieren")"
                                            @onclick="() => Copy(e.Id, false, links.Public)">
                                        @(IsCopied(e.Id, false) ? "✓" : "🔗")
                                    </button>
                                }
                                else if (e.Status == EventStatus.Intern)
                                {
                                    <button type="button" class="ta-link-btn"
                                            disabled="@(string.IsNullOrEmpty(links.Intern))"
                                            title="@(string.IsNullOrEmpty(links.Intern) ? "Noch nicht veröffentlicht" : "Internen Link (mit Geheimnis) kopieren")"
                                            @onclick="() => Copy(e.Id, true, links.Intern)">
                                        @(IsCopied(e.Id, true) ? "✓" : "🔒")
                                    </button>
                                }
                            </td>
                            <td class="ta-col-actions">
                                <button type="button" class="ta-icon-btn" title="Preise &amp; Kontingente pro Kategorie"
                                        @onclick="() => OpenPricing(e)">💰</button>
                                <button type="button" class="ta-icon-btn" title="Status und Kontingent bearbeiten"
                                        @onclick="() => OpenEdit(e)">✎</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <p class="ta-summary">@_events.Count @(_events.Count == 1 ? "Anlass" : "Anlässe")</p>
        }
    }
</section>

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Anlass bearbeiten</h2>
            <p class="ta-modal-sub">@_editing.Name · @_editing.Date.ToString("dd.MM.yyyy")</p>

            <div class="ta-field">
                <label class="ta-label" for="editStatus">Status</label>
                <select id="editStatus" class="ta-select" @bind="_editStatus">
                    @foreach (var st in Enum.GetValues<EventStatus>())
                    {
                        <option value="@st">@StatusLabel(st)</option>
                    }
                </select>
            </div>

            <div class="ta-field">
                <label class="ta-label" for="editQuota">Einlasskontingent</label>
                <input id="editQuota" type="number" min="0" step="1" class="ta-input" placeholder="Unbegrenzt" @bind="_editQuota" />
                <p class="ta-field-hint">Leer lassen für unbegrenzt.</p>
            </div>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEdit" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_pricingEvent is not null)
{
    <div class="ta-overlay" @onmousedown="CancelPricing">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Preise &amp; Kontingente</h2>
            <p class="ta-modal-sub">@_pricingEvent.Name · @_pricingEvent.Date.ToString("dd.MM.yyyy")</p>

            <div style="display:grid; grid-template-columns:1.5fr .7fr 1fr 1fr; gap:.4rem .75rem; align-items:center; margin-top:.5rem;">
                <span class="ta-label">Kategorie</span>
                <span class="ta-label" style="text-align:center;">Anbieten</span>
                <span class="ta-label">Preis (CHF)</span>
                <span class="ta-label">Kontingent</span>

                @foreach (var row in _priceRows)
                {
                    <span>@row.Category.DisplayName()</span>
                    <span style="text-align:center;">
                        <input type="checkbox" @bind="row.Enabled" />
                    </span>
                    <input type="number" min="0" step="0.05" class="ta-input" @bind="row.Price" disabled="@(!row.Enabled)" />
                    <input type="number" min="0" step="1" class="ta-input" placeholder="∞" @bind="row.Quota" disabled="@(!row.Enabled)" />
                }
            </div>
            <p class="ta-field-hint">„Anbieten" abwählen entfernt die Kategorie aus dem Verkauf. Kontingent leer = unbegrenzt.</p>

            @if (_pricingError is not null)
            {
                <p class="ta-modal-error">@_pricingError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelPricing" disabled="@_pricingSaving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SavePricing" disabled="@_pricingSaving">
                    @(_pricingSaving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private IEventAdmissionReport AdmissionReport { get; set; } = default!;
    [Inject] private IEventStatusEditor StatusEditor { get; set; } = default!;
    [Inject] private IEventAdmissionQuota QuotaEditor { get; set; } = default!;
    [Inject] private IEventPrices Prices { get; set; } = default!;
    [Inject] private IEventLinkReader LinkReader { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Event> _events = [];
    private IReadOnlyDictionary<int, EventAdmissionCounts> _counts = new Dictionary<int, EventAdmissionCounts>();
    private IReadOnlyDictionary<int, int?> _quotas = new Dictionary<int, int?>();
    private IReadOnlyDictionary<int, EventLinks> _links = new Dictionary<int, EventLinks>();

    public int SelectedSeasonId { get; set; }

    private string _sortCol = "date";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        _counts = await AdmissionReport.GetCountsByEventAsync();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadEventsAsync();
        _loading = false;
    }

    private EventAdmissionCounts Counts(int eventId) => _counts.TryGetValue(eventId, out var c) ? c : EventAdmissionCounts.Empty;
    private int? Quota(int eventId) => _quotas.TryGetValue(eventId, out var q) ? q : null;
    private EventLinks Links(int eventId) => _links.TryGetValue(eventId, out var l) ? l : new EventLinks(null, null);
    private static string QuotaLabel(int? quota) => quota?.ToString("N0") ?? "∞";

    private async Task ReloadEventsAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        if (SelectedSeasonId > 0)
        {
            _events = await Events.GetBySeasonAsync(SelectedSeasonId);
            _quotas = await QuotaEditor.GetAllAsync();
            _links = await LinkReader.GetBySeasonAsync(SelectedSeasonId);
        }
        else
        {
            _events = [];
            _quotas = new Dictionary<int, int?>();
            _links = new Dictionary<int, EventLinks>();
        }
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<Event> Sorted()
    {
        IEnumerable<Event> q = _sortCol switch
        {
            "name" => _events.OrderBy(e => e.Name),
            "status" => _events.OrderBy(e => e.Status),
            _ => _events.OrderBy(e => e.Date).ThenBy(e => e.StartTime),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static string StatusLabel(EventStatus status) => status switch
    {
        EventStatus.Open => "Öffentlich",
        EventStatus.Intern => "Intern",
        EventStatus.Closed => "Geschlossen",
        _ => "Entwurf"
    };

    private (int EventId, bool Intern)? _copied;
    private bool IsCopied(int eventId, bool intern) => _copied is { } c && c.EventId == eventId && c.Intern == intern;

    private async Task Copy(int eventId, bool intern, string? relative)
    {
        if (string.IsNullOrEmpty(relative)) return;
        var origin = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
        var absolute = relative.StartsWith("http") ? relative : origin + relative;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", absolute);
            _copied = (eventId, intern);
            StateHasChanged();
            await Task.Delay(1500);
            if (IsCopied(eventId, intern)) { _copied = null; StateHasChanged(); }
        }
        catch { }
    }

    private Event? _editing;
    private EventStatus _editStatus;
    private int? _editQuota;
    private bool _saving;
    private string? _editError;

    private void OpenEdit(Event e)
    {
        _editing = e;
        _editStatus = e.Status;
        _editQuota = Quota(e.Id);
        _editError = null;
    }

    private void CancelEdit() { _editing = null; _editError = null; }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        if (_editQuota is < 0) { _editError = "Einlasskontingent darf nicht negativ sein."; return; }
        _saving = true;
        _editError = null;
        try
        {
            await StatusEditor.SetStatusAsync(_editing.Id, _editStatus);
            await QuotaEditor.SetAsync(_editing.Id, _editQuota);
            _editing = null;
            await ReloadEventsAsync();
        }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private sealed class CategoryRow
    {
        public TicketCategory Category { get; init; }
        public bool Enabled { get; set; }
        public decimal Price { get; set; }
        public int? Quota { get; set; }
    }

    private Event? _pricingEvent;
    private EventPrice? _pricingExisting;
    private List<CategoryRow> _priceRows = [];
    private bool _pricingSaving;
    private string? _pricingError;

    private async Task OpenPricing(Event e)
    {
        _pricingEvent = e;
        _pricingError = null;
        _pricingExisting = await Prices.GetByEventAsync(e.Id);
        var byCategory = (_pricingExisting?.Categories ?? []).ToDictionary(c => c.Category);
        _priceRows = Enum.GetValues<TicketCategory>()
            .Select(cat => byCategory.TryGetValue(cat, out var existing)
                ? new CategoryRow { Category = cat, Enabled = true, Price = existing.SalePrice, Quota = existing.Quota }
                : new CategoryRow { Category = cat, Enabled = false, Price = 0m, Quota = null })
            .ToList();
    }

    private void CancelPricing() { _pricingEvent = null; _pricingError = null; }

    private async Task SavePricing()
    {
        if (_pricingEvent is null) return;
        _pricingSaving = true;
        _pricingError = null;
        try
        {
            var categories = _priceRows
                .Where(r => r.Enabled)
                .Select(r => CategoryPrice.Create(r.Category, r.Price, r.Quota))
                .ToList();
            var price = EventPrice.FromPersistence(
                _pricingExisting?.Id ?? 0,
                _pricingEvent.Id,
                _pricingExisting?.TotalSalesQuota,
                _pricingExisting?.AdmissionQuota,
                categories);
            await Prices.SaveAsync(price);
            _pricingEvent = null;
        }
        catch (Exception ex) { _pricingError = ex.Message; }
        finally { _pricingSaving = false; }
    }
}
