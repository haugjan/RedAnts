@using RedAnts.Domain.Ticketing.Sales
@using Microsoft.AspNetCore.WebUtilities
@implements IDisposable
@inject NavigationManager Navigation

<div class="ta-app">
    <nav class="ta-subnav">
        @foreach (var t in Tabs)
        {
            <button type="button"
                    class="ta-subnav-btn @(_tab == t.Key ? "active" : "")"
                    @onclick="() => SelectTab(t.Key)">
                @t.Label
            </button>
        }
    </nav>

    <main class="ta-content">
        <CascadingValue Value="Identity">
            @switch (_tab)
            {
                case "seasons":
                    <AdminSeasonsComponent AdminUser="@AdminUser" />
                    break;
                case "tickets":
                    <AdminTicketsComponent AdminUser="@AdminUser" />
                    break;
                case "flextickets":
                    <AdminFlexTicketsComponent AdminUser="@AdminUser" />
                    break;
                case "seasoncards":
                    <AdminSeasonCardsComponent AdminUser="@AdminUser" />
                    break;
                case "membercards":
                    <AdminMemberCardsComponent AdminUser="@AdminUser" />
                    break;
                case "freeentries":
                    <AdminFreeEntriesComponent AdminUser="@AdminUser" />
                    break;
                case "orders":
                    <AdminOrdersComponent AdminUser="@AdminUser" />
                    break;
                case "newsletter":
                    <AdminNewsletterComponent AdminUser="@AdminUser" />
                    break;
                case "helper":
                    <AdminHelpersComponent AdminUser="@AdminUser" />
                    break;
                default:
                    <AdminEventsComponent AdminUser="@AdminUser" />
                    break;
            }
        </CascadingValue>
    </main>
</div>

<style>
    :root {
        --ta-nav: #1b264f;
        --ta-accent: #5dade2;
        --ta-ink: #1b264f;
        --ta-muted: #68676b;
        --ta-border: #e9e9eb;
        --ta-font: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .ta-app {
        font-family: var(--ta-font);
        color: var(--ta-ink);
        min-height: 100vh;
        display: flex; flex-direction: column;
        background: #f4f4f4;
    }

    .ta-subnav {
        display: flex; align-items: stretch; flex-wrap: wrap;
        padding: 0 0.5rem;
        background: var(--ta-nav);
        flex-shrink: 0;
    }
    .ta-subnav-btn {
        appearance: none; background: none; border: none; cursor: pointer;
        font-family: var(--ta-font);
        font-size: 0.9rem; font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        padding: 0.8rem 1.1rem;
        border-bottom: 3px solid transparent;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
    }
    .ta-subnav-btn:hover { color: #fff; background: rgba(255, 255, 255, 0.08); }
    .ta-subnav-btn.active { color: #fff; border-bottom-color: var(--ta-accent); }

    .ta-content { padding: 1.75rem 1.5rem 3rem; flex: 1; min-width: 0; }

    .ta-page-title {
        font-family: var(--ta-font);
        font-size: 1.5rem; font-weight: 700;
        color: var(--ta-ink);
        margin: 0 0 1.25rem;
    }
    .ta-placeholder {
        background: #fff; border: 1px solid var(--ta-border); border-radius: 3px;
        padding: 1.5rem; color: var(--ta-muted);
    }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";
    [Parameter] public string? AdminEmail { get; set; }

    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private AdminIdentity Identity => new(AdminUser, AdminEmail);

    private string _tab = "seasons";
    private bool _ready;

    protected override void OnInitialized()
    {
        var query = QueryHelpers.ParseQuery(new Uri(Navigation.Uri).Query);
        if (query.TryGetValue("tab", out var tab) && Tabs.Any(t => t.Key == tab)) _tab = tab!;
        if (query.TryGetValue("season", out var season) && int.TryParse(season, out var seasonId))
            AdminState.SelectedSeasonId = seasonId;
        if (query.TryGetValue("event", out var evt) && int.TryParse(evt, out var eventId))
            AdminState.SelectedEventId = eventId;
        if (query.TryGetValue("bundle", out var bundle) && int.TryParse(bundle, out var bundleId))
            AdminState.SelectedBundleId = bundleId;
        AdminState.Changed += OnStateChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _ready = true;
        WriteUrl();
    }

    private void SelectTab(string key)
    {
        if (_tab == key) return;
        _tab = key;
        if (_ready) WriteUrl();
    }

    private void OnStateChanged()
    {
        if (_ready) WriteUrl();
    }

    private void WriteUrl()
    {
        var showEvent = _tab is "tickets" or "freeentries";
        var showBundle = _tab is "flextickets";
        var url = Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = _tab,
            ["season"] = AdminState.SelectedSeasonId,
            ["event"] = showEvent ? AdminState.SelectedEventId : null,
            ["bundle"] = showBundle ? AdminState.SelectedBundleId : null
        });
        Navigation.NavigateTo(url, forceLoad: false, replace: true);
    }

    public void Dispose() => AdminState.Changed -= OnStateChanged;

    private static readonly (string Key, string Label)[] Tabs =
    [
        ("seasons", "Saisons"),
        ("events", "Anlässe"),
        ("tickets", TicketType.EventTicket.DisplayName()),
        ("flextickets", TicketType.SeasonSingle.DisplayName()),
        ("freeentries", TicketType.FreeEntry.DisplayName()),
        ("seasoncards", TicketType.SeasonPass.DisplayName()),
        ("membercards", TicketType.MemberCard.DisplayName()),
        ("orders", "Bestellungen"),
        ("newsletter", "Newsletter"),
        ("helper", "Helfer")
    ];
}
