@* Root of the backoffice "Ticketing" admin app, shown inside a section-dashboard iframe.
   The sub-navigation is NOT rendered here: each tab is its own native Umbraco dashboard, so the
   backoffice tab bar drives navigation and the browser URL. This component only renders the single
   tab it was opened with (passed as ?tab= → Tab), keeping every tab deep-linkable. *@

<div class="ta-app">
    <main class="ta-content">
        @switch (_tab)
        {
            case "tickets":
                <AdminTicketsComponent AdminUser="@AdminUser" />
                break;
            case "seasoncards":
                <AdminSeasonCardsComponent AdminUser="@AdminUser" />
                break;
            case "membercards":
                <AdminMemberCardsComponent AdminUser="@AdminUser" />
                break;
            default:
                <AdminEventsComponent AdminUser="@AdminUser" />
                break;
        }
    </main>
</div>

<style>
    /* Match the Umbraco backoffice look: Lato, neutral greys, blue accent (no Red Ants branding). */
    :root {
        --ta-nav: #1b264f;      /* Umbraco header navy */
        --ta-accent: #5dade2;   /* active-tab indicator */
        --ta-ink: #1b264f;      /* headings / primary text */
        --ta-muted: #68676b;    /* secondary text */
        --ta-border: #e9e9eb;   /* Umbraco surface border */
        --ta-font: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .ta-app {
        font-family: var(--ta-font);
        color: var(--ta-ink);
        min-height: 100vh;
        display: flex; flex-direction: column;
        background: #f4f4f4;
    }

    .ta-content { padding: 1.75rem 1.5rem 3rem; max-width: 1100px; flex: 1; }

    .ta-page-title {
        font-family: var(--ta-font);
        font-size: 1.5rem; font-weight: 700;
        color: var(--ta-ink);
        margin: 0 0 0.35rem;
    }
    .ta-page-lead { color: var(--ta-muted); margin: 0 0 1.25rem; }
    .ta-placeholder {
        background: #fff; border: 1px solid var(--ta-border); border-radius: 3px;
        padding: 1.5rem; color: var(--ta-muted);
    }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    /// <summary>Which tab to render; set from the iframe's <c>?tab=</c> (native dashboard pathname).</summary>
    [Parameter] public string Tab { get; set; } = "events";

    private string _tab = "events";

    protected override void OnParametersSet() => _tab = Tab;
}
