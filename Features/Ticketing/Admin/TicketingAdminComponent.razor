@* Root of the backoffice "Ticketing" admin app, shown inside the single section-dashboard iframe.
   Tabs are in-app state (no Blazor Router / native dashboards) — this fills the section content
   reliably. Styled to match the Umbraco backoffice (Lato, navy bar, blue active indicator). *@

<div class="ta-app">
    <nav class="ta-subnav">
        @foreach (var t in Tabs)
        {
            <button type="button"
                    class="ta-subnav-btn @(_tab == t.Key ? "active" : "")"
                    @onclick="() => _tab = t.Key">
                @t.Label
            </button>
        }
    </nav>

    <main class="ta-content">
        @switch (_tab)
        {
            case "tickets":
                <AdminTicketsComponent AdminUser="@AdminUser" />
                break;
            case "seasoncards":
                <AdminSeasonCardsComponent AdminUser="@AdminUser" />
                break;
            case "membercards":
                <AdminMemberCardsComponent AdminUser="@AdminUser" />
                break;
            default:
                <AdminEventsComponent AdminUser="@AdminUser" />
                break;
        }
    </main>
</div>

<style>
    /* Match the Umbraco backoffice look: Lato, neutral greys, blue accent (no Red Ants branding). */
    :root {
        --ta-nav: #1b264f;      /* Umbraco header navy */
        --ta-accent: #5dade2;   /* active-tab indicator */
        --ta-ink: #1b264f;      /* headings / primary text */
        --ta-muted: #68676b;    /* secondary text */
        --ta-border: #e9e9eb;   /* Umbraco surface border */
        --ta-font: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .ta-app {
        font-family: var(--ta-font);
        color: var(--ta-ink);
        min-height: 100vh;
        display: flex; flex-direction: column;
        background: #f4f4f4;
    }

    /* Sub-navigation bar, flush under the Umbraco section nav and in the same navy. */
    .ta-subnav {
        display: flex; align-items: stretch; flex-wrap: wrap;
        padding: 0 0.5rem;
        background: var(--ta-nav);
        flex-shrink: 0;
    }
    .ta-subnav-btn {
        appearance: none; background: none; border: none; cursor: pointer;
        font-family: var(--ta-font);
        font-size: 0.9rem; font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        padding: 0.8rem 1.1rem;
        border-bottom: 3px solid transparent;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
    }
    .ta-subnav-btn:hover { color: #fff; background: rgba(255, 255, 255, 0.08); }
    .ta-subnav-btn.active { color: #fff; border-bottom-color: var(--ta-accent); }

    .ta-content { padding: 1.75rem 1.5rem 3rem; max-width: 1100px; flex: 1; }

    .ta-page-title {
        font-family: var(--ta-font);
        font-size: 1.5rem; font-weight: 700;
        color: var(--ta-ink);
        margin: 0 0 0.35rem;
    }
    .ta-page-lead { color: var(--ta-muted); margin: 0 0 1.25rem; }
    .ta-placeholder {
        background: #fff; border: 1px solid var(--ta-border); border-radius: 3px;
        padding: 1.5rem; color: var(--ta-muted);
    }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    private string _tab = "events";

    private static readonly (string Key, string Label)[] Tabs =
    [
        ("events", "Anlässe"),
        ("tickets", "Tickets"),
        ("seasoncards", "Saisonkarten"),
        ("membercards", "Mitgliederkarten")
    ];
}
