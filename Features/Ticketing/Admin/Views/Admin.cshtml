@model RedAnts.Features.Ticketing.Admin.AdminIdentity
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Ticketing Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/ticketing-admin.css?v=4" />
    <style>
        html, body {
            height: 100%; margin: 0; background: #f4f4f4;
            font-family: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
    </style>
</head>
<body>
    <component type="typeof(RedAnts.Features.Ticketing.Admin.TicketingAdminComponent)"
               render-mode="Server"
               param-AdminUser="@Model.Name"
               param-AdminEmail="@Model.Email" />
    <script src="/_framework/blazor.server.js"></script>
    <script>
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            var overlay = document.querySelector('.ta-overlay');
            if (!overlay) return;
            var cancel = overlay.querySelector('.ta-modal-actions .ta-btn-ghost');
            if (cancel && !cancel.disabled) cancel.click();
        });
        window.redants = window.redants || {};
        window.redants.showPicker = function (el) {
            if (!el) return;
            try { el.showPicker(); }
            catch (e) { el.focus(); }
        };
        window.redants.setValue = function (el, v) { if (el) el.value = v; };
        window.redants.selectAll = function (el) { if (el && el.select) el.select(); };
    </script>
</body>
</html>
