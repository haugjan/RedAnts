@using RedAnts.Domain.Ticketing.Sales
@inject ISeasonPassAdminReport Report
@inject ISeasonPasses Passes

<section class="ta-page">
    <h1 class="ta-page-title">Saisonkarten</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="spSeasonSelect">Saison</label>
                    <select id="spSeasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadPassesAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                @if (_passes.Count > 0)
                {
                    <a class="ta-btn ta-btn-ghost" href="/admin/saisonkarten/season/@SelectedSeasonId/passes.csv"
                       target="_blank" rel="noopener" title="Saisonkarten dieser Saison als CSV herunterladen">⬇ CSV</a>
                }
                <button type="button" class="ta-btn ta-btn-primary" disabled="@(SelectedSeasonId <= 0)" @onclick="OpenCreate">
                    Saisonkarte erstellen
                </button>
            </div>
        </div>

        @if (_passes.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Saisonkarten ausgestellt.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Karten-Nr.</th>
                            <th class="ta-th-sort" @onclick='() => Sort("buyer")'>Käufer:in <span class="ta-sort-ind">@Ind("buyer")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("created")'>Erstellt <span class="ta-sort-ind">@Ind("created")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("category")'>Kategorie <span class="ta-sort-ind">@Ind("category")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("price")'>Preis <span class="ta-sort-ind">@Ind("price")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("status")'>Status <span class="ta-sort-ind">@Ind("status")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("visits")'>Event&shy;besuche <span class="ta-sort-ind">@Ind("visits")</span></th>
                            <th>Zahlung</th>
                            <th>Bestell-Nr.</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Sorted())
                        {
                            <tr>
                                <td>
                                    <span class="ta-ticketno">@AdminFormat.TicketNo(p.Uuid)</span>
                                    <a class="ta-qr-link" href="/ticket/for/@p.Uuid" target="_blank" rel="noopener" title="Online-Ticket" aria-label="Online-Ticket">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17 14h.01M20 14v3M14 17h.01M17 20h3M20 20h.01"/></svg>
                                    </a>
                                </td>
                                <td class="ta-cell-name">
                                    @if (p.BuyerName is not null)
                                    {
                                        @p.BuyerName
                                        @if (p.BuyerType is { } bt) { <span class="ta-badge ta-badge-buyer">@bt.DisplayName()</span> }
                                    }
                                    else { <span class="ta-muted">—</span> }
                                </td>
                                <td title="@AdminFormat.CreatedTooltip(p.CreatedAt, p.CreatedByName, null, OnlineMarker(p))">@AdminFormat.CreatedShort(p.CreatedAt, p.CreatedByName, OnlineMarker(p))</td>
                                <td>
                                    <InlineSelectEdit TValue="TicketCategory" Value="p.Category" FieldLabel="Kategorie"
                                                      Options="CategoryOptions" Label="@(c => c.DisplayName())"
                                                      Save="@(v => SaveCategoryAsync(p, v))" />
                                </td>
                                <td class="ta-num">CHF @p.Price.ToString("N2")</td>
                                <td>
                                    <InlineSelectEdit TValue="TicketStatus" Value="p.Status" FieldLabel="Status"
                                                      Options="StatusOptions" Label="@StatusLabel"
                                                      Save="@(v => SaveStatusAsync(p, v))">
                                        <Display Context="st">
                                            <span class="ta-badge ta-badge-@st.ToString().ToLowerInvariant()">@StatusLabel(st)</span>
                                        </Display>
                                    </InlineSelectEdit>
                                </td>
                                <td class="ta-num">
                                    @if (p.EventVisits > 0)
                                    {
                                        <button type="button" class="ta-visits-link" @onclick="() => OpenVisits(p)">@p.EventVisits</button>
                                    }
                                    else
                                    {
                                        <span class="ta-muted">0</span>
                                    }
                                </td>
                                <td>@(p.PaymentState ?? "–")</td>
                                <td>@(p.OrderNumber ?? "–")</td>
                                <td class="ta-col-actions">
                                    <button type="button" class="ta-icon-btn" title="Bearbeiten" @onclick="() => OpenEdit(p)">✎</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="ta-summary">@_passes.Count Saisonkarte@(_passes.Count == 1 ? "" : "n") · Total CHF @_passes.Sum(p => p.Price).ToString("N2")</p>
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Saisonkarte erstellen</h2>

            <div class="ta-field">
                <label class="ta-label" for="newSpBuyerType">Käufer:in</label>
                <select id="newSpBuyerType" class="ta-select" @bind="_newBuyerType">
                    <option value="@BuyerType.Private">Privatperson</option>
                    <option value="@BuyerType.Company">Firma</option>
                </select>
            </div>
            @if (_newBuyerType == BuyerType.Company)
            {
                <div class="ta-field">
                    <label class="ta-label" for="newSpCompany">Firmenname</label>
                    <input id="newSpCompany" class="ta-input" @bind="_newCompany" />
                </div>
            }
            else
            {
                <div class="ta-field">
                    <label class="ta-label" for="newSpFirstName">Vorname</label>
                    <input id="newSpFirstName" class="ta-input" @bind="_newFirstName" />
                </div>
                <div class="ta-field">
                    <label class="ta-label" for="newSpLastName">Nachname</label>
                    <input id="newSpLastName" class="ta-input" @bind="_newLastName" />
                </div>
            }

            <div class="ta-field">
                <label class="ta-label" for="newSpCategory">Kategorie</label>
                <select id="newSpCategory" class="ta-select" @bind="_newCategory">
                    @foreach (var c in Enum.GetValues<TicketCategory>())
                    {
                        <option value="@c">@c.DisplayName()</option>
                    }
                </select>
            </div>

            <div class="ta-field">
                <label class="ta-label" for="newSpPrice">Preis (CHF)</label>
                <input id="newSpPrice" type="number" step="0.01" min="0" class="ta-input" @bind="_newPrice" />
            </div>

            @if (_createError is not null)
            {
                <p class="ta-modal-error">@_createError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate" disabled="@_creating">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="CreatePassAsync" disabled="@_creating">
                    @(_creating ? "Erstellt …" : "Erstellen")
                </button>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Saisonkarte bearbeiten</h2>
            <p class="ta-modal-sub">Karten-Nr. @AdminFormat.TicketNo(_editing.Uuid)</p>

            <div class="ta-field">
                <label class="ta-label" for="editBuyerType">Käufer:in</label>
                <select id="editBuyerType" class="ta-select" @bind="_editBuyerType">
                    <option value="@BuyerType.Private">Privatperson</option>
                    <option value="@BuyerType.Company">Firma</option>
                </select>
            </div>
            @if (_editBuyerType == BuyerType.Company)
            {
                <div class="ta-field">
                    <label class="ta-label" for="editCompany">Firmenname</label>
                    <input id="editCompany" class="ta-input" @bind="_editCompany" />
                </div>
            }
            else
            {
                <div class="ta-field">
                    <label class="ta-label" for="editFirstName">Vorname</label>
                    <input id="editFirstName" class="ta-input" @bind="_editFirstName" />
                </div>
                <div class="ta-field">
                    <label class="ta-label" for="editLastName">Nachname</label>
                    <input id="editLastName" class="ta-input" @bind="_editLastName" />
                </div>
            }

            <div class="ta-field">
                <label class="ta-label" for="editCategory">Kategorie</label>
                <select id="editCategory" class="ta-select" @bind="_editCategory">
                    @foreach (var c in Enum.GetValues<TicketCategory>())
                    {
                        <option value="@c">@c.DisplayName()</option>
                    }
                </select>
            </div>

            <div class="ta-field">
                <label class="ta-label" for="editPrice">Preis (CHF)</label>
                <input id="editPrice" type="number" step="0.01" min="0" class="ta-input" @bind="_editPrice" />
            </div>

            <div class="ta-field">
                <label class="ta-label" for="editStatus">Status</label>
                <select id="editStatus" class="ta-select" @bind="_editStatus">
                    @foreach (var st in Enum.GetValues<TicketStatus>())
                    {
                        <option value="@st">@StatusLabel(st)</option>
                    }
                </select>
            </div>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEdit" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_visitsPass is not null)
{
    <VisitsOverlay Uuid="_visitsPass.Uuid" Title="@(_visitsPass.BuyerName ?? AdminFormat.TicketNo(_visitsPass.Uuid))" OnClose="CloseVisits" />
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";
    [CascadingParameter] public AdminIdentity Identity { get; set; } = new("admin", null);

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<SeasonPassListItem> _passes = [];

    public int SelectedSeasonId { get; set; }

    private string _sortCol = "buyer";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadPassesAsync();
        _loading = false;
    }

    private async Task ReloadPassesAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _passes = SelectedSeasonId > 0 ? await Report.GetBySeasonAsync(SelectedSeasonId) : [];
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<SeasonPassListItem> Sorted()
    {
        IEnumerable<SeasonPassListItem> q = _sortCol switch
        {
            "category" => _passes.OrderBy(p => p.Category),
            "price" => _passes.OrderBy(p => p.Price),
            "status" => _passes.OrderBy(p => p.Status),
            "visits" => _passes.OrderBy(p => p.EventVisits),
            "created" => _passes.OrderBy(p => p.CreatedAt),
            _ => _passes.OrderBy(p => p.BuyerName ?? "￿"),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static int? OnlineMarker(SeasonPassListItem p) => p.OrderNumber is null ? null : 0;

    private static readonly TicketCategory[] CategoryOptions = Enum.GetValues<TicketCategory>();
    private static readonly TicketStatus[] StatusOptions = [TicketStatus.Valid, TicketStatus.Cancelled];

    private async Task SaveCategoryAsync(SeasonPassListItem p, TicketCategory category)
    {
        var pass = await Passes.GetByUuidAsync(p.Uuid);
        if (pass is null) return;
        pass.Edit(category, pass.Price, pass.Status);
        await Passes.SaveAsync(pass);
        await ReloadPassesAsync();
    }

    private async Task SaveStatusAsync(SeasonPassListItem p, TicketStatus status)
    {
        var pass = await Passes.GetByUuidAsync(p.Uuid);
        if (pass is null) return;
        pass.Edit(pass.Category, pass.Price, status);
        await Passes.SaveAsync(pass);
        await ReloadPassesAsync();
    }

    private SeasonPassListItem? _visitsPass;
    private void OpenVisits(SeasonPassListItem p) => _visitsPass = p;
    private void CloseVisits() => _visitsPass = null;

    private static string StatusLabel(TicketStatus status) => status switch
    {
        TicketStatus.Valid => "Gültig",
        TicketStatus.Cancelled => "Storniert",
        TicketStatus.Blocked => "Gesperrt",
        _ => status.ToString()
    };

    private bool _showCreate;
    private bool _creating;
    private TicketCategory _newCategory = TicketCategory.Adult;
    private decimal _newPrice;
    private BuyerType _newBuyerType = BuyerType.Private;
    private string _newFirstName = "";
    private string _newLastName = "";
    private string _newCompany = "";
    private string? _createError;

    private void OpenCreate()
    {
        _newCategory = TicketCategory.Adult;
        _newPrice = 0m;
        _newBuyerType = BuyerType.Private;
        _newFirstName = _newLastName = _newCompany = "";
        _createError = null;
        _showCreate = true;
    }
    private void CloseCreate() { _showCreate = false; _createError = null; }

    private async Task CreatePassAsync()
    {
        if (_creating) return;
        if (SelectedSeasonId <= 0) { _createError = "Es ist keine Saison gewählt."; return; }
        if (_newPrice < 0) { _createError = "Der Preis darf nicht negativ sein."; return; }
        _creating = true;
        _createError = null;
        try
        {
            var buyer = Buyer.Create(_newBuyerType, _newFirstName, _newLastName, _newCompany);
            await Passes.SaveAsync(SeasonPass.Create(SelectedSeasonId, _newCategory, _newPrice, null,
                buyer, Identity.Name, Identity.Email));
            _showCreate = false;
            await ReloadPassesAsync();
        }
        catch (DomainException ex) { _createError = ex.Message; }
        finally { _creating = false; }
    }

    private SeasonPassListItem? _editing;
    private TicketCategory _editCategory;
    private decimal _editPrice;
    private TicketStatus _editStatus;
    private BuyerType _editBuyerType = BuyerType.Private;
    private string _editFirstName = "";
    private string _editLastName = "";
    private string _editCompany = "";
    private bool _saving;
    private string? _editError;

    private async Task OpenEdit(SeasonPassListItem pass)
    {
        _editing = pass;
        _editCategory = pass.Category;
        _editPrice = decimal.Round(pass.Price, 2);
        _editStatus = pass.Status;
        _editFirstName = _editLastName = _editCompany = "";
        _editBuyerType = BuyerType.Private;

        var current = await Passes.GetByUuidAsync(pass.Uuid);
        if (current?.Buyer is { } b)
        {
            _editBuyerType = b.Type;
            _editFirstName = b.FirstName ?? "";
            _editLastName = b.LastName ?? "";
            _editCompany = b.Company ?? "";
        }
        _editError = null;
    }

    private void CancelEdit() { _editing = null; _editError = null; }

    private async Task SaveEdit()
    {
        if (_editing is null || _saving) return;
        _saving = true;
        _editError = null;
        try
        {
            var pass = await Passes.GetByUuidAsync(_editing.Uuid);
            if (pass is null) { _editError = "Diese Saisonkarte wurde nicht gefunden."; return; }

            pass.Edit(_editCategory, _editPrice, _editStatus);
            pass.SetBuyer(Buyer.Create(_editBuyerType, _editFirstName, _editLastName, _editCompany));
            await Passes.SaveAsync(pass);

            _editing = null;
            await ReloadPassesAsync();
        }
        catch (DomainException ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }
}
