@using RedAnts.Domain.Ticketing.Sales
@inject IOrderAdminReport Report

<section class="ta-page">
    <h1 class="ta-page-title">Bestellungen</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="ordSeasonSelect">Saison</label>
                    <select id="ordSeasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadOrdersAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="ta-field ta-field--grow">
                    <label class="ta-label" for="ordSearch">Suche</label>
                    <input id="ordSearch" type="search" class="ta-input ta-orders-search"
                           placeholder="Name, E-Mail, Ort, PLZ, Bestell-Nr., Kategorie …"
                           @bind="_search" @bind:event="oninput" />
                </div>
            </div>
        </div>

        @if (_orders.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Onlineeinkäufe vorhanden.</div>
        }
        else
        {
            var shown = Sorted().ToList();
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Bestell-Nr.</th>
                            <th class="ta-th-sort" @onclick='() => Sort("buyer")'>Adresse <span class="ta-sort-ind">@Ind("buyer")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("created")'>Kaufdatum <span class="ta-sort-ind">@Ind("created")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("status")'>Bezahlt <span class="ta-sort-ind">@Ind("status")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("amount")'>Betrag <span class="ta-sort-ind">@Ind("amount")</span></th>
                            <th>Zahlart</th>
                            <th>Spieltickets</th>
                            <th>Saisonkarten</th>
                            <th>Flextickets</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in shown)
                        {
                            <tr>
                                <td><code class="ta-uuid">@o.OrderNumber</code></td>
                                <td class="ta-cell-address">
                                    <div class="ta-addr-name">
                                        @o.BuyerName
                                        @if (o.BuyerType == BuyerType.Company)
                                        {
                                            <span class="ta-badge ta-badge-buyer">@o.BuyerType.DisplayName()</span>
                                        }
                                    </div>
                                    <div>@o.Street@(string.IsNullOrWhiteSpace(o.AddressLine2) ? "" : $", {o.AddressLine2}")</div>
                                    <div>@o.PostalCode @o.City@(IsSwitzerland(o.Country) ? "" : $", {o.Country}")</div>
                                    <div class="ta-addr-sub">@o.Email</div>
                                </td>
                                <td>@o.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <span class="ta-badge @StatusClass(o.Status)">@StatusLabel(o.Status)</span>
                                    @{ var actions = ActionsFor(o.Status); }
                                    @if (actions.Length > 0)
                                    {
                                        <div class="ta-status-actions">
                                            @foreach (var a in actions)
                                            {
                                                <button type="button" class="ta-link-btn @(a == OrderAction.Refund ? "ta-link-danger" : "")"
                                                        @onclick="() => Ask(o, a)">@ActionLabel(a)</button>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="ta-num">CHF @o.TotalGross.ToString("N2")</td>
                                <td>@(o.PaymentSource is { } ps ? ps.DisplayName() : "—")</td>
                                <td class="ta-cell-summary">@Cell(o.EventTicketCount, o.EventTicketSummary)</td>
                                <td class="ta-cell-summary">@Cell(o.SeasonPassCount, o.SeasonPassSummary)</td>
                                <td class="ta-cell-summary">@Cell(o.FlexTicketCount, o.FlexTicketSummary)</td>
                                <td class="ta-col-actions">
                                    <button type="button" class="ta-icon-btn" title="Positionen anzeigen" @onclick="() => OpenItems(o)">📦</button>
                                    <button type="button" class="ta-icon-btn" title="Bestellverlauf" @onclick="() => OpenLog(o)">🧾</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (shown.Count == 0)
            {
                <div class="ta-placeholder">Keine Bestellung passt zur Suche „@_search".</div>
            }
            <p class="ta-summary">
                @if (!string.IsNullOrWhiteSpace(_search))
                {
                    <text>@shown.Count von @_orders.Count Bestellungen · </text>
                }
                else
                {
                    <text>@_orders.Count Bestellung@(_orders.Count == 1 ? "" : "en") · </text>
                }
                @shown.Count(o => o.Status == OrderStatus.Paid) bezahlt ·
                @shown.Count(o => o.Status != OrderStatus.Paid) offen ·
                Total bezahlt CHF @shown.Where(o => o.Status == OrderStatus.Paid).Sum(o => o.TotalGross).ToString("N2")
            </p>
        }
    }
</section>

@if (_logOrder is not null)
{
    <OrderLogOverlay OrderId="_logOrder.OrderId" Title="@_logOrder.OrderNumber" OnClose="CloseLog" />
}

@if (_itemsOrder is not null)
{
    <OrderItemsOverlay OrderId="_itemsOrder.OrderId" Title="@_itemsOrder.OrderNumber" OnClose="CloseItems" />
}

@if (_actionOrder is not null)
{
    <ConfirmDialog Title="@ActionTitle(_action)"
                   Message="@ActionMessage(_action, _actionOrder)"
                   ConfirmLabel="@ActionLabel(_action)"
                   Danger="@(_action != OrderAction.MarkPaid)"
                   Busy="_actionBusy"
                   Error="@_actionError"
                   OnConfirm="ConfirmActionAsync"
                   OnCancel="CancelAction">
        @if (_action == OrderAction.Refund)
        {
            @if (_refundOnlineAvailable)
            {
                <div class="ta-refund-choice">
                    <label class="ta-radio">
                        <input type="radio" name="refundMethod" checked="@_refundViaPayrexx" @onchange="() => _refundViaPayrexx = true" />
                        <span>Direkt über Payrexx zurückerstatten</span>
                    </label>
                    <label class="ta-radio">
                        <input type="radio" name="refundMethod" checked="@(!_refundViaPayrexx)" @onchange="() => _refundViaPayrexx = false" />
                        <span>Auf anderem Weg erledigt (nur vermerken)</span>
                    </label>
                </div>
            }
            else
            {
                <p class="ta-modal-note">Diese Bestellung wurde nicht online über Payrexx bezahlt. Die Rückerstattung wird nur als erledigt vermerkt.</p>
            }
        }
    </ConfirmDialog>
}

<style>
    .ta-field--grow { flex: 1 1 18rem; }
    .ta-orders-search { width: 100%; min-width: 14rem; }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "";
    [CascadingParameter] public AdminIdentity Identity { get; set; } = new("admin", null);

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private IOrderStatusEditor StatusEditor { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private enum OrderAction { MarkPaid, Cancel, Refund }

    private OrderListItem? _actionOrder;
    private OrderAction _action;
    private bool _actionBusy;
    private string? _actionError;
    private bool _refundOnlineAvailable;
    private bool _refundViaPayrexx;

    private static OrderAction[] ActionsFor(OrderStatus status) => status switch
    {
        OrderStatus.Draft => [OrderAction.MarkPaid, OrderAction.Cancel],
        OrderStatus.Paid => [OrderAction.Cancel, OrderAction.Refund],
        _ => []
    };

    private void Ask(OrderListItem o, OrderAction action)
    {
        _actionOrder = o;
        _action = action;
        _actionError = null;
        _actionBusy = false;
        _refundOnlineAvailable = o.PaymentSource == PaymentSource.Online && o.TotalGross > 0m;
        _refundViaPayrexx = _refundOnlineAvailable;
    }

    private void CancelAction()
    {
        _actionOrder = null;
        _actionError = null;
    }

    private async Task ConfirmActionAsync()
    {
        if (_actionOrder is null) return;
        _actionBusy = true;
        _actionError = null;
        try
        {
            switch (_action)
            {
                case OrderAction.MarkPaid: await StatusEditor.SetStatusAsync(_actionOrder.OrderId, OrderStatus.Paid, Identity.Name); break;
                case OrderAction.Cancel: await StatusEditor.SetStatusAsync(_actionOrder.OrderId, OrderStatus.Cancelled, Identity.Name); break;
                case OrderAction.Refund: await StatusEditor.RefundAsync(_actionOrder.OrderId, _refundViaPayrexx, Identity.Name); break;
            }
            _actionOrder = null;
            await ReloadOrdersAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private static string ActionLabel(OrderAction action) => action switch
    {
        OrderAction.MarkPaid => "Als bezahlt",
        OrderAction.Cancel => "Stornieren",
        OrderAction.Refund => "Rückerstatten",
        _ => ""
    };

    private static string ActionTitle(OrderAction action) => action switch
    {
        OrderAction.MarkPaid => "Als bezahlt markieren",
        OrderAction.Cancel => "Bestellung stornieren",
        OrderAction.Refund => "Bestellung zurückerstatten",
        _ => "Bestätigen"
    };

    private static string ActionMessage(OrderAction action, OrderListItem o) => action switch
    {
        OrderAction.MarkPaid => $"Bestellung {o.OrderNumber} als bezahlt markieren?",
        OrderAction.Cancel => $"Bestellung {o.OrderNumber} stornieren? Dies kann nicht rückgängig gemacht werden.",
        OrderAction.Refund => $"Bestellung {o.OrderNumber} über CHF {o.TotalGross:N2} zurückerstatten? Dies kann nicht rückgängig gemacht werden.",
        _ => ""
    };

    private OrderListItem? _logOrder;
    private void OpenLog(OrderListItem o) => _logOrder = o;
    private void CloseLog() => _logOrder = null;

    private OrderListItem? _itemsOrder;
    private void OpenItems(OrderListItem o) => _itemsOrder = o;
    private void CloseItems() => _itemsOrder = null;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<OrderListItem> _orders = [];
    private string _search = "";

    public int SelectedSeasonId { get; set; }

    private string _sortCol = "created";
    private bool _sortAsc = false;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadOrdersAsync();
        _loading = false;
    }

    private async Task ReloadOrdersAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        if (SelectedSeasonId <= 0) { _orders = []; return; }
        var eventIds = (await Events.GetBySeasonAsync(SelectedSeasonId)).Select(e => e.Id).ToList();
        _orders = await Report.GetBySeasonAsync(SelectedSeasonId, eventIds);
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<OrderListItem> Sorted()
    {
        var src = Filtered();
        IEnumerable<OrderListItem> q = _sortCol switch
        {
            "buyer" => src.OrderBy(o => o.BuyerName),
            "amount" => src.OrderBy(o => o.TotalGross),
            "status" => src.OrderBy(o => o.Status),
            _ => src.OrderBy(o => o.CreatedAt),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private IEnumerable<OrderListItem> Filtered()
    {
        var terms = (_search ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return terms.Length == 0
            ? _orders
            : _orders.Where(o => terms.All(t => Haystack(o).Contains(t, StringComparison.OrdinalIgnoreCase)));
    }

    private static string Haystack(OrderListItem o) => string.Join(' ', new[]
    {
        o.OrderNumber, o.BuyerName, o.Email, o.Street, o.AddressLine2 ?? "", o.PostalCode, o.City, o.Country,
        o.EventTicketSummary, o.SeasonPassSummary, o.FlexTicketSummary,
        o.PaymentSource is { } ps ? ps.DisplayName() : "", StatusLabel(o.Status)
    });

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static bool IsSwitzerland(string country) =>
        string.IsNullOrWhiteSpace(country) || country.Equals("Schweiz", StringComparison.OrdinalIgnoreCase);

    private static string Cell(int count, string summary) => count == 0 ? "—" : summary;

    private static string StatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.Paid => "Bezahlt",
        OrderStatus.Draft => "Unbezahlt",
        OrderStatus.Cancelled => "Storniert",
        OrderStatus.Refunded => "Erstattet",
        _ => status.ToString()
    };

    private static string StatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Paid => "ta-badge-valid",
        OrderStatus.Draft => "ta-badge-draft",
        OrderStatus.Cancelled => "ta-badge-cancelled",
        OrderStatus.Refunded => "ta-badge-intern",
        _ => "ta-badge-draft"
    };
}
