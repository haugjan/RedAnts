@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Ports

<div class="ta-overlay" @onmousedown="Close">
    <div class="ta-modal ta-modal-visits" @onmousedown:stopPropagation="true">
        <h2 class="ta-modal-title">Bestellpositionen</h2>
        <p class="ta-modal-sub">@Title</p>

        @if (_loading)
        {
            <p class="ta-muted-text">Wird geladen …</p>
        }
        else if (_items.Count == 0)
        {
            <p class="ta-muted-text">Keine Positionen erfasst.</p>
        }
        else
        {
            <table class="ta-subtable">
                <thead>
                    <tr>
                        <th>Art</th>
                        <th>Bezeichnung</th>
                        <th class="ta-num">Menge</th>
                        <th class="ta-num">Einzelpreis</th>
                        <th class="ta-num">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var it in _items)
                    {
                        <tr>
                            <td>@KindLabel(it.Kind)</td>
                            <td>@it.Label</td>
                            <td class="ta-num">@it.Quantity</td>
                            <td class="ta-num">CHF @it.UnitPrice.ToString("0.00")</td>
                            <td class="ta-num">CHF @it.LineTotal.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="ta-modal-actions">
            <button type="button" class="ta-btn ta-btn-ghost" @onclick="Close">Schliessen</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int OrderId { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    [Inject] private IOrderItems Items { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<OrderItem> _items = [];

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _items = await Items.GetByOrderAsync(OrderId);
        _loading = false;
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private static string KindLabel(OrderItemKind kind) => kind switch
    {
        OrderItemKind.EventTicket => "Spielticket",
        OrderItemKind.SeasonSingle => "Flexticket",
        OrderItemKind.SeasonPass => "Saisonkarte",
        OrderItemKind.MemberCard => "Mitgliederkarte",
        OrderItemKind.AddOn => "Zusatzoption",
        _ => kind.ToString()
    };
}
