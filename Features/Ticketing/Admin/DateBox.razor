@using System.Globalization
@inject IJSRuntime JS

<span class="ta-datebox">
    <input type="text" class="ta-input ta-datebox-text" placeholder="TT.MM.JJJJ" inputmode="numeric"
           value="@_text" @onchange="OnTextChanged" disabled="@Disabled" />
    <button type="button" class="ta-datebox-cal" title="Kalender öffnen" tabindex="-1"
            @onclick="OpenPickerAsync" disabled="@Disabled">📅</button>
    <input type="date" class="ta-datebox-native" @ref="_native" tabindex="-1" aria-hidden="true"
           value="@(Value?.ToString("yyyy-MM-dd"))" @onchange="OnNativeChanged" disabled="@Disabled" />
</span>

@code {
    [Parameter] public DateOnly? Value { get; set; }
    [Parameter] public EventCallback<DateOnly?> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private ElementReference _native;
    private string _text = "";

    private static readonly string[] Formats = ["dd.MM.yyyy", "d.M.yyyy", "dd.MM.yy", "d.M.yy", "yyyy-MM-dd"];

    protected override void OnParametersSet() => _text = Value?.ToString("dd.MM.yyyy") ?? "";

    private async Task OpenPickerAsync()
    {
        if (Disabled) return;
        try { await JS.InvokeVoidAsync("redants.showPicker", _native); }
        catch { }
    }

    private async Task OnNativeChanged(ChangeEventArgs e) =>
        await SetAsync(DateOnly.TryParse(e.Value?.ToString(), CultureInfo.InvariantCulture, out var d) ? d : null);

    private async Task OnTextChanged(ChangeEventArgs e)
    {
        var raw = (e.Value?.ToString() ?? "").Trim();
        if (raw.Length == 0) { await SetAsync(null); return; }
        await SetAsync(DateOnly.TryParseExact(raw, Formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d)
            ? d : Value);
    }

    private async Task SetAsync(DateOnly? value)
    {
        _text = value?.ToString("dd.MM.yyyy") ?? "";
        if (value == Value) return;
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }
}
