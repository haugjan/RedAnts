@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using RedAnts.Domain.Ticketing
@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Ports

<section class="ta-page">
    <h1 class="ta-page-title">Mitglieder</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="mcSeasonSelect">Saison</label>
                    <select id="mcSeasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadCardsAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="OpenExport" disabled="@(_cards.Count == 0)"
                        title="Mitglieder einer Referenz als CSV herunterladen">Mitglieder exportieren (CSV)</button>
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="OpenImport" disabled="@(SelectedSeasonId <= 0)">
                    Mitglieder importieren (CSV)
                </button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="OpenCreate" disabled="@(SelectedSeasonId <= 0)">
                    Mitgliederkarte erstellen
                </button>
            </div>
        </div>

        @if (_cards.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Mitgliederkarten erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Karten-Nr.</th>
                            <th class="ta-th-sort" @onclick='() => Sort("name")'>Inhaber:in <span class="ta-sort-ind">@Ind("name")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("created")'>Erstellt <span class="ta-sort-ind">@Ind("created")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("reference")'>Referenz <span class="ta-sort-ind">@Ind("reference")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("category")'>Kategorie <span class="ta-sort-ind">@Ind("category")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("status")'>Status <span class="ta-sort-ind">@Ind("status")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("visits")'>Event&shy;besuche <span class="ta-sort-ind">@Ind("visits")</span></th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Sorted())
                        {
                            <tr>
                                <td>
                                    <span class="ta-ticketno">@AdminFormat.TicketNo(c.Uuid)</span>
                                    <a class="ta-qr-link" href="/ticket/for/@c.Uuid" target="_blank" rel="noopener" title="Online-Ticket" aria-label="Online-Ticket">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17 14h.01M20 14v3M14 17h.01M17 20h3M20 20h.01"/></svg>
                                    </a>
                                </td>
                                <td class="ta-cell-name">
                                    @if (c.HasName) { @c.HolderName }
                                    else { <span class="ta-muted">(ohne Name)</span> }
                                    @if (c.Birthday is { } b) { <span class="ta-muted"> (@b.ToString("dd.MM.yyyy"))</span> }
                                </td>
                                <td title="@AdminFormat.CreatedTooltip(c.CreatedAt, c.CreatedByName, null, null)">@AdminFormat.CreatedShort(c.CreatedAt, c.CreatedByName, null)</td>
                                <td>@(string.IsNullOrEmpty(c.Reference) ? "–" : c.Reference)</td>
                                <td><span class="ta-badge @CategoryBadgeClass(c.Category)">@c.CategoryLabel</span></td>
                                <td>
                                    <span class="ta-badge @(c.IsCancelled ? "ta-badge-cancelled" : "ta-badge-valid")">
                                        @(c.IsCancelled ? "Storniert" : "Gültig")
                                    </span>
                                </td>
                                <td class="ta-num">
                                    @if (c.EventVisits > 0)
                                    {
                                        <button type="button" class="ta-visits-link" @onclick="() => OpenVisits(c)">@c.EventVisits</button>
                                    }
                                    else
                                    {
                                        <span class="ta-muted">0</span>
                                    }
                                </td>
                                <td class="ta-col-actions">
                                    <button type="button" class="ta-icon-btn" title="Bearbeiten" @onclick="() => OpenEdit(c)">✎</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="ta-summary">@_cards.Count Mitgliederkarte@(_cards.Count == 1 ? "" : "n")</p>
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Mitgliederkarte erstellen</h2>
            <p class="ta-modal-sub">@_selectedSeasonName</p>

            <div class="ta-field">
                <label class="ta-label" for="newMcCategory">Kategorie</label>
                <select id="newMcCategory" class="ta-select" @bind="_newCategory">
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat">@cat.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newMcLastName">Name (optional)</label>
                <input id="newMcLastName" class="ta-input" type="text" maxlength="100" @bind="_newLastName" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newMcFirstName">Vorname (optional)</label>
                <input id="newMcFirstName" class="ta-input" type="text" maxlength="100" @bind="_newFirstName" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newMcBirthday">Geburtsdatum (optional)</label>
                <input id="newMcBirthday" class="ta-input" type="date" @bind="_newBirthday" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newMcReference">Referenz</label>
                <input id="newMcReference" class="ta-input" type="text" maxlength="100" placeholder="Eindeutig pro Saison" @bind="_newReference" />
            </div>

            @if (!string.IsNullOrEmpty(_createError))
            {
                <p class="ta-modal-error">@_createError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate" disabled="@_creating">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="CreateCardAsync" disabled="@_creating">
                    @(_creating ? "Erstellt …" : "Erstellen")
                </button>
            </div>
        </div>
    </div>
}

@if (_showExport)
{
    <div class="ta-overlay" @onmousedown="CloseExport">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Mitglieder exportieren (CSV)</h2>

            @if (_references.Count == 0)
            {
                <p class="ta-muted-text">Für diese Saison sind keine Referenzen vorhanden.</p>
            }
            else
            {
                <div class="ta-field">
                    <label class="ta-label" for="expReference">Referenz (Bundle)</label>
                    <select id="expReference" class="ta-select" @bind="_exportReference">
                        @foreach (var r in _references)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseExport">Schliessen</button>
                @if (!string.IsNullOrEmpty(_exportReference))
                {
                    <a class="ta-btn ta-btn-primary" href="/admin/mitglieder/export.csv?referenz=@Uri.EscapeDataString(_exportReference)"
                       target="_blank" rel="noopener" @onclick="CloseExport">Herunterladen</a>
                }
            </div>
        </div>
    </div>
}

@if (_showImport)
{
    <div class="ta-overlay" @onmousedown="CloseImport">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Mitglieder importieren</h2>

            <div class="ta-field">
                <label class="ta-label">Saison</label>
                <div class="ta-readonly">@_selectedSeasonName</div>
            </div>

            <div class="ta-field">
                <label class="ta-label" for="impReference">Referenz</label>
                <input id="impReference" class="ta-input" type="text" maxlength="100" placeholder="z. B. Mitglieder 2026" @bind="_importReference" />
            </div>

            <div class="ta-field">
                <label class="ta-label">CSV-Datei</label>
                <InputFile OnChange="OnFileSelectedAsync" accept=".csv,text/csv" />
                <p class="ta-hint">
                    Spalten: Kategorie (Red Ants / Block 4), Name, Vorname, Geburtsdatum (dd.MM.yyyy). Fehlende Angaben ausser der Referenz sind erlaubt.
                    <a href="/admin/mitglieder/beispiel.csv" target="_blank" rel="noopener">Beispieldatei herunterladen</a>
                </p>
            </div>

            @if (_fileName is not null)
            {
                <div class="ta-parse">
                    <strong>@_fileName</strong>: @_parsedRows.Count Zeile@(_parsedRows.Count == 1 ? "" : "n") erkannt.
                    @if (_parseWarnings.Count > 0)
                    {
                        <ul class="ta-warnings">
                            @foreach (var w in _parseWarnings)
                            {
                                <li>@w</li>
                            }
                        </ul>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_importError))
            {
                <div class="ta-error">@_importError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseImport" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="ImportAsync" disabled="@(_saving || _parsedRows.Count == 0)">
                    @(_saving ? "Wird importiert …" : $"{_parsedRows.Count} Mitglieder importieren")
                </button>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Mitglied bearbeiten</h2>
            <p class="ta-modal-sub">Karten-Nr. @AdminFormat.TicketNo(_editing.Uuid)</p>

            <div class="ta-field">
                <label class="ta-label" for="editLastName">Name</label>
                <input id="editLastName" class="ta-input" type="text" maxlength="100" @bind="_editLastName" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editFirstName">Vorname</label>
                <input id="editFirstName" class="ta-input" type="text" maxlength="100" @bind="_editFirstName" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editBirthday">Geburtsdatum</label>
                <input id="editBirthday" class="ta-input" type="date" @bind="_editBirthday" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editCategory">Kategorie</label>
                <select id="editCategory" class="ta-select" @bind="_editCategory">
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat">@cat.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editReference">Referenz</label>
                <input id="editReference" class="ta-input" type="text" maxlength="100" @bind="_editReference" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editStatus">Status</label>
                <select id="editStatus" class="ta-select" @bind="_editStatus">
                    <option value="@TicketStatus.Valid">Gültig</option>
                    <option value="@TicketStatus.Cancelled">Storniert</option>
                </select>
            </div>

            @if (!string.IsNullOrEmpty(_editError))
            {
                <div class="ta-modal-error">@_editError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_savingEdit">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEditAsync" disabled="@_savingEdit">
                    @(_savingEdit ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_visitsCard is not null)
{
    <VisitsOverlay Uuid="_visitsCard.Uuid" Title="@(_visitsCard.HasName ? _visitsCard.HolderName : AdminFormat.TicketNo(_visitsCard.Uuid))" OnClose="CloseVisits" />
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";
    [CascadingParameter] public AdminIdentity Identity { get; set; } = new("admin", null);

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IMemberCardAdminReport Report { get; set; } = default!;
    [Inject] private IMemberCards Members { get; set; } = default!;
    [Inject] private IMemberCardEditor MemberEditor { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private static readonly MemberCategory[] Categories = Enum.GetValues<MemberCategory>();

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<MemberCardListItem> _cards = [];

    public int SelectedSeasonId { get; set; }
    private string _selectedSeasonName = "";

    private string _sortCol = "name";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadCardsAsync();
        _loading = false;
    }

    private async Task ReloadCardsAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _selectedSeasonName = _seasons.FirstOrDefault(s => s.Id == SelectedSeasonId)?.Name ?? "";
        _cards = SelectedSeasonId > 0 ? await Report.GetBySeasonAsync(SelectedSeasonId) : [];
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<MemberCardListItem> Sorted()
    {
        IEnumerable<MemberCardListItem> q = _sortCol switch
        {
            "category" => _cards.OrderBy(c => c.Category),
            "reference" => _cards.OrderBy(c => c.Reference ?? "￿"),
            "status" => _cards.OrderBy(c => c.Status),
            "visits" => _cards.OrderBy(c => c.EventVisits),
            "created" => _cards.OrderBy(c => c.CreatedAt),
            _ => _cards.OrderBy(c => c.LastName ?? "￿").ThenBy(c => c.FirstName ?? "￿"),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private bool _showCreate;
    private bool _creating;
    private MemberCategory _newCategory = MemberCategory.RedAnts;
    private string _newFirstName = "";
    private string _newLastName = "";
    private DateOnly? _newBirthday;
    private string _newReference = "";
    private string? _createError;

    private void OpenCreate()
    {
        _newCategory = MemberCategory.RedAnts;
        _newFirstName = _newLastName = _newReference = "";
        _newBirthday = null;
        _createError = null;
        _showCreate = true;
    }
    private void CloseCreate() { if (!_creating) { _showCreate = false; _createError = null; } }

    private async Task CreateCardAsync()
    {
        if (_creating) return;
        if (SelectedSeasonId <= 0) { _createError = "Bitte zuerst eine Saison wählen."; return; }
        if (string.IsNullOrWhiteSpace(_newReference)) { _createError = "Bitte eine Referenz angeben."; return; }
        _creating = true;
        _createError = null;
        try
        {
            await Members.CreateAsync(SelectedSeasonId, _newCategory,
                string.IsNullOrWhiteSpace(_newFirstName) ? null : _newFirstName,
                string.IsNullOrWhiteSpace(_newLastName) ? null : _newLastName,
                _newBirthday, _newReference.Trim(), Identity.Name, Identity.Email);
            _showCreate = false;
            await ReloadCardsAsync();
        }
        catch (DomainException ex) { _createError = ex.Message; }
        finally { _creating = false; }
    }

    private bool _showExport;
    private IReadOnlyList<string> _references = [];
    private string _exportReference = "";

    private void OpenExport()
    {
        _references = _cards
            .Where(c => !string.IsNullOrWhiteSpace(c.Reference))
            .Select(c => c.Reference!)
            .Distinct()
            .OrderBy(r => r)
            .ToList();
        _exportReference = _references.FirstOrDefault() ?? "";
        _showExport = true;
    }
    private void CloseExport() => _showExport = false;

    private bool _showImport;
    private bool _saving;
    private string? _importError;
    private string _importReference = "";
    private string? _fileName;
    private IReadOnlyList<MemberImportRow> _parsedRows = [];
    private IReadOnlyList<string> _parseWarnings = [];

    private void OpenImport()
    {
        _importError = null;
        _importReference = "";
        _fileName = null;
        _parsedRows = [];
        _parseWarnings = [];
        _showImport = true;
    }

    private void CloseImport() { if (!_saving) _showImport = false; }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _importError = null;
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new StreamReader(stream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true);
            var text = await reader.ReadToEndAsync();

            var result = MemberCsv.Parse(text);
            _fileName = file.Name;
            _parsedRows = result.Rows;
            _parseWarnings = result.Warnings;
        }
        catch (Exception ex)
        {
            _fileName = null;
            _parsedRows = [];
            _parseWarnings = [];
            _importError = $"Datei konnte nicht gelesen werden: {ex.Message}";
        }
    }

    private async Task ImportAsync()
    {
        _importError = null;
        if (SelectedSeasonId <= 0) { _importError = "Bitte zuerst eine Saison wählen."; return; }
        if (string.IsNullOrWhiteSpace(_importReference)) { _importError = "Bitte eine Referenz angeben."; return; }
        if (_parsedRows.Count == 0) { _importError = "Bitte eine CSV-Datei mit mindestens einer Zeile wählen."; return; }

        _saving = true;
        try
        {
            var reference = _importReference.Trim();
            await Members.ImportAsync(SelectedSeasonId, reference, _parsedRows, Identity.Name, Identity.Email);
            _showImport = false;
            await ReloadCardsAsync();
        }
        catch (DomainException ex) { _importError = ex.Message; }
        finally { _saving = false; }
    }

    private MemberCardListItem? _editing;
    private string _editFirstName = "";
    private string _editLastName = "";
    private DateOnly? _editBirthday;
    private MemberCategory _editCategory;
    private string _editReference = "";
    private TicketStatus _editStatus;
    private bool _savingEdit;
    private string? _editError;

    private void OpenEdit(MemberCardListItem c)
    {
        _editing = c;
        _editFirstName = c.FirstName ?? "";
        _editLastName = c.LastName ?? "";
        _editBirthday = c.Birthday;
        _editCategory = c.Category;
        _editReference = c.Reference ?? "";
        _editStatus = c.Status;
        _editError = null;
    }

    private void CancelEdit() { if (!_savingEdit) { _editing = null; _editError = null; } }

    private async Task SaveEditAsync()
    {
        if (_editing is null) return;
        _savingEdit = true;
        _editError = null;
        try
        {
            await MemberEditor.SetDetailsAsync(_editing.Uuid, _editFirstName, _editLastName, _editBirthday,
                _editCategory, _editStatus, _editReference);
            _editing = null;
            await ReloadCardsAsync();
        }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _savingEdit = false; }
    }

    private MemberCardListItem? _visitsCard;
    private void OpenVisits(MemberCardListItem c) => _visitsCard = c;
    private void CloseVisits() => _visitsCard = null;

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static string CategoryBadgeClass(MemberCategory category) => category switch
    {
        MemberCategory.Block4 => "ta-badge-block4",
        _ => "ta-badge-redants"
    };
}
