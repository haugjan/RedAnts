@inherits InlineEditBase<DateOnly?>

@if (!Editing)
{
    <button type="button" class="ta-inline" title="@($"{FieldLabel} ändern")" disabled="@Disabled" @onclick="BeginEdit">
        @FormatValue(Value)
    </button>
}
else
{
    <input class="ta-input ta-inline-editor" type="date" value="@(Value?.ToString("yyyy-MM-dd"))"
           @onchange="OnChanged" @onkeydown="OnKeyDown" />
}

@if (ConfirmOpen)
{
    <ConfirmDialog Title="@ConfirmTitle"
                   Message="@ConfirmMessage"
                   ConfirmLabel="Ändern"
                   Busy="@Busy"
                   Error="@Error"
                   OnConfirm="ConfirmSaveAsync"
                   OnCancel="DismissConfirm" />
}

@code {
    [Parameter] public bool AllowEmpty { get; set; }
    [Parameter] public string EmptyLabel { get; set; } = "—";

    protected override string FormatValue(DateOnly? value) => value?.ToString("dd.MM.yyyy") ?? EmptyLabel;

    private void OnChanged(ChangeEventArgs e)
    {
        var raw = (e.Value?.ToString() ?? "").Trim();
        if (raw.Length == 0)
        {
            if (AllowEmpty) RequestSave(null);
            else CancelEdit();
            return;
        }
        if (!DateOnly.TryParse(raw, out var parsed))
        {
            CancelEdit();
            return;
        }
        RequestSave(parsed);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CancelEdit();
    }
}
