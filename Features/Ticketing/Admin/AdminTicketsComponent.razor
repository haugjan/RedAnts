@using RedAnts.Domain.Ticketing
@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Ports
@using RedAnts.Features.Ticketing.Scanning

<section class="ta-page">
    <h1 class="ta-page-title">@TicketType.EventTicket.DisplayName()</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="seasonSelect">Saison</label>
                    <select id="seasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="OnSeasonChangedAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="ta-field">
                    <label class="ta-label" for="eventSelect">Anlass</label>
                    <select id="eventSelect" class="ta-select" disabled="@(_events.Count == 0)"
                            @bind="SelectedEventId" @bind:after="ReloadTicketsAsync">
                        @if (_events.Count == 0)
                        {
                            <option value="0">— keine Anlässe —</option>
                        }
                        else
                        {
                            @foreach (var e in _events)
                            {
                                <option value="@e.Id">@e.Date.ToString("dd.MM.yyyy") · @e.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                <button type="button" class="ta-btn ta-btn-ghost" disabled="@(_bundles.Count == 0)" @onclick="OpenExport">
                    Export CSV
                </button>
                <button type="button" class="ta-btn ta-btn-ghost" disabled="@(SelectedEventId <= 0)" @onclick="OpenCreateBundle">
                    Bundle erstellen
                </button>
                <button type="button" class="ta-btn ta-btn-primary" disabled="@(SelectedEventId <= 0)" @onclick="OpenCreate">
                    Ticket erstellen
                </button>
            </div>
        </div>

        @if (SelectedEventId <= 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Anlässe erfasst.</div>
        }
        else if (_tickets.Count == 0)
        {
            <div class="ta-placeholder">Für diesen Anlass sind keine Tickets erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Ticket-Nr.</th>
                            <th class="ta-th-sort" @onclick='() => Sort("buyer")'>Käufer:in <span class="ta-sort-ind">@Ind("buyer")</span></th>
                            <th>Bundle</th>
                            <th class="ta-th-sort" @onclick='() => Sort("created")'>Erstellt <span class="ta-sort-ind">@Ind("created")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("category")'>Kategorie <span class="ta-sort-ind">@Ind("category")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("price")'>Preis <span class="ta-sort-ind">@Ind("price")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("status")'>Status <span class="ta-sort-ind">@Ind("status")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("redeemed")'>Eingelöst <span class="ta-sort-ind">@Ind("redeemed")</span></th>
                            <th>Event&shy;besuche</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Sorted())
                        {
                            <tr>
                                <td>
                                    <span class="ta-ticketno">
                                        <span class="ta-no">@AdminFormat.TicketNo(t.Uuid)</span>
                                        <a class="ta-qr-link" href="/ticket/for/@t.Uuid" target="_blank" rel="noopener" title="Online-Ticket" aria-label="Online-Ticket">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17 14h.01M20 14v3M14 17h.01M17 20h3M20 20h.01"/></svg>
                                        </a>
                                    </span>
                                </td>
                                <td class="ta-cell-name">
                                    @if (t.Buyer is not null)
                                    {
                                        @t.Buyer.DisplayName
                                        <span class="ta-badge ta-badge-buyer">@t.Buyer.Type.DisplayName()</span>
                                    }
                                    else
                                    {
                                        <span class="ta-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (t.BundleId is { } bundleId && _bundleRefById.TryGetValue(bundleId, out var bundleRef))
                                    {
                                        <span class="ta-badge ta-badge-buyer">@bundleRef</span>
                                    }
                                    else
                                    {
                                        <span class="ta-muted">—</span>
                                    }
                                </td>
                                <td class="ta-created" title="@AdminFormat.CreatedTooltip(t.CreatedAt, t.CreatedByName, t.CreatedByEmail, t.OrderId)">
                                    @AdminFormat.CreatedShort(t.CreatedAt, t.CreatedByName, t.OrderId)
                                </td>
                                <td>
                                    <InlineSelectEdit TValue="TicketCategory"
                                                      Value="@t.Category"
                                                      Options="@AllCategories"
                                                      Label="@(c => c.DisplayName())"
                                                      FieldLabel="Kategorie"
                                                      Save="@(c => SaveCategoryAsync(t, c))" />
                                </td>
                                <td class="ta-num">
                                    <InlineNumberEdit Value="@t.Price"
                                                      Decimals="2"
                                                      Min="0"
                                                      Prefix="CHF"
                                                      FieldLabel="Abgabepreis"
                                                      Save="@(p => SavePriceAsync(t, p))" />
                                </td>
                                <td>
                                    <InlineSelectEdit TValue="TicketStatus"
                                                      Value="@t.Status"
                                                      Options="@AllStatuses"
                                                      Label="@(s => s.DisplayName())"
                                                      FieldLabel="Status"
                                                      Save="@(s => SaveStatusAsync(t, s))">
                                        <Display Context="status">
                                            <span class="ta-badge ta-badge-@status.ToString().ToLowerInvariant()">@status.DisplayName()</span>
                                        </Display>
                                    </InlineSelectEdit>
                                </td>
                                <td>
                                    @if (t.Status == TicketStatus.Valid)
                                    {
                                        <InlineSelectEdit TValue="RedemptionState"
                                                          Value="@StateOf(t)"
                                                          Options="@AllRedemptionStates"
                                                          Label="@RedemptionLabel"
                                                          FieldLabel="Eingelöst"
                                                          Save="@(s => SaveRedemptionAsync(t, s))">
                                            <Display Context="state">
                                                <span class="ta-badge @RedemptionBadge(state)">@RedemptionLabel(state)</span>
                                            </Display>
                                        </InlineSelectEdit>
                                    }
                                    else
                                    {
                                        <span class="ta-badge ta-badge-draft">Offen</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="ta-visits-link" @onclick="() => _visitsFor = t">Besuche</button>
                                </td>
                                <td class="ta-col-actions">
                                    <button type="button" class="ta-icon-btn" title="Bearbeiten" @onclick="() => OpenEdit(t)">✎</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="ta-summary">
                @_tickets.Count Tickets · @_tickets.Count(t => StateOf(t) == RedemptionState.Redeemed) eingelöst
                · @_tickets.Count(t => StateOf(t) == RedemptionState.Outside) draussen
                · @_tickets.Count(t => StateOf(t) == RedemptionState.Open) offen
            </p>
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Ticket erstellen</h2>
            <div class="ta-field">
                <label class="ta-label" for="newBuyerType">Käufer:in</label>
                <select id="newBuyerType" class="ta-select" @bind="_newBuyerType">
                    <option value="@BuyerType.Private">Privatperson</option>
                    <option value="@BuyerType.Company">Firma</option>
                </select>
            </div>
            @if (_newBuyerType == BuyerType.Company)
            {
                <div class="ta-field">
                    <label class="ta-label" for="newCompany">Firmenname</label>
                    <input id="newCompany" class="ta-input" @bind="_newCompany" />
                </div>
            }
            else
            {
                <div class="ta-field">
                    <label class="ta-label" for="newFirstName">Vorname</label>
                    <input id="newFirstName" class="ta-input" @bind="_newFirstName" />
                </div>
                <div class="ta-field">
                    <label class="ta-label" for="newLastName">Nachname</label>
                    <input id="newLastName" class="ta-input" @bind="_newLastName" />
                </div>
            }
            <div class="ta-field">
                <label class="ta-label" for="newCategory">Kategorie</label>
                <select id="newCategory" class="ta-select" @bind="_newCategory">
                    @foreach (var cat in Enum.GetValues<TicketCategory>())
                    {
                        <option value="@cat">@cat.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newPrice">Abgabepreis (CHF)</label>
                <input id="newPrice" type="number" step="0.01" min="0" class="ta-input" @bind="_newPrice" @bind:after="() => _newPrice = decimal.Round(_newPrice, 2)" />
            </div>
            @if (_createError is not null)
            {
                <p class="ta-modal-error">@_createError</p>
            }
            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="CreateTicketAsync">Erstellen</button>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Ticket bearbeiten</h2>
            <p class="ta-modal-sub">Ticket-Nr. @AdminFormat.TicketNo(_editing.Uuid)</p>

            <div class="ta-field">
                <label class="ta-label" for="editCategory">Kategorie</label>
                <select id="editCategory" class="ta-select" @bind="_editCategory">
                    @foreach (var cat in Enum.GetValues<TicketCategory>())
                    {
                        <option value="@cat">@cat.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editPrice">Preis (CHF)</label>
                <input id="editPrice" type="number" step="0.01" min="0" class="ta-input" @bind="_editPrice" @bind:after="() => _editPrice = decimal.Round(_editPrice, 2)" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editStatus">Status</label>
                <select id="editStatus" class="ta-select" @bind="_editStatus">
                    <option value="@TicketStatus.Valid">Gültig</option>
                    <option value="@TicketStatus.Cancelled">Storniert</option>
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="editRedeemed">Eingelöst</label>
                <select id="editRedeemed" class="ta-select" @bind="_editRedeemed" disabled="@(_editStatus == TicketStatus.Cancelled)">
                    <option value="false">Offen</option>
                    <option value="true">Eingelöst</option>
                </select>
                <p class="ta-field-hint">Ein storniertes Ticket kann nicht eingelöst sein.</p>
            </div>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEdit" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_visitsFor is not null)
{
    <VisitsOverlay Uuid="@_visitsFor.Uuid"
                   Title="@($"Spielticket {AdminFormat.TicketNo(_visitsFor.Uuid)}")"
                   OnClose="() => _visitsFor = null" />
}

@if (_showCreateBundle)
{
    <div class="ta-overlay" @onmousedown="CloseCreateBundle">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Ticket-Bundle erstellen</h2>
            <div class="ta-field">
                <label class="ta-label">Anlass</label>
                <div class="ta-readonly">@_selectedEventName</div>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="bundleCategory">Ticketkategorie</label>
                <select id="bundleCategory" class="ta-select" @bind="_bundleCategory">
                    @foreach (var cat in AllCategories)
                    {
                        <option value="@cat">@cat.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="bundleReference">Bundlename</label>
                <input id="bundleReference" class="ta-input" type="text" maxlength="50" placeholder="z. B. Sponsoren 2026" @bind="_bundleReference" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="bundleQuantity">Anzahl Tickets</label>
                <input id="bundleQuantity" class="ta-input" type="number" min="1" max="1000" @bind="_bundleQuantity" />
            </div>
            @if (_bundleError is not null)
            {
                <p class="ta-modal-error">@_bundleError</p>
            }
            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreateBundle" disabled="@_bundleSaving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="CreateBundleAsync" disabled="@_bundleSaving">
                    @(_bundleSaving ? "Wird erstellt …" : "Bundle erstellen")
                </button>
            </div>
        </div>
    </div>
}

@if (_showExport)
{
    <div class="ta-overlay" @onmousedown="CloseExport">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Bundle exportieren</h2>
            <p class="ta-modal-sub">Bundle wählen, das als CSV heruntergeladen wird.</p>
            @if (_bundles.Count == 0)
            {
                <p class="ta-muted-text">Für diesen Anlass sind keine Bundles erfasst.</p>
            }
            else
            {
                <ul class="ta-bundle-list">
                    @foreach (var b in _bundles)
                    {
                        <li>
                            <a class="ta-btn ta-btn-ghost" href="/admin/spieltickets/bundle/@b.Id/tickets.csv"
                               target="_blank" rel="noopener"
                               title="Bundle als Excel/CSV herunterladen (Referenz + Kurzkennung + Ticketlink)">
                                @b.Reference · @b.Category.DisplayName() · @b.TicketCount Stk.
                            </a>
                        </li>
                    }
                </ul>
            }
            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseExport">Schliessen</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";
    [CascadingParameter] public AdminIdentity? Identity { get; set; }

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private IEventTickets Tickets { get; set; } = default!;
    [Inject] private IEventTicketBundles Bundles { get; set; } = default!;
    [Inject] private IVisitLogReader Visits { get; set; } = default!;
    [Inject] private IAdmissionService Admission { get; set; } = default!;
    [Inject] private IAdminOrderFactory OrderFactory { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private static readonly TicketCategory[] AllCategories = Enum.GetValues<TicketCategory>();
    private static readonly TicketStatus[] AllStatuses = [TicketStatus.Valid, TicketStatus.Cancelled];
    private static readonly RedemptionState[] AllRedemptionStates = Enum.GetValues<RedemptionState>();
    private static readonly Func<RedemptionState, string> RedemptionLabel = s => s.DisplayName();

    private IReadOnlyDictionary<Guid, bool> _inside = new Dictionary<Guid, bool>();

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Event> _events = [];
    private IReadOnlyList<EventTicket> _tickets = [];
    private IReadOnlyList<EventTicketBundleView> _bundles = [];
    private IReadOnlyDictionary<int, string> _bundleRefById = new Dictionary<int, string>();
    private string _selectedEventName = "";

    public int SelectedSeasonId { get; set; }
    public int SelectedEventId { get; set; }

    private string _sortCol = "category";
    private bool _sortAsc = true;

    private bool _showCreate;
    private TicketCategory _newCategory = TicketCategory.Adult;
    private decimal _newPrice;
    private BuyerType _newBuyerType = BuyerType.Private;
    private string _newFirstName = "";
    private string _newLastName = "";
    private string _newCompany = "";
    private string? _createError;

    protected override async Task OnInitializedAsync()
    {
        var restoreEventId = AdminState.SelectedEventId;
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await OnSeasonChangedAsync();
        if (restoreEventId is int eid && eid != SelectedEventId && _events.Any(e => e.Id == eid))
        {
            SelectedEventId = eid;
            await ReloadTicketsAsync();
        }
        _loading = false;
    }

    private async Task OnSeasonChangedAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _events = SelectedSeasonId > 0
            ? (await Events.GetBySeasonAsync(SelectedSeasonId)).OrderBy(e => e.Date).ThenBy(e => e.StartTime).ToList()
            : [];
        SelectedEventId = DefaultEvent(_events)?.Id ?? 0;
        await ReloadTicketsAsync();
    }

    private async Task ReloadTicketsAsync()
    {
        AdminState.SelectedEventId = SelectedEventId > 0 ? SelectedEventId : null;
        _selectedEventName = _events.FirstOrDefault(e => e.Id == SelectedEventId)?.Name ?? "";
        _tickets = SelectedEventId > 0
            ? (await Tickets.GetByEventAsync(SelectedEventId)).OrderBy(t => t.CreatedAt).ToList()
            : [];
        _bundles = SelectedEventId > 0
            ? await Bundles.GetByEventAsync(SelectedEventId)
            : [];
        _bundleRefById = _bundles.ToDictionary(b => b.Id, b => b.Reference);
        _inside = SelectedEventId > 0
            ? await Visits.GetInsideByEventAsync(SelectedEventId)
            : new Dictionary<Guid, bool>();
    }

    private RedemptionState StateOf(EventTicket t) =>
        RedemptionStateExtensions.Derive(t.Redeemed, _inside.TryGetValue(t.Uuid, out var inside) ? inside : null);

    private static string RedemptionBadge(RedemptionState state) => state switch
    {
        RedemptionState.Redeemed => "ta-badge-redeemed",
        RedemptionState.Outside => "ta-badge-blocked",
        _ => "ta-badge-draft"
    };

    private async Task SaveCategoryAsync(EventTicket t, TicketCategory category)
    {
        await Tickets.SaveAsync(EventTicket.FromPersistence(t.Id, t.Uuid, t.EventId, category, t.Price,
            t.OrderId, t.Status, t.CreatedAt, t.Redeemed, t.Buyer, t.CreatedByName, t.CreatedByEmail, t.BundleId));
        await ReloadTicketsAsync();
    }

    private async Task SavePriceAsync(EventTicket t, decimal? price)
    {
        if (price is not { } p || p < 0) throw new DomainException("Der Abgabepreis darf nicht leer oder negativ sein.");
        await Tickets.SaveAsync(EventTicket.FromPersistence(t.Id, t.Uuid, t.EventId, t.Category, decimal.Round(p, 2),
            t.OrderId, t.Status, t.CreatedAt, t.Redeemed, t.Buyer, t.CreatedByName, t.CreatedByEmail, t.BundleId));
        await ReloadTicketsAsync();
    }

    private async Task SaveStatusAsync(EventTicket t, TicketStatus status)
    {
        await Tickets.SaveAsync(WithStatus(t, status));
        await ReloadTicketsAsync();
    }

    private async Task SaveRedemptionAsync(EventTicket t, RedemptionState target)
    {
        var scannedBy = Identity?.Name ?? AdminUser;
        var current = StateOf(t);

        switch (target)
        {
            case RedemptionState.Redeemed:
                await ScanOrThrowAsync(t, ScanMode.CheckIn, scannedBy);
                break;
            case RedemptionState.Outside:
                if (current == RedemptionState.Open)
                    throw new DomainException("Ein offenes Ticket war nie drin und kann nicht auf „Draussen“ gesetzt werden.");
                await ScanOrThrowAsync(t, ScanMode.CheckOut, scannedBy);
                break;
            case RedemptionState.Open:
                if (current == RedemptionState.Redeemed && _inside.GetValueOrDefault(t.Uuid))
                    await ScanOrThrowAsync(t, ScanMode.CheckOut, scannedBy);
                await Tickets.SaveAsync(WithRedeemed(t, false));
                break;
        }
        await ReloadTicketsAsync();
    }

    private async Task ScanOrThrowAsync(EventTicket t, ScanMode mode, string scannedBy)
    {
        var outcome = await Admission.ScanTicketAsync(t.EventId, TicketType.EventTicket, t.Uuid, t.EventId, mode, scannedBy);
        if (!outcome.Ok) throw new DomainException(outcome.Reason ?? "Die Änderung wurde abgelehnt.");
    }

    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<EventTicket> Sorted()
    {
        IEnumerable<EventTicket> q = _sortCol switch
        {
            "buyer" => _tickets.OrderBy(t => t.Buyer?.DisplayName ?? "", StringComparer.OrdinalIgnoreCase),
            "created" => _tickets.OrderBy(t => t.CreatedAt),
            "price" => _tickets.OrderBy(t => t.Price),
            "status" => _tickets.OrderBy(t => t.Status),
            "redeemed" => _tickets.OrderBy(t => t.Redeemed),
            _ => _tickets.OrderBy(t => t.Category),
        };
        return _sortAsc ? q : q.Reverse();
    }

    private EventTicket? _visitsFor;

    private static EventTicket WithStatus(EventTicket t, TicketStatus status) =>
        EventTicket.FromPersistence(t.Id, t.Uuid, t.EventId, t.Category, t.Price, t.OrderId,
            status, t.CreatedAt, RedeemedOnlyIfValid(status, t.Redeemed), t.Buyer, t.CreatedByName, t.CreatedByEmail, t.BundleId);

    private static EventTicket WithRedeemed(EventTicket t, bool redeemed) =>
        EventTicket.FromPersistence(t.Id, t.Uuid, t.EventId, t.Category, t.Price, t.OrderId,
            t.Status, t.CreatedAt, RedeemedOnlyIfValid(t.Status, redeemed), t.Buyer, t.CreatedByName, t.CreatedByEmail, t.BundleId);

    private void OpenCreate()
    {
        _newCategory = TicketCategory.Adult;
        _newPrice = 0m;
        _newBuyerType = BuyerType.Private;
        _newFirstName = _newLastName = _newCompany = "";
        _createError = null;
        _showCreate = true;
    }
    private void CloseCreate() => _showCreate = false;

    private async Task CreateTicketAsync()
    {
        if (SelectedEventId <= 0) { _createError = "Es ist kein Anlass gewählt."; return; }
        if (_newPrice < 0) { _createError = "Der Abgabepreis darf nicht negativ sein."; return; }
        if ((await Admission.GetOccupancyAsync(SelectedEventId)).Full)
        { _createError = "Halle voll: Es können keine Tickets mehr erstellt werden."; return; }
        try
        {
            var buyer = Buyer.Create(_newBuyerType, _newFirstName, _newLastName, _newCompany);
            var order = await OrderFactory.CreateAsync(buyer, Identity?.Email,
                [new AdminOrderLine(OrderItemKind.EventTicket, SelectedEventId, _newCategory, _newCategory.DisplayName(), 1, _newPrice)],
                Identity?.Name ?? AdminUser);
            await Tickets.SaveAsync(EventTicket.Create(SelectedEventId, _newCategory, _newPrice, order.Id, buyer,
                Identity?.Name ?? AdminUser, Identity?.Email));
        }
        catch (DomainException ex) { _createError = ex.Message; return; }
        _showCreate = false;
        await ReloadTicketsAsync();
    }

    private bool _showCreateBundle;
    private bool _bundleSaving;
    private TicketCategory _bundleCategory = TicketCategory.Adult;
    private string _bundleReference = "";
    private int _bundleQuantity = 1;
    private string? _bundleError;

    private void OpenCreateBundle()
    {
        _bundleCategory = TicketCategory.Adult;
        _bundleReference = "";
        _bundleQuantity = 1;
        _bundleError = null;
        _showCreateBundle = true;
    }
    private void CloseCreateBundle() => _showCreateBundle = false;

    private async Task CreateBundleAsync()
    {
        _bundleError = null;
        var reference = (_bundleReference ?? "").Trim();
        if (SelectedEventId <= 0) { _bundleError = "Es ist kein Anlass gewählt."; return; }
        if (reference.Length == 0) { _bundleError = "Bitte einen Bundlenamen angeben."; return; }
        if (_bundleQuantity < 1) { _bundleError = "Die Anzahl muss mindestens 1 sein."; return; }
        if ((await Admission.GetOccupancyAsync(SelectedEventId)).Full)
        { _bundleError = "Halle voll: Es können keine Tickets mehr erstellt werden."; return; }

        _bundleSaving = true;
        try
        {
            if (await Bundles.ReferenceExistsAsync(SelectedEventId, reference))
            {
                _bundleError = $"Der Bundlename „{reference}“ ist für diesen Anlass bereits vergeben.";
                return;
            }
            var order = await OrderFactory.CreateAsync(Buyer.Create(BuyerType.Company, null, null, reference), Identity?.Email,
                [new AdminOrderLine(OrderItemKind.EventTicket, SelectedEventId, _bundleCategory, $"Ticket-Bundle · {reference}", _bundleQuantity, 0m)],
                Identity?.Name ?? AdminUser);
            await Bundles.CreateAsync(SelectedEventId, _bundleCategory, reference, _bundleQuantity,
                Identity?.Name ?? AdminUser, Identity?.Email, order.Id);
            _showCreateBundle = false;
            await ReloadTicketsAsync();
        }
        catch (DomainException ex) { _bundleError = ex.Message; }
        finally { _bundleSaving = false; }
    }

    private bool _showExport;
    private void OpenExport() => _showExport = true;
    private void CloseExport() => _showExport = false;

    private EventTicket? _editing;
    private TicketCategory _editCategory;
    private decimal _editPrice;
    private TicketStatus _editStatus;
    private bool _editRedeemed;
    private bool _saving;
    private string? _editError;

    private void OpenEdit(EventTicket t)
    {
        _editing = t;
        _editCategory = t.Category;
        _editPrice = decimal.Round(t.Price, 2);
        _editStatus = t.Status;
        _editRedeemed = t.Redeemed;
        _editError = null;
    }

    private void CancelEdit() { _editing = null; _editError = null; }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        if (_editPrice < 0) { _editError = "Der Preis darf nicht negativ sein."; return; }
        _saving = true;
        _editError = null;
        try
        {
            var redeemed = RedeemedOnlyIfValid(_editStatus, _editRedeemed);
            await Tickets.SaveAsync(EventTicket.FromPersistence(_editing.Id, _editing.Uuid, _editing.EventId,
                _editCategory, decimal.Round(_editPrice, 2), _editing.OrderId, _editStatus, _editing.CreatedAt, redeemed,
                _editing.Buyer, _editing.CreatedByName, _editing.CreatedByEmail, _editing.BundleId));
            _editing = null;
            await ReloadTicketsAsync();
        }
        catch (DomainException ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private static bool RedeemedOnlyIfValid(TicketStatus status, bool redeemed) =>
        status == TicketStatus.Valid && redeemed;

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }

    private static Event? DefaultEvent(IReadOnlyList<Event> events)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return events.FirstOrDefault(e => e.Date >= today) ?? events.MaxBy(e => e.Date);
    }
}
