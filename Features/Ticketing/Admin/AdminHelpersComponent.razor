@using RedAnts.Domain.Ticketing.Sales
@inject IHelpers Helpers
@inject IHelperScanReport ScanReport
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<section class="ta-page">
    <h1 class="ta-page-title">Helfer</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="helperSeason">Saison</label>
                    <select id="helperSeason" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                <button type="button" class="ta-btn ta-btn-primary" @onclick="OpenCreate" disabled="@(SelectedSeasonId <= 0)">
                    Helfer erfassen
                </button>
            </div>
        </div>

        @if (_helpers.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Helfer erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>E-Mail</th>
                            <th>Passwort</th>
                            <th>Login-Link</th>
                            <th class="ta-num">Scans</th>
                            <th>Aktiv</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in _helpers)
                        {
                            <tr class="@(h.Active ? "" : "ta-row-off")">
                                <td>@h.FullName</td>
                                <td>@(string.IsNullOrWhiteSpace(h.Email) ? "—" : h.Email)</td>
                                <td>
                                    <code class="ta-uuid">@h.Code</code>
                                    <button type="button" class="ta-icon-btn" title="Passwort kopieren" @onclick="() => CopyAsync(h.Code)">⧉</button>
                                </td>
                                <td>
                                    <button type="button" class="ta-icon-btn" title="Login-Link kopieren" @onclick="() => CopyAsync(LoginLink(h))">🔗</button>
                                </td>
                                <td class="ta-num">
                                    <button type="button" class="ta-visits-link" title="Scan-Übersicht dieses Helfers" @onclick="() => OpenScans(h)">
                                        📊 @ScanTotal(h)
                                    </button>
                                </td>
                                <td>
                                    <input type="checkbox" checked="@h.Active" @onchange="@(e => ToggleActiveAsync(h, e.Value is true))" />
                                </td>
                                <td class="ta-col-actions">
                                    @if (_confirmDelete == h.Id)
                                    {
                                        <button type="button" class="ta-btn ta-btn-ghost ta-btn-sm" @onclick="() => _confirmDelete = null">Abbrechen</button>
                                        <button type="button" class="ta-btn ta-btn-danger ta-btn-sm" @onclick="() => DeleteAsync(h)">Löschen</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="ta-icon-btn" title="Helfer löschen" @onclick="() => _confirmDelete = h.Id">🗑</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_copied)
            {
                <p class="ta-copied">In Zwischenablage kopiert</p>
            }
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Helfer erfassen</h2>
            <p class="ta-modal-sub">@_selectedSeasonName</p>

            <div class="ta-field">
                <label class="ta-label" for="newHelperFirst">Vorname</label>
                <input id="newHelperFirst" class="ta-input" type="text" maxlength="100" @bind="_newFirst" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newHelperLast">Nachname</label>
                <input id="newHelperLast" class="ta-input" type="text" maxlength="100" @bind="_newLast" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newHelperEmail">E-Mail (optional)</label>
                <input id="newHelperEmail" class="ta-input" type="email" maxlength="200" @bind="_newEmail" />
            </div>

            @if (!string.IsNullOrEmpty(_addError))
            {
                <div class="ta-modal-error">@_addError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate" disabled="@_adding">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="AddAsync" disabled="@_adding">
                    @(_adding ? "Wird erfasst …" : "Erfassen")
                </button>
            </div>
        </div>
    </div>
}

@if (_scanFor is not null)
{
    <div class="ta-overlay" @onmousedown="CloseScans">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Scan-Übersicht</h2>
            <p class="ta-modal-sub">@_scanFor.FullName</p>

            @if (_scanDetail.Count == 0)
            {
                <div class="ta-placeholder">Dieser Helfer hat noch keine Scans erfasst.</div>
            }
            else
            {
                <div class="ta-table-wrap">
                    <table class="ta-table">
                        <thead>
                            <tr>
                                <th>Anlass</th>
                                <th class="ta-num">Einlässe</th>
                                <th class="ta-num">Auslässe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _scanDetail)
                            {
                                <tr>
                                    <td>@d.EventName <span class="ta-muted">· @d.EventDate.ToString("dd.MM.yyyy")</span></td>
                                    <td class="ta-num">@d.CheckIns</td>
                                    <td class="ta-num @(d.CheckOuts > 0 ? "ta-warn" : "")">@d.CheckOuts</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td>Total</td>
                                <td class="ta-num">@_scanDetail.Sum(d => d.CheckIns)</td>
                                <td class="ta-num">@_scanDetail.Sum(d => d.CheckOuts)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseScans">Schliessen</button>
            </div>
        </div>
    </div>
}

<style>
    .ta-warn { color: #b42318; font-weight: 700; }
    .ta-btn-sm { padding: .25rem .6rem; font-size: .8rem; }
    .ta-table tfoot td { font-weight: 700; border-top: 2px solid var(--ta-border); }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Helper> _helpers = [];
    private IReadOnlyList<HelperScanRow> _scanRows = [];
    private Dictionary<int, Event> _eventById = new();

    public int SelectedSeasonId { get; set; }
    private string _selectedSeasonName = "";

    private bool _showCreate;
    private string _newFirst = "";
    private string _newLast = "";
    private string _newEmail = "";
    private bool _adding;
    private string? _addError;
    private int? _confirmDelete;
    private bool _copied;

    private Helper? _scanFor;
    private IReadOnlyList<HelperScanDetail> _scanDetail = [];

    private sealed record HelperScanDetail(string EventName, DateOnly EventDate, int CheckIns, int CheckOuts);

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _selectedSeasonName = _seasons.FirstOrDefault(s => s.Id == SelectedSeasonId)?.Name ?? "";
        _confirmDelete = null;
        if (SelectedSeasonId <= 0)
        {
            _helpers = [];
            _scanRows = [];
            _eventById = new();
            return;
        }
        _helpers = await Helpers.GetBySeasonAsync(SelectedSeasonId);
        var events = await Events.GetBySeasonAsync(SelectedSeasonId);
        _eventById = events.ToDictionary(e => e.Id);
        _scanRows = await ScanReport.GetByEventsAsync(events.Select(e => e.Id).ToList());
    }

    private int ScanTotal(Helper h) =>
        _scanRows.Where(r => r.Person == h.FullName).Sum(r => r.Total);

    private void OpenCreate()
    {
        if (SelectedSeasonId <= 0) return;
        _newFirst = _newLast = _newEmail = "";
        _addError = null;
        _showCreate = true;
    }

    private void CloseCreate()
    {
        if (_adding) return;
        _showCreate = false;
    }

    private async Task AddAsync()
    {
        if (SelectedSeasonId <= 0) return;
        _adding = true;
        _addError = null;
        try
        {
            await Helpers.AddAsync(SelectedSeasonId, _newFirst, _newLast, _newEmail);
            _showCreate = false;
            await ReloadAsync();
        }
        catch (Exception ex) { _addError = ex.Message; }
        finally { _adding = false; }
    }

    private void OpenScans(Helper h)
    {
        _scanFor = h;
        _scanDetail = _scanRows
            .Where(r => r.Person == h.FullName && _eventById.ContainsKey(r.EventId))
            .Select(r => new HelperScanDetail(_eventById[r.EventId].Name, _eventById[r.EventId].Date, r.CheckIns, r.CheckOuts))
            .OrderByDescending(d => d.EventDate)
            .ToList();
    }

    private void CloseScans() => _scanFor = null;

    private async Task ToggleActiveAsync(Helper h, bool active)
    {
        await Helpers.SetActiveAsync(h.Id, active);
        await ReloadAsync();
    }

    private async Task DeleteAsync(Helper h)
    {
        await Helpers.DeleteAsync(h.Id);
        _confirmDelete = null;
        await ReloadAsync();
    }

    private string LoginLink(Helper h)
    {
        var configured = Config["Scanner:PublicUrl"];
        var baseUrl = !string.IsNullOrWhiteSpace(configured)
            ? configured.TrimEnd('/')
            : new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
        return $"{baseUrl}/scan/{h.Code}";
    }

    private async Task CopyAsync(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
            StateHasChanged();
        }
        catch { }
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }
}
