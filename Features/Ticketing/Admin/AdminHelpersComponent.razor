@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Email
@inject IHelpers Helpers
@inject IHelperScanReport ScanReport
@inject IHelperInviteMailer InviteMailer
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<section class="ta-page">
    <h1 class="ta-page-title">Helfer</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="helperSeason">Saison</label>
                    <select id="helperSeason" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                <button type="button" class="ta-btn ta-btn-primary" @onclick="OpenCreate" disabled="@(SelectedSeasonId <= 0)">
                    Helfer erfassen
                </button>
            </div>
        </div>

        @if (_helpers.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Helfer erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>E-Mail</th>
                            <th>Passwort</th>
                            <th>Zuweisung</th>
                            <th class="ta-num" title="An wie vielen verschiedenen Anlässen dieser Helfer Einlässe / Auslässe gescannt hat">Anlässe Ein/Aus</th>
                            <th class="ta-num" title="Gesamtzahl der gescannten Einlässe / Auslässe">Scans Ein/Aus</th>
                            <th>E-Mail senden</th>
                            <th>Aktiv</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in _helpers)
                        {
                            var a = Agg(h);
                            <tr class="@(h.Active ? "" : "ta-row-off")">
                                <td>@h.FullName</td>
                                <td>@h.Email</td>
                                <td>
                                    <code class="ta-uuid">@h.Code</code>
                                    <button type="button" class="ta-icon-btn" title="Passwort kopieren" @onclick="() => CopyAsync(h.Code)">⧉</button>
                                    <button type="button" class="ta-icon-btn" title="Login-Link kopieren" @onclick="() => CopyAsync(LoginLink(h))">🔗</button>
                                </td>
                                <td>
                                    <button type="button" class="ta-visits-link" title="Anlass-Zuweisung bearbeiten" @onclick="() => OpenAssign(h)">
                                        @AssignmentLabel(h) ✎
                                    </button>
                                </td>
                                <td class="ta-num @(a.UnassignedEvents > 0 ? "ta-warn" : "")"
                                    title="@(a.UnassignedEvents > 0 ? $"Hat an {a.UnassignedEvents} nicht zugewiesenen Anlässen gescannt" : "Verschiedene Anlässe mit Einlässen / Auslässen")">
                                    <button type="button" class="ta-visits-link" @onclick="() => OpenScans(h)">@a.EventsIn / @a.EventsOut</button>
                                </td>
                                <td class="ta-num">@a.ScansIn / <span class="@(a.ScansOut > 0 ? "ta-warn" : "")">@a.ScansOut</span></td>
                                <td>
                                    <button type="button" class="ta-icon-btn" title="E-Mail mit Zugang an diesen Helfer senden" @onclick="() => OpenMail(h)">✉</button>
                                </td>
                                <td>
                                    <input type="checkbox" checked="@h.Active" @onchange="@(e => ToggleActiveAsync(h, e.Value is true))" />
                                </td>
                                <td class="ta-col-actions">
                                    <button type="button" class="ta-icon-btn" title="Helfer löschen" @onclick="() => OpenDelete(h)">🗑</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_copied)
            {
                <p class="ta-copied">In Zwischenablage kopiert</p>
            }
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Helfer erfassen</h2>
            <p class="ta-modal-sub">@_selectedSeasonName</p>

            <div class="ta-field">
                <label class="ta-label" for="newHelperFirst">Vorname</label>
                <input id="newHelperFirst" class="ta-input" type="text" maxlength="100" @bind="_newFirst" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newHelperLast">Nachname</label>
                <input id="newHelperLast" class="ta-input" type="text" maxlength="100" @bind="_newLast" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newHelperEmail">E-Mail</label>
                <input id="newHelperEmail" class="ta-input" type="email" maxlength="200" @bind="_newEmail" />
            </div>

            @if (!string.IsNullOrEmpty(_addError))
            {
                <div class="ta-modal-error">@_addError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate" disabled="@_adding">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="AddAsync" disabled="@_adding">
                    @(_adding ? "Wird erfasst …" : "Erfassen")
                </button>
            </div>
        </div>
    </div>
}

@if (_assignFor is not null)
{
    <div class="ta-overlay" @onmousedown="CloseAssign">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Anlass-Zuweisung</h2>
            <p class="ta-modal-sub">@_assignFor.FullName</p>

            <label class="ta-assign-all">
                <input type="checkbox" checked="@_assignAll" @onchange="@(e => _assignAll = e.Value is true)" />
                Alle Anlässe (auch künftig neu hinzukommende)
            </label>

            @if (!_assignAll)
            {
                @if (_events.Count == 0)
                {
                    <div class="ta-placeholder">Diese Saison hat noch keine Anlässe.</div>
                }
                else
                {
                    <div class="ta-assign-events">
                        @foreach (var ev in _events.OrderBy(e => e.Date).ThenBy(e => e.StartTime))
                        {
                            <label class="ta-assign-event">
                                <input type="checkbox" checked="@_assignEventIds.Contains(ev.Id)"
                                       @onchange="@(e => ToggleAssignEvent(ev.Id, e.Value is true))" />
                                @ev.Name <span class="ta-muted">· @ev.Date.ToString("dd.MM.yyyy")</span>
                            </label>
                        }
                    </div>
                }
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseAssign" disabled="@_assignSaving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveAssign" disabled="@_assignSaving">
                    @(_assignSaving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_mailFor is not null)
{
    <div class="ta-overlay" @onmousedown="CloseMail">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">E-Mail an Helfer</h2>
            <p class="ta-modal-sub">@_mailFor.FullName · @_mailFor.Email</p>

            <div class="ta-field">
                <label class="ta-label" for="mailSubject">Betreff</label>
                <input id="mailSubject" class="ta-input" type="text" maxlength="200" @bind="_mailSubject" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="mailBody">Text</label>
                <textarea id="mailBody" class="ta-input" rows="9" @bind="_mailBody"></textarea>
                <p class="ta-field-hint">Platzhalter: {Vorname}, {Nachname}, {Passwort}, {Link}. Zugangslink, Passwort und die PDF-Anleitung werden automatisch mitgeschickt.</p>
            </div>

            @if (_mailError is not null)
            {
                <div class="ta-modal-error">@_mailError</div>
            }
            @if (_mailSent)
            {
                <div class="ta-copied">E-Mail wurde versendet.</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseMail" disabled="@_mailSending">Schliessen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SendMail" disabled="@_mailSending">
                    @(_mailSending ? "Wird gesendet …" : "Senden")
                </button>
            </div>
        </div>
    </div>
}

@if (_scanFor is not null)
{
    <div class="ta-overlay" @onmousedown="CloseScans">
        <div class="ta-modal ta-modal-scans" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Scan-Übersicht</h2>
            <p class="ta-modal-sub">@_scanFor.FullName</p>

            @if (_scanDetail.Count == 0)
            {
                <div class="ta-placeholder">Dieser Helfer hat noch keine Scans erfasst.</div>
            }
            else
            {
                <div class="ta-table-wrap">
                    <table class="ta-table">
                        <thead>
                            <tr>
                                <th>Anlass</th>
                                <th class="ta-num">Einlässe</th>
                                <th class="ta-num">Auslässe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _scanDetail)
                            {
                                <tr>
                                    <td>@d.EventName <span class="ta-muted">· @d.EventDate.ToString("dd.MM.yyyy")</span>@(d.Unassigned ? " ⚠" : "")</td>
                                    <td class="ta-num">@d.CheckIns</td>
                                    <td class="ta-num @(d.CheckOuts > 0 ? "ta-warn" : "")">@d.CheckOuts</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td>Total</td>
                                <td class="ta-num">@_scanDetail.Sum(d => d.CheckIns)</td>
                                <td class="ta-num">@_scanDetail.Sum(d => d.CheckOuts)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseScans">Schliessen</button>
            </div>
        </div>
    </div>
}

@if (_deleteFor is not null)
{
    <div class="ta-overlay" @onmousedown="CloseDelete">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Helfer löschen</h2>
            <p class="ta-modal-sub">@_deleteFor.FullName</p>

            <p>Diesen Helfer wirklich löschen? Zugangslink und Passwort werden dauerhaft entfernt.</p>
            @if (_deleteHasScans)
            {
                <div class="ta-modal-warn">
                    Dieser Helfer hat bereits Scans erfasst. Die gescannten Einlässe und Auslässe bleiben in den Auswertungen erhalten, sind danach aber keinem Helfer mehr zugeordnet.
                </div>
            }
            @if (_deleteError is not null)
            {
                <div class="ta-modal-error">@_deleteError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseDelete" disabled="@_deleting">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-danger" @onclick="ConfirmDeleteAsync" disabled="@_deleting">
                    @(_deleting ? "Wird gelöscht …" : "Löschen")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .ta-warn { color: #b42318; font-weight: 700; }
    .ta-modal-warn { background: #fff4e5; border: 1px solid #f0c37a; color: #7a4b06; border-radius: 6px; padding: .6rem .8rem; margin: 0 0 1rem; font-size: .9rem; }
    .ta-btn-sm { padding: .25rem .6rem; font-size: .8rem; }
    .ta-table tfoot td { font-weight: 700; border-top: 2px solid var(--ta-border); }
    .ta-assign-all { display: flex; align-items: center; gap: .5rem; font-weight: 700; margin: 0 0 .8rem; }
    .ta-assign-events { display: flex; flex-direction: column; gap: .35rem; max-height: 320px; overflow-y: auto; padding: .2rem 0; }
    .ta-assign-event { display: flex; align-items: center; gap: .5rem; }

    .ta-modal-scans .ta-table-wrap { overflow-x: visible; }
    .ta-modal-scans .ta-table { min-width: 0; width: 100%; }
    .ta-modal-scans .ta-table th.ta-num, .ta-modal-scans .ta-table td.ta-num { width: 5rem; white-space: nowrap; }
    .ta-modal-scans .ta-table th:first-child, .ta-modal-scans .ta-table td:first-child { white-space: normal; }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<Helper> _helpers = [];
    private IReadOnlyList<HelperScanRow> _scanRows = [];
    private IReadOnlyList<Event> _events = [];
    private Dictionary<int, Event> _eventById = new();

    public int SelectedSeasonId { get; set; }
    private string _selectedSeasonName = "";

    private bool _showCreate;
    private string _newFirst = "";
    private string _newLast = "";
    private string _newEmail = "";
    private bool _adding;
    private string? _addError;
    private bool _copied;

    private Helper? _deleteFor;
    private bool _deleteHasScans;
    private bool _deleting;
    private string? _deleteError;

    private Helper? _assignFor;
    private bool _assignAll;
    private HashSet<int> _assignEventIds = new();
    private bool _assignSaving;

    private Helper? _mailFor;
    private string _mailSubject = "";
    private string _mailBody = "";
    private bool _mailSending;
    private bool _mailSent;
    private string? _mailError;

    private Helper? _scanFor;
    private IReadOnlyList<HelperScanDetail> _scanDetail = [];

    private sealed record HelperScanDetail(string EventName, DateOnly EventDate, int CheckIns, int CheckOuts, bool Unassigned);
    private sealed record HelperAgg(int EventsIn, int EventsOut, int ScansIn, int ScansOut, int UnassignedEvents);

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _selectedSeasonName = _seasons.FirstOrDefault(s => s.Id == SelectedSeasonId)?.Name ?? "";
        if (SelectedSeasonId <= 0)
        {
            _helpers = [];
            _scanRows = [];
            _events = [];
            _eventById = new();
            return;
        }
        _helpers = await Helpers.GetBySeasonAsync(SelectedSeasonId);
        _events = (await Events.GetBySeasonAsync(SelectedSeasonId)).OrderByDescending(e => e.Date).ToList();
        _eventById = _events.ToDictionary(e => e.Id);
        _scanRows = await ScanReport.GetByEventsAsync(_events.Select(e => e.Id).ToList());
    }

    private HelperAgg Agg(Helper h)
    {
        var rows = _scanRows.Where(r => r.Person == h.FullName).ToList();
        var eventsIn = rows.Where(r => r.CheckIns > 0).Select(r => r.EventId).Distinct().Count();
        var eventsOut = rows.Where(r => r.CheckOuts > 0).Select(r => r.EventId).Distinct().Count();
        var scansIn = rows.Sum(r => r.CheckIns);
        var scansOut = rows.Sum(r => r.CheckOuts);
        var unassigned = h.AllEvents
            ? 0
            : rows.Where(r => r.Total > 0).Select(r => r.EventId).Distinct().Count(id => !h.EventIds.Contains(id));
        return new HelperAgg(eventsIn, eventsOut, scansIn, scansOut, unassigned);
    }

    private bool HasScans(Helper h) => _scanRows.Where(r => r.Person == h.FullName).Sum(r => r.Total) > 0;

    private string AssignmentLabel(Helper h) =>
        h.AllEvents ? "Alle Anlässe" : $"{h.EventIds.Count(id => _eventById.ContainsKey(id))} Anlässe";

    private void OpenCreate()
    {
        if (SelectedSeasonId <= 0) return;
        _newFirst = _newLast = _newEmail = "";
        _addError = null;
        _showCreate = true;
    }

    private void CloseCreate()
    {
        if (_adding) return;
        _showCreate = false;
    }

    private async Task AddAsync()
    {
        if (SelectedSeasonId <= 0) return;
        _adding = true;
        _addError = null;
        try
        {
            await Helpers.AddAsync(SelectedSeasonId, _newFirst, _newLast, _newEmail);
            _showCreate = false;
            await ReloadAsync();
        }
        catch (Exception ex) { _addError = ex.Message; }
        finally { _adding = false; }
    }

    private void OpenAssign(Helper h)
    {
        _assignFor = h;
        _assignAll = h.AllEvents;
        _assignEventIds = h.EventIds.ToHashSet();
    }

    private void CloseAssign() { if (!_assignSaving) _assignFor = null; }

    private void ToggleAssignEvent(int eventId, bool on)
    {
        if (on) _assignEventIds.Add(eventId);
        else _assignEventIds.Remove(eventId);
    }

    private async Task SaveAssign()
    {
        if (_assignFor is null) return;
        _assignSaving = true;
        try
        {
            var ids = _assignEventIds.Where(id => _eventById.ContainsKey(id)).ToList();
            await Helpers.SetAssignmentAsync(_assignFor.Id, _assignAll, ids);
            _assignFor = null;
            await ReloadAsync();
        }
        finally { _assignSaving = false; }
    }

    private void OpenScans(Helper h)
    {
        _scanFor = h;
        _scanDetail = _scanRows
            .Where(r => r.Person == h.FullName && _eventById.ContainsKey(r.EventId))
            .Select(r => new HelperScanDetail(_eventById[r.EventId].Name, _eventById[r.EventId].Date, r.CheckIns, r.CheckOuts,
                !h.AllEvents && !h.EventIds.Contains(r.EventId)))
            .OrderByDescending(d => d.EventDate)
            .ToList();
    }

    private void CloseScans() => _scanFor = null;

    private void OpenMail(Helper h)
    {
        _mailFor = h;
        _mailSubject = InviteMailer.DefaultSubject;
        _mailBody = InviteMailer.DefaultBody;
        _mailSent = false;
        _mailError = null;
    }

    private void CloseMail() { if (!_mailSending) { _mailFor = null; _mailError = null; _mailSent = false; } }

    private async Task SendMail()
    {
        if (_mailFor is null) return;
        _mailSending = true;
        _mailError = null;
        _mailSent = false;
        try
        {
            var result = await InviteMailer.SendAsync(_mailFor, _mailSubject, _mailBody, LoginLink(_mailFor));
            if (result.Success) _mailSent = true;
            else _mailError = result.Error ?? "E-Mail konnte nicht versendet werden.";
        }
        catch (Exception ex) { _mailError = ex.Message; }
        finally { _mailSending = false; }
    }

    private async Task ToggleActiveAsync(Helper h, bool active)
    {
        await Helpers.SetActiveAsync(h.Id, active);
        await ReloadAsync();
    }

    private void OpenDelete(Helper h)
    {
        _deleteFor = h;
        _deleteHasScans = HasScans(h);
        _deleteError = null;
    }

    private void CloseDelete() { if (!_deleting) { _deleteFor = null; _deleteError = null; } }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteFor is null) return;
        _deleting = true;
        _deleteError = null;
        try
        {
            await Helpers.DeleteAsync(_deleteFor.Id);
            _deleteFor = null;
            await ReloadAsync();
        }
        catch (Exception ex) { _deleteError = ex.Message; }
        finally { _deleting = false; }
    }

    private string LoginLink(Helper h)
    {
        var configured = Config["Scanner:PublicUrl"];
        var baseUrl = !string.IsNullOrWhiteSpace(configured)
            ? configured.TrimEnd('/')
            : new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
        return $"{baseUrl}/scan/{h.Code}";
    }

    private async Task CopyAsync(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
            StateHasChanged();
        }
        catch { }
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }
}
