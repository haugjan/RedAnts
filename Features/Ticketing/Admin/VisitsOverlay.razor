@using RedAnts.Domain.Ticketing.Sales

<div class="ta-overlay" @onmousedown="Close">
    <div class="ta-modal ta-modal-visits" @onmousedown:stopPropagation="true">
        <h2 class="ta-modal-title">Eventbesuche</h2>
        <p class="ta-modal-sub">@Title</p>

        @if (_loading)
        {
            <p class="ta-muted-text">Wird geladen …</p>
        }
        else if (_visits.Count == 0)
        {
            <div class="ta-placeholder">Noch keine Eventbesuche.</div>
        }
        else
        {
            @if (_visits.Count > 1)
            {
                <div class="ta-visits-bar">
                    <span class="ta-muted">@_visits.Count Anlässe · @_visits.Sum(v => v.Scans.Count) Scans</span>
                    <button type="button" class="ta-linkbtn" @onclick="ToggleAll">
                        @(_expanded.Count == _visits.Count ? "Alle zuklappen" : "Alle aufklappen")
                    </button>
                </div>
            }
            @for (var i = 0; i < _visits.Count; i++)
            {
                var index = i;
                var v = _visits[index];
                var open = _expanded.Contains(index);
                <div class="ta-visit">
                    <button type="button" class="ta-visit-toggle" @onclick="() => Toggle(index)">
                        <span class="ta-visit-chevron">@(open ? "▾" : "▸")</span>
                        <span class="ta-visit-event">@v.EventName</span>
                        @if (v.EventDate is { } d)
                        {
                            <span class="ta-visit-date">@d.ToString("dd.MM.yyyy")</span>
                        }
                        <span class="ta-badge @(v.IsInside ? "ta-badge-valid" : "ta-badge-draft")">
                            @(v.IsInside ? "Drin" : "Draussen")
                        </span>
                        <span class="ta-visit-summary">@Summary(v)</span>
                    </button>
                    @if (open && v.Scans.Count > 0)
                    {
                        <table class="ta-subtable">
                            <thead>
                                <tr><th>Scan</th><th>Zeit</th><th>Scannperson</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var s in v.Scans)
                                {
                                    <tr>
                                        <td>@(s.Type == VisitLogType.CheckIn ? "Eingescannt" : "Ausgescannt")</td>
                                        <td>@s.OccurredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@(string.IsNullOrEmpty(s.ScannedBy) ? "—" : s.ScannedBy)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        }

        <div class="ta-modal-actions">
            <button type="button" class="ta-btn ta-btn-ghost" @onclick="Close">Schliessen</button>
        </div>
    </div>
</div>

<style>
    .ta-visits-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: .5rem; font-size: .85rem; }
    .ta-linkbtn { background: none; border: none; padding: 0; cursor: pointer; color: var(--ta-accent); font: inherit; text-decoration: underline; }
    .ta-visit-toggle { display: flex; align-items: center; gap: .6rem; width: 100%; text-align: left; background: none; border: none; cursor: pointer; padding: .55rem .1rem; font: inherit; color: var(--ta-ink); }
    .ta-visit-toggle:hover { background: rgba(0,0,0,.03); }
    .ta-visit-chevron { color: var(--ta-muted); font-size: .8rem; width: .9rem; flex-shrink: 0; }
    .ta-visit-summary { margin-left: auto; color: var(--ta-muted); font-size: .82rem; white-space: nowrap; }
</style>

@code {
    [Parameter] public Guid Uuid { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    [Inject] private IVisitLogReader Visits { get; set; } = default!;

    private bool _loading = true;
    private IReadOnlyList<TicketVisitEntry> _visits = [];
    private readonly HashSet<int> _expanded = [];

    protected override async Task OnInitializedAsync()
    {
        _visits = await Visits.GetByTicketUuidAsync(Uuid);
        if (_visits.Count == 1) _expanded.Add(0);
        _loading = false;
    }

    private void Toggle(int index)
    {
        if (!_expanded.Remove(index)) _expanded.Add(index);
    }

    private void ToggleAll()
    {
        if (_expanded.Count == _visits.Count) _expanded.Clear();
        else for (var i = 0; i < _visits.Count; i++) _expanded.Add(i);
    }

    private static string Summary(TicketVisitEntry v)
    {
        if (v.Scans.Count == 0) return "keine Scans";
        var last = v.Scans.Max(s => s.OccurredAt).ToLocalTime();
        return $"{v.Scans.Count} Scan{(v.Scans.Count == 1 ? "" : "s")} · zuletzt {last:dd.MM.yyyy HH:mm}";
    }

    private Task Close() => OnClose.InvokeAsync();
}
