@using Microsoft.JSInterop
@using RedAnts.Domain.Ticketing
@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Ports

<section class="ta-page">
    <h1 class="ta-page-title">Saisons</h1>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters"></div>
            <div class="ta-toolbar-actions">
                @if (_createSeasonUrl is not null)
                {
                    <a class="ta-btn ta-btn-ghost" href="@_createSeasonUrl"
                       title="Öffnet das Backoffice-Content mit einer neuen Saison">Saison im Content erstellen</a>
                }
            </div>
        </div>

        @if (_seasons.Count == 0)
        {
            <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
        }
        else
        {
        <div class="ta-table-wrap">
            <table class="ta-table">
                <thead>
                    <tr>
                        <th>Zeitraum</th>
                        <th>Saison</th>
                        <th>Verkaufs&shy;status</th>
                        <th class="ta-num">Anlässe</th>
                        <th class="ta-num">Standard-Einlass&shy;kontingent</th>
                        <th class="ta-num">Standard-Verkaufs&shy;kontingent</th>
                        <th class="ta-num">Verk. Saison&shy;karten</th>
                        <th class="ta-num">Verk. Tickets</th>
                        <th class="ta-num">Einlässe</th>
                        <th></th>
                        <th class="ta-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _seasons)
                    {
                        var links = Links(s.Id);
                        var stats = Stats(s.Id);
                        <tr>
                            <td class="ta-period">
                                <InlineDateEdit Value="@((DateOnly?)s.StartDate)" FieldLabel="Startdatum"
                                                Save="@(d => SavePeriodAsync(s, d, s.EndDate))" />
                                <span class="ta-period-sep">–</span>
                                <InlineDateEdit Value="@((DateOnly?)s.EndDate)" FieldLabel="Enddatum"
                                                Save="@(d => SavePeriodAsync(s, s.StartDate, d))" />
                            </td>
                            <td class="ta-cell-name">
                                <InlineTextEdit Value="@s.Name" FieldLabel="Saisonbezeichnung" MaxLength="100"
                                                Save="@(name => SaveNameAsync(s, name))" />
                            </td>
                            <td>
                                <InlineSelectEdit TValue="SeasonStatus" Value="@s.Status" FieldLabel="Verkaufsstatus"
                                                  Options="@_statusOptions" Label="@(st => StatusLabel(st))"
                                                  Save="@(st => SaveStatusAsync(s, st))">
                                    <Display Context="st">
                                        <span class="ta-badge ta-badge-@st.ToString().ToLowerInvariant()">@StatusLabel(st)</span>
                                    </Display>
                                </InlineSelectEdit>
                            </td>
                            <td class="ta-num">@EventCount(s.Id)</td>
                            <td class="ta-num">
                                <InlineNumberEdit Value="@((decimal?)Quota(s.Id))" FieldLabel="Standard-Einlasskontingent"
                                                  Min="0" AllowEmpty="true" EmptyLabel="∞"
                                                  Save="@(v => SaveQuotaAsync(s, v))" />
                            </td>
                            <td class="ta-num">
                                <InlineNumberEdit Value="@((decimal?)SalesQuota(s.Id))" FieldLabel="Standard-Verkaufskontingent"
                                                  Min="0" AllowEmpty="true" EmptyLabel="∞"
                                                  Save="@(v => SaveSalesQuotaAsync(s, v))" />
                            </td>
                            <td class="ta-num">@stats.PassesSold</td>
                            <td class="ta-num">@stats.TicketsSold</td>
                            <td class="ta-num">@stats.Admissions</td>
                            <td class="ta-links">
                                @if (s.Status == SeasonStatus.Open)
                                {
                                    <button type="button" class="ta-link-btn"
                                            disabled="@(string.IsNullOrEmpty(links.Public))"
                                            title="@(string.IsNullOrEmpty(links.Public) ? "Nicht veröffentlicht" : "Öffentlichen Link kopieren")"
                                            @onclick="() => Copy(s.Id, false, links.Public)">🔗</button>
                                }
                                else if (s.Status == SeasonStatus.Intern)
                                {
                                    <button type="button" class="ta-link-btn"
                                            disabled="@(string.IsNullOrEmpty(links.Intern))"
                                            title="@(string.IsNullOrEmpty(links.Intern) ? "Nicht veröffentlicht" : "Internen Link (mit Geheimnis) kopieren")"
                                            @onclick="() => Copy(s.Id, true, links.Intern)">🔒</button>
                                }
                                else
                                {
                                    <span class="ta-muted">–</span>
                                }
                                @if (_copied is { } c && c.SeasonId == s.Id)
                                {
                                    <span class="ta-copied">in Zwischenablage kopiert</span>
                                }
                            </td>
                            <td class="ta-col-actions">
                                <button type="button" class="ta-icon-btn" title="Preise und Kontingente" @onclick="() => OpenEditAsync(s)">$</button>
                                <button type="button" class="ta-icon-btn" title="Zusatzoptionen@(AddOnCount(s.Id) > 0 ? $" ({AddOnCount(s.Id)})" : "")" @onclick="() => OpenAddOns(s)">＋</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="ta-summary">@_seasons.Count @(_seasons.Count == 1 ? "Saison" : "Saisons")</p>
        }
    }
</section>

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal ta-modal--xwide" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Preise und Kontingente</h2>
            <p class="ta-modal-sub">@_editing.Name · @_editing.StartDate.ToString("dd.MM.yyyy") – @_editing.EndDate.ToString("dd.MM.yyyy")</p>

            <div class="ta-field">
                <label class="ta-label">Preisstufen dieser Saison</label>
                <div class="ta-subtable-wrap">
                <table class="ta-subtable">
                    <thead>
                        <tr>
                            <th rowspan="2">Stufe</th>
                            <th rowspan="2" class="ta-num">Alter bis</th>
                            <th colspan="5" class="ta-subgroup">Saisonkarten</th>
                            <th colspan="4" class="ta-subgroup ta-subgroup-alt">Tickets (Standard für neue Anlässe)</th>
                            <th rowspan="2"></th>
                        </tr>
                        <tr>
                            <th class="ta-group-col">Angeboten</th>
                            <th class="ta-num">Preis (CHF)</th>
                            <th class="ta-num">Kontingent</th>
                            <th class="ta-num">Verkauf bis</th>
                            <th class="ta-num">Verbraucht</th>
                            <th class="ta-group-col">Angeboten</th>
                            <th class="ta-num">Preis (CHF)</th>
                            <th class="ta-num">Kontingent</th>
                            <th class="ta-num">Verkauf bis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _editTiers)
                        {
                            <tr class="@(c.PassOffered || c.TicketOffered ? "" : "ta-row-off")">
                                <td><input type="text" maxlength="200" class="ta-input ta-tier-name" placeholder="z. B. Erwachsen" @bind="c.Name" /></td>
                                <td class="ta-num"><input type="number" min="0" step="1" class="ta-input ta-input-age" placeholder="–" @bind="c.MaxAge" /></td>
                                <td class="ta-group-col"><input type="checkbox" @bind="c.PassOffered" /></td>
                                <td class="ta-num"><input type="number" min="0" step="0.01" class="ta-input ta-input-sm" disabled="@(!c.PassOffered)" @bind="c.PassPrice" @bind:after="() => c.PassPrice = decimal.Round(c.PassPrice, 2)" /></td>
                                <td class="ta-num"><input type="number" min="0" step="1" class="ta-input ta-input-sm" placeholder="∞" disabled="@(!c.PassOffered)" @bind="c.PassQuota" /></td>
                                <td class="ta-num"><DateBox @bind-Value="c.PassAvailableUntil" Disabled="@(!c.PassOffered)" /></td>
                                <td class="ta-num">@c.Sold@(c.PassQuota is { } q ? $" / {q}" : "")</td>
                                <td class="ta-group-col"><input type="checkbox" @bind="c.TicketOffered" /></td>
                                <td class="ta-num"><input type="number" min="0" step="0.01" class="ta-input ta-input-sm" disabled="@(!c.TicketOffered)" @bind="c.TicketPrice" @bind:after="() => c.TicketPrice = decimal.Round(c.TicketPrice, 2)" /></td>
                                <td class="ta-num"><input type="number" min="0" step="1" class="ta-input ta-input-sm" placeholder="∞" disabled="@(!c.TicketOffered)" @bind="c.TicketQuota" /></td>
                                <td class="ta-num"><DateBox @bind-Value="c.TicketAvailableUntil" Disabled="@(!c.TicketOffered)" /></td>
                                <td class="ta-num ta-tier-actions">
                                    <button type="button" class="ta-icon-btn" title="@(c.HasPromo ? "Aktion entfernen" : "Aktion hinzufügen")" @onclick="() => TogglePromo(c)">@(c.HasPromo ? "★" : "☆")</button>
                                    <button type="button" class="ta-icon-btn" title="@(c.CanDelete ? "Stufe löschen" : "Nicht löschbar: bereits verkauft")" disabled="@(!c.CanDelete)" @onclick="() => RemoveTier(c)">×</button>
                                </td>
                            </tr>
                            @if (c.HasPromo)
                            {
                                <tr class="ta-tier-promo">
                                    <td class="ta-promo-name"><span class="ta-promo-arrow">↳</span><input type="text" maxlength="200" class="ta-input ta-tier-name" placeholder="Aktionsname" @bind="c.PromoName" /></td>
                                    <td></td>
                                    <td class="ta-group-col ta-muted">Aktion</td>
                                    <td class="ta-num"><input type="number" min="0" step="0.01" class="ta-input ta-input-sm" disabled="@(!c.PassOffered)" @bind="c.PassPromoPrice" @bind:after="() => c.PassPromoPrice = decimal.Round(c.PassPromoPrice, 2)" /></td>
                                    <td class="ta-num"><input type="number" min="0" step="1" class="ta-input ta-input-sm" placeholder="∞" disabled="@(!c.PassOffered)" @bind="c.PassPromoQuota" /></td>
                                    <td class="ta-num"><DateBox @bind-Value="c.PassPromoAvailableUntil" Disabled="@(!c.PassOffered)" /></td>
                                    <td class="ta-num">@c.PromoSold@(c.PassPromoQuota is { } pq ? $" / {pq}" : "")</td>
                                    <td class="ta-group-col ta-muted">Aktion</td>
                                    <td class="ta-num"><input type="number" min="0" step="0.01" class="ta-input ta-input-sm" disabled="@(!c.TicketOffered)" @bind="c.TicketPromoPrice" @bind:after="() => c.TicketPromoPrice = decimal.Round(c.TicketPromoPrice, 2)" /></td>
                                    <td class="ta-num"><input type="number" min="0" step="1" class="ta-input ta-input-sm" placeholder="∞" disabled="@(!c.TicketOffered)" @bind="c.TicketPromoQuota" /></td>
                                    <td class="ta-num"><DateBox @bind-Value="c.TicketPromoAvailableUntil" Disabled="@(!c.TicketOffered)" /></td>
                                    <td></td>
                                </tr>
                            }
                        }
                        @if (_editTiers.Count == 0)
                        {
                            <tr><td colspan="12" class="ta-muted">Noch keine Preisstufen erfasst.</td></tr>
                        }
                    </tbody>
                </table>
                </div>
                <button type="button" class="ta-btn ta-btn-ghost ta-addon-add" @onclick="AddTier">+ Stufe hinzufügen</button>
                <p class="ta-field-hint">Jede Stufe hat einen Namen und optional eine Altersgrenze (nur Anzeige). Links: Saisonkarten-Verkauf dieser Saison. Rechts: Standardwerte, die jeder NEUE Anlass beim Erstellen übernimmt (bestehende Anlässe bleiben unverändert). Mit ☆ fügst du einer Stufe eine benannte Aktion hinzu: Solange deren Kontingent und Datum nicht erreicht sind, gilt der Aktionspreis, danach der Normalpreis. „Verkauf bis" leer = kein Enddatum; sonst endet der Verkauf nach dem Datum oder sobald das Kontingent erreicht ist. Stufen lassen sich nur löschen, solange noch keine Karten verkauft wurden.</p>
            </div>

            @if (_editError is not null)
            {
                <p class="ta-modal-error">@_editError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEdit" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@if (_editingAddOns is not null)
{
    <div class="ta-overlay" @onmousedown="CancelAddOns">
        <div class="ta-modal ta-modal--xwide" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Zusatzoptionen</h2>
            <p class="ta-modal-sub">@_editingAddOns.Name · zubuchbar zu Saisonkarten dieser Saison</p>

            <div class="ta-field">
                <div class="ta-subtable-wrap">
                <table class="ta-subtable">
                    <thead>
                        <tr>
                            <th>Bezeichnung</th>
                            <th class="ta-num">Preis (CHF)</th>
                            <th>Geltung</th>
                            <th class="ta-group-col">Aktiv</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _addOnRows)
                        {
                            <tr class="@(r.Active ? "" : "ta-row-off")">
                                <td><input type="text" maxlength="200" class="ta-input ta-addon-label" placeholder="z. B. Livestream-Abo" @bind="r.Label" /></td>
                                <td class="ta-num"><input type="number" min="0" step="0.01" class="ta-input ta-input-sm" @bind="r.Price" @bind:after="() => r.Price = decimal.Round(r.Price, 2)" /></td>
                                <td><select class="ta-select ta-scope-select" @bind="r.Scope">
                                    <option value="@AddOnScope.PerPass">Pro Saisonkarte</option>
                                    <option value="@AddOnScope.PerOrder">Einmalig pro Bestellung</option>
                                </select></td>
                                <td class="ta-group-col"><input type="checkbox" @bind="r.Active" /></td>
                                <td class="ta-num"><button type="button" class="ta-icon-btn" title="Entfernen" @onclick="() => RemoveAddOnRow(r)">×</button></td>
                            </tr>
                        }
                        @if (_addOnRows.Count == 0)
                        {
                            <tr><td colspan="5" class="ta-muted">Noch keine Zusatzoptionen erfasst.</td></tr>
                        }
                    </tbody>
                </table>
                </div>
                <button type="button" class="ta-btn ta-btn-ghost ta-addon-add" @onclick="AddAddOnRow">+ Option hinzufügen</button>
                <p class="ta-field-hint">Aktive Optionen können beim Kauf einer Saisonkarte dieser Saison zusätzlich gewählt werden. „Pro Saisonkarte" wird je Karte berechnet (z. B. physische Karte), „einmalig pro Bestellung" nur einmal je Bestellung, unabhängig von der Kartenanzahl (z. B. Livestream-Abo). Bei jeder gewählten Option wird tickets@("@")redants.ch benachrichtigt.</p>
            </div>

            @if (_addOnError is not null)
            {
                <p class="ta-modal-error">@_addOnError</p>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelAddOns" disabled="@_addOnSaving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveAddOns" disabled="@_addOnSaving">
                    @(_addOnSaving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .ta-addon-label { width: 100%; min-width: 12rem; text-align: left; }
    .ta-addon-add { margin-top: .5rem; }
    .ta-subtable-wrap { overflow-x: auto; }
    .ta-subtable { width: 100%; border-collapse: collapse; margin-top: .4rem; }
    .ta-subtable th { text-align: left; font-size: .68rem; text-transform: uppercase; color: var(--ta-muted); padding: 2px 5px; }
    .ta-subtable td { padding: 3px 5px; font-size: .85rem; }
    .ta-subtable th.ta-num, .ta-subtable td.ta-num { text-align: right; }
    .ta-input-sm { width: 5.3rem; padding: .3rem .35rem; text-align: right; }
    .ta-tier-name { width: 100%; min-width: 9rem; text-align: left; }
    .ta-input-age { width: 3.4rem; padding: .3rem .35rem; text-align: right; }
    .ta-tier-actions { white-space: nowrap; }
    .ta-tier-promo td { background: rgba(200, 16, 46, .04); }
    .ta-promo-name { white-space: nowrap; }
    .ta-promo-arrow { color: var(--ta-muted); margin-right: .3rem; }
    .ta-subtable .ta-dateseg { padding: .28rem .3rem; }
    .ta-subtable .ta-datebox { gap: .15rem; }
    .ta-subtable .ta-seg-dm { width: 1.35rem; }
    .ta-subtable .ta-seg-y { width: 2.4rem; }
    .ta-subtable .ta-datebox-cal { padding: .28rem .35rem; }
    .ta-row-off td { opacity: .45; }
    .ta-row-off td:nth-child(-n+2) { opacity: 1; }
    .ta-period { white-space: nowrap; }
    .ta-period-sep { color: var(--ta-muted); margin: 0 .15rem; }
    .ta-quota-used { display: block; font-size: .72rem; color: var(--ta-muted); }
    .ta-copied { margin-left: .45rem; font-size: .75rem; color: #1c7c43; font-weight: 700; white-space: nowrap; }
</style>

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IEvents Events { get; set; } = default!;
    [Inject] private ISeasonPrices SeasonPrices { get; set; } = default!;
    [Inject] private IPriceTiers PriceTiers { get; set; } = default!;
    [Inject] private ISeasonAddOns SeasonAddOns { get; set; } = default!;
    [Inject] private ISeasonPassPricing PassPricing { get; set; } = default!;
    [Inject] private ISeasonStatusEditor StatusEditor { get; set; } = default!;
    [Inject] private ISeasonStatsReader StatsReader { get; set; } = default!;
    [Inject] private ISeasonLinkReader LinkReader { get; set; } = default!;
    [Inject] private IContentCreateLinks CreateLinks { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private static readonly IReadOnlyList<SeasonStatus> _statusOptions = Enum.GetValues<SeasonStatus>();

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private Dictionary<int, SeasonPrice?> _prices = new();
    private Dictionary<int, int> _eventCounts = new();
    private Dictionary<int, SeasonStats> _stats = new();
    private IReadOnlyDictionary<int, SeasonLinks> _links = new Dictionary<int, SeasonLinks>();
    private string? _createSeasonUrl;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        _links = await LinkReader.GetAllAsync();
        _createSeasonUrl = await CreateLinks.CreateSeasonUrlAsync();
        _prices = new Dictionary<int, SeasonPrice?>();
        _eventCounts = new Dictionary<int, int>();
        _stats = new Dictionary<int, SeasonStats>();
        _addOns = new Dictionary<int, IReadOnlyList<SeasonAddOn>>();
        foreach (var s in _seasons)
        {
            _prices[s.Id] = await SeasonPrices.GetBySeasonAsync(s.Id);
            _addOns[s.Id] = await SeasonAddOns.GetBySeasonAsync(s.Id);
            var eventIds = (await Events.GetBySeasonAsync(s.Id)).Select(e => e.Id).ToList();
            _eventCounts[s.Id] = eventIds.Count;
            _stats[s.Id] = await StatsReader.GetAsync(s.Id, eventIds);
        }
        _loading = false;
    }

    private SeasonPrice? Price(int seasonId) => _prices.GetValueOrDefault(seasonId);
    private int? Quota(int seasonId) => Price(seasonId)?.TotalSalesQuota;
    private int? SalesQuota(int seasonId) => Price(seasonId)?.DefaultTicketSalesQuota;
    private int EventCount(int seasonId) => _eventCounts.GetValueOrDefault(seasonId);
    private SeasonStats Stats(int seasonId) => _stats.GetValueOrDefault(seasonId) ?? new SeasonStats(0, 0, 0);
    private SeasonLinks Links(int seasonId) => _links.GetValueOrDefault(seasonId) ?? new SeasonLinks(null, null);

    private static string StatusLabel(SeasonStatus status) => status switch
    {
        SeasonStatus.Open => "Öffentlich",
        SeasonStatus.Intern => "Intern",
        SeasonStatus.Closed => "Geschlossen",
        _ => "Entwurf"
    };

    private async Task SaveNameAsync(Season s, string name)
    {
        await StatusEditor.SetNameAsync(s.Id, name);
        await ReloadAsync();
    }

    private async Task SavePeriodAsync(Season s, DateOnly? start, DateOnly? end)
    {
        if (start is null || end is null) throw new DomainException("Start- und Enddatum sind erforderlich.");
        await StatusEditor.SetPeriodAsync(s.Id, start.Value, end.Value);
        await ReloadAsync();
    }

    private async Task SaveStatusAsync(Season s, SeasonStatus status)
    {
        await StatusEditor.SetStatusAsync(s.Id, status);
        await ReloadAsync();
    }

    private async Task SaveQuotaAsync(Season s, decimal? value)
    {
        if (value is < 0) throw new DomainException("Das Einlasskontingent darf nicht negativ sein.");
        var quota = value is { } v ? (int?)Math.Round(v) : null;
        var existing = Price(s.Id);
        var price = existing is null
            ? SeasonPrice.Create(s.Id, quota, [])
            : SeasonPrice.FromPersistence(existing.Id, existing.SeasonId, quota, existing.Categories, existing.DefaultTicketSalesQuota);
        await SeasonPrices.SaveAsync(price);
        await ReloadAsync();
    }

    private async Task SaveSalesQuotaAsync(Season s, decimal? value)
    {
        if (value is < 0) throw new DomainException("Das Verkaufskontingent darf nicht negativ sein.");
        var quota = value is { } v ? (int?)Math.Round(v) : null;
        var existing = Price(s.Id);
        var price = existing is null
            ? SeasonPrice.Create(s.Id, null, [], quota)
            : SeasonPrice.FromPersistence(existing.Id, existing.SeasonId, existing.TotalSalesQuota, existing.Categories, quota);
        await SeasonPrices.SaveAsync(price);
        await ReloadAsync();
    }

    private (int SeasonId, bool Intern)? _copied;

    private async Task Copy(int seasonId, bool intern, string? relative)
    {
        if (string.IsNullOrEmpty(relative)) return;
        var origin = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
        var absolute = relative.StartsWith("http") ? relative : origin + relative;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", absolute);
            _copied = (seasonId, intern);
            StateHasChanged();
            await Task.Delay(2000);
            if (_copied is { } c && c.SeasonId == seasonId && c.Intern == intern)
            {
                _copied = null;
                StateHasChanged();
            }
        }
        catch { }
    }

    private Season? _editing;
    private List<TierRow> _editTiers = new();
    private bool _saving;
    private string? _editError;

    private async Task OpenEditAsync(Season s)
    {
        _editing = s;
        var price = Price(s.Id);
        var sold = await PassPricing.GetSoldCountsAsync(s.Id);
        var tiers = await PriceTiers.GetBySeasonAsync(s.Id);
        var priceByTier = (price?.Categories ?? [])
            .Where(c => c.TierId is not null)
            .ToDictionary(c => c.TierId!.Value);
        var promoByParent = tiers.Where(t => t.PromoOfTierId is not null).ToDictionary(t => t.PromoOfTierId!.Value);

        _editTiers = tiers
            .Where(t => t.PromoOfTierId is null)
            .OrderBy(t => t.SortOrder).ThenBy(t => t.Id)
            .Select(t =>
            {
                var row = new TierRow { Id = t.Id, Name = t.Name, MaxAge = t.MaxAge, SortOrder = t.SortOrder, Sold = sold.GetValueOrDefault(t.Id) };
                if (priceByTier.TryGetValue(t.Id, out var cp))
                {
                    row.PassOffered = cp.PassOffered; row.PassPrice = decimal.Round(cp.PassPrice, 2); row.PassQuota = cp.PassQuota;
                    row.PassAvailableUntil = cp.PassAvailableUntil;
                    row.TicketOffered = cp.TicketOffered; row.TicketPrice = decimal.Round(cp.TicketPrice, 2); row.TicketQuota = cp.TicketQuota;
                    row.TicketAvailableUntil = cp.TicketAvailableUntil;
                }
                if (promoByParent.GetValueOrDefault(t.Id) is { } promo)
                {
                    row.HasPromo = true; row.PromoId = promo.Id; row.PromoName = promo.Name;
                    row.PromoSold = sold.GetValueOrDefault(promo.Id);
                    if (priceByTier.TryGetValue(promo.Id, out var pp))
                    {
                        row.PassPromoPrice = decimal.Round(pp.PassPrice, 2); row.PassPromoQuota = pp.PassQuota;
                        row.PassPromoAvailableUntil = pp.PassAvailableUntil;
                        row.TicketPromoPrice = decimal.Round(pp.TicketPrice, 2); row.TicketPromoQuota = pp.TicketQuota;
                        row.TicketPromoAvailableUntil = pp.TicketAvailableUntil;
                    }
                }
                return row;
            })
            .ToList();
        _editError = null;
    }

    private void CancelEdit() { if (!_saving) { _editing = null; _editError = null; } }

    private void AddTier() =>
        _editTiers.Add(new TierRow { Name = "", SortOrder = (_editTiers.Count == 0 ? 0 : _editTiers.Max(t => t.SortOrder) + 1) });

    private void RemoveTier(TierRow r)
    {
        if (r.Sold > 0 || r.PromoSold > 0) return;
        _editTiers.Remove(r);
    }

    private static void TogglePromo(TierRow r)
    {
        r.HasPromo = !r.HasPromo;
        if (r.HasPromo && string.IsNullOrWhiteSpace(r.PromoName)) r.PromoName = $"Aktion {r.Name}".Trim();
    }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        _saving = true;
        _editError = null;
        try
        {
            var tierInputs = _editTiers
                .Where(t => !string.IsNullOrWhiteSpace(t.Name))
                .Select(t => new PriceTierInput(t.Id, t.Name.Trim(), t.MaxAge, t.SortOrder,
                    t.HasPromo && !string.IsNullOrWhiteSpace(t.PromoName)
                        ? new PriceTierPromoInput(t.PromoId, t.PromoName.Trim()) : null))
                .ToList();
            var saved = await PriceTiers.SaveForSeasonAsync(_editing.Id, tierInputs);

            var savedNormals = saved.Where(t => t.PromoOfTierId is null).OrderBy(t => t.SortOrder).ThenBy(t => t.Id).ToList();
            var savedPromoByParent = saved.Where(t => t.PromoOfTierId is not null).ToDictionary(t => t.PromoOfTierId!.Value);

            var cats = new List<SeasonCategoryPrice>();
            var editable = _editTiers.Where(t => !string.IsNullOrWhiteSpace(t.Name))
                .OrderBy(t => t.SortOrder).ThenBy(t => t.Id).ToList();
            for (var i = 0; i < editable.Count && i < savedNormals.Count; i++)
            {
                var t = editable[i];
                var normal = savedNormals[i];
                cats.Add(SeasonCategoryPrice.Create(default,
                    decimal.Round(t.PassPrice, 2), t.PassOffered, t.PassQuota,
                    decimal.Round(t.TicketPrice, 2), t.TicketOffered, t.TicketQuota,
                    t.PassAvailableUntil, t.TicketAvailableUntil, normal.Id));

                if (savedPromoByParent.GetValueOrDefault(normal.Id) is { } promo)
                    cats.Add(SeasonCategoryPrice.Create(default,
                        decimal.Round(t.PassPromoPrice, 2), t.PassOffered, t.PassPromoQuota,
                        decimal.Round(t.TicketPromoPrice, 2), t.TicketOffered, t.TicketPromoQuota,
                        t.PassPromoAvailableUntil, t.TicketPromoAvailableUntil, promo.Id));
            }

            var existing = Price(_editing.Id);
            var price = existing is null
                ? SeasonPrice.Create(_editing.Id, null, cats)
                : SeasonPrice.FromPersistence(existing.Id, existing.SeasonId, existing.TotalSalesQuota, cats, existing.DefaultTicketSalesQuota);
            await SeasonPrices.SaveAsync(price);
            _editing = null;
            await ReloadAsync();
        }
        catch (DomainException ex) { _editError = ex.Message; }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private sealed class TierRow
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int? MaxAge { get; set; }
        public int SortOrder { get; set; }
        public bool PassOffered { get; set; }
        public decimal PassPrice { get; set; }
        public int? PassQuota { get; set; }
        public DateOnly? PassAvailableUntil { get; set; }
        public bool TicketOffered { get; set; }
        public decimal TicketPrice { get; set; }
        public int? TicketQuota { get; set; }
        public DateOnly? TicketAvailableUntil { get; set; }
        public int Sold { get; set; }
        public bool HasPromo { get; set; }
        public int PromoId { get; set; }
        public string PromoName { get; set; } = "";
        public decimal PassPromoPrice { get; set; }
        public int? PassPromoQuota { get; set; }
        public DateOnly? PassPromoAvailableUntil { get; set; }
        public decimal TicketPromoPrice { get; set; }
        public int? TicketPromoQuota { get; set; }
        public DateOnly? TicketPromoAvailableUntil { get; set; }
        public int PromoSold { get; set; }
        public bool CanDelete => Sold == 0 && PromoSold == 0;
    }

    private Dictionary<int, IReadOnlyList<SeasonAddOn>> _addOns = new();
    private int AddOnCount(int seasonId) => _addOns.GetValueOrDefault(seasonId)?.Count ?? 0;

    private Season? _editingAddOns;
    private List<AddOnRow> _addOnRows = new();
    private bool _addOnSaving;
    private string? _addOnError;

    private void OpenAddOns(Season s)
    {
        _editingAddOns = s;
        _addOnRows = (_addOns.GetValueOrDefault(s.Id) ?? [])
            .Select(a => new AddOnRow { Label = a.Label, Price = decimal.Round(a.Price, 2), Active = a.Active, Scope = a.Scope })
            .ToList();
        _addOnError = null;
    }

    private void CancelAddOns() { if (!_addOnSaving) { _editingAddOns = null; _addOnError = null; } }
    private void AddAddOnRow() => _addOnRows.Add(new AddOnRow { Active = true });
    private void RemoveAddOnRow(AddOnRow r) => _addOnRows.Remove(r);

    private async Task SaveAddOns()
    {
        if (_editingAddOns is null) return;
        _addOnSaving = true;
        _addOnError = null;
        try
        {
            var options = _addOnRows
                .Where(r => !string.IsNullOrWhiteSpace(r.Label))
                .Select(r => SeasonAddOn.Create(_editingAddOns.Id, r.Label, decimal.Round(r.Price, 2), r.Active, 0, r.Scope))
                .ToList();
            await SeasonAddOns.ReplaceForSeasonAsync(_editingAddOns.Id, options);
            _editingAddOns = null;
            await ReloadAsync();
        }
        catch (DomainException ex) { _addOnError = ex.Message; }
        catch (Exception ex) { _addOnError = ex.Message; }
        finally { _addOnSaving = false; }
    }

    private sealed class AddOnRow
    {
        public string Label { get; set; } = "";
        public decimal Price { get; set; }
        public bool Active { get; set; } = true;
        public AddOnScope Scope { get; set; } = AddOnScope.PerPass;
    }
}
