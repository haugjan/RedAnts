@using RedAnts.Domain.Ticketing
@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Ports

@* Flextickets administration: Flextickets are always issued as bundles. Pick a season (synced across
   tabs), list its bundles, create bundles, and rename a bundle via the last-column icon. Shared look
   from /css/ticketing-admin.css. *@

<section class="ta-page">
    <h1 class="ta-page-title">@TicketType.SeasonSingle.DisplayName()</h1>
    <p class="ta-page-lead">Flextickets werden immer als Bundle erstellt und bundle-weise angezeigt.</p>

    @if (_loading)
    {
        <p class="ta-muted-text">Wird geladen …</p>
    }
    else if (_seasons.Count == 0)
    {
        <div class="ta-placeholder">Es sind noch keine Saisons erfasst.</div>
    }
    else
    {
        <div class="ta-toolbar">
            <div class="ta-toolbar-filters">
                <div class="ta-field">
                    <label class="ta-label" for="seasonSelect">Saison</label>
                    <select id="seasonSelect" class="ta-select" @bind="SelectedSeasonId" @bind:after="ReloadBundlesAsync">
                        @foreach (var s in _seasons)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ta-toolbar-actions">
                <button type="button" class="ta-btn ta-btn-primary" disabled="@(SelectedSeasonId <= 0)" @onclick="OpenCreate">
                    Bundle erstellen
                </button>
            </div>
        </div>

        @if (_bundles.Count == 0)
        {
            <div class="ta-placeholder">Für diese Saison sind keine Flexticket-Bundles erfasst.</div>
        }
        else
        {
            <div class="ta-table-wrap">
                <table class="ta-table">
                    <thead>
                        <tr>
                            <th class="ta-th-sort" @onclick='() => Sort("reference")'>Referenz <span class="ta-sort-ind">@Ind("reference")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("created")'>Erstellt <span class="ta-sort-ind">@Ind("created")</span></th>
                            <th class="ta-th-sort" @onclick='() => Sort("category")'>Kategorie <span class="ta-sort-ind">@Ind("category")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("count")'>Anzahl <span class="ta-sort-ind">@Ind("count")</span></th>
                            <th class="ta-num ta-th-sort" @onclick='() => Sort("redeemed")'>Eingelöst <span class="ta-sort-ind">@Ind("redeemed")</span></th>
                            <th class="ta-num">Offen</th>
                            <th class="ta-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Sorted())
                        {
                            <tr>
                                <td class="ta-cell-ref">@b.Reference</td>
                                <td>@b.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@b.Category.DisplayName()</td>
                                <td class="ta-num">@b.TicketCount</td>
                                <td class="ta-num">@b.RedeemedCount</td>
                                <td class="ta-num">@(b.TicketCount - b.RedeemedCount)</td>
                                <td class="ta-col-actions">
                                    <a class="ta-icon-btn" href="/admin/flextickets/bundle/@b.Id/serienbrief.rtf"
                                       title="Word-Serienbrief mit QR-Codes herunterladen" target="_blank" rel="noopener">📄</a>
                                    <a class="ta-icon-btn" href="/admin/flextickets/bundle/@b.Id/tickets.csv"
                                       title="Bundle als CSV herunterladen (Kurzkennung + Ticketlink)" target="_blank" rel="noopener">⬇</a>
                                    <button type="button" class="ta-icon-btn" title="Referenz bearbeiten" @onclick="() => OpenEdit(b)">✎</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="ta-summary">
                @_bundles.Count Bundles · @_bundles.Sum(b => b.TicketCount) Flextickets · @_bundles.Sum(b => b.RedeemedCount) eingelöst
            </p>
        }
    }
</section>

@if (_showCreate)
{
    <div class="ta-overlay" @onmousedown="CloseCreate">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Flexticket-Bundle erstellen</h2>

            <div class="ta-field">
                <label class="ta-label">Saison</label>
                <div class="ta-readonly">@_selectedSeasonName</div>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newCategory">Ticketkategorie</label>
                <select id="newCategory" class="ta-select" @bind="_newCategory">
                    @foreach (var c in Categories)
                    {
                        <option value="@c">@c.DisplayName()</option>
                    }
                </select>
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newReference">Referenz</label>
                <input id="newReference" class="ta-input" type="text" maxlength="50" placeholder="z. B. Charge 2026-A" @bind="_newReference" />
            </div>
            <div class="ta-field">
                <label class="ta-label" for="newQuantity">Anzahl Flextickets</label>
                <input id="newQuantity" class="ta-input" type="number" min="1" max="1000" @bind="_newQuantity" />
            </div>

            @if (!string.IsNullOrEmpty(_createError))
            {
                <div class="ta-error">@_createError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CloseCreate" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="CreateBundleAsync" disabled="@_saving">
                    @(_saving ? "Wird erstellt …" : "Bundle erstellen")
                </button>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="ta-overlay" @onmousedown="CancelEdit">
        <div class="ta-modal" @onmousedown:stopPropagation="true">
            <h2 class="ta-modal-title">Bundle bearbeiten</h2>
            <p class="ta-modal-sub">@_editing.Category.DisplayName() · @_editing.TicketCount Flextickets</p>

            <div class="ta-field">
                <label class="ta-label" for="editReference">Referenz</label>
                <input id="editReference" class="ta-input" type="text" maxlength="50" @bind="_editReference" />
                <p class="ta-field-hint">Kategorie und Anzahl eines ausgestellten Bundles sind nicht änderbar.</p>
            </div>

            @if (!string.IsNullOrEmpty(_editError))
            {
                <div class="ta-modal-error">@_editError</div>
            }

            <div class="ta-modal-actions">
                <button type="button" class="ta-btn ta-btn-ghost" @onclick="CancelEdit" disabled="@_saving">Abbrechen</button>
                <button type="button" class="ta-btn ta-btn-primary" @onclick="SaveEditAsync" disabled="@_saving">
                    @(_saving ? "Speichert …" : "Speichern")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    [Inject] private ISeasons Seasons { get; set; } = default!;
    [Inject] private IFlexTicketBundles Bundles { get; set; } = default!;
    [Inject] private IFlexBundleEditor BundleEditor { get; set; } = default!;
    [Inject] private TicketingAdminState AdminState { get; set; } = default!;

    private static readonly TicketCategory[] Categories = Enum.GetValues<TicketCategory>();

    private bool _loading = true;
    private IReadOnlyList<Season> _seasons = [];
    private IReadOnlyList<FlexTicketBundleView> _bundles = [];

    public int SelectedSeasonId { get; set; }
    private string _selectedSeasonName = "";

    private string _sortCol = "created";
    private bool _sortAsc = false;

    // Create overlay
    private bool _showCreate;
    private bool _saving;
    private string? _createError;
    private TicketCategory _newCategory = TicketCategory.Adult;
    private string _newReference = "";
    private int _newQuantity = 1;

    protected override async Task OnInitializedAsync()
    {
        _seasons = (await Seasons.GetAllAsync()).OrderByDescending(s => s.StartDate).ToList();
        SelectedSeasonId = AdminState.SelectedSeasonId is int id && _seasons.Any(s => s.Id == id)
            ? id
            : CurrentSeason(_seasons)?.Id ?? _seasons.FirstOrDefault()?.Id ?? 0;
        await ReloadBundlesAsync();
        _loading = false;
    }

    private async Task ReloadBundlesAsync()
    {
        AdminState.SelectedSeasonId = SelectedSeasonId > 0 ? SelectedSeasonId : null;
        _selectedSeasonName = _seasons.FirstOrDefault(s => s.Id == SelectedSeasonId)?.Name ?? "";
        _bundles = SelectedSeasonId > 0 ? await Bundles.GetBySeasonAsync(SelectedSeasonId) : [];
    }

    // --- Sorting ---
    private void Sort(string col) { _sortAsc = _sortCol == col ? !_sortAsc : true; _sortCol = col; }
    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";
    private IEnumerable<FlexTicketBundleView> Sorted()
    {
        IEnumerable<FlexTicketBundleView> q = _sortCol switch
        {
            "reference" => _bundles.OrderBy(b => b.Reference),
            "category" => _bundles.OrderBy(b => b.Category),
            "count" => _bundles.OrderBy(b => b.TicketCount),
            "redeemed" => _bundles.OrderBy(b => b.RedeemedCount),
            _ => _bundles.OrderBy(b => b.CreatedAt),
        };
        return _sortAsc ? q : q.Reverse();
    }

    // --- Create ---
    private void OpenCreate()
    {
        _createError = null;
        _newCategory = TicketCategory.Adult;
        _newReference = "";
        _newQuantity = 1;
        _showCreate = true;
    }

    private void CloseCreate() { if (!_saving) _showCreate = false; }

    private async Task CreateBundleAsync()
    {
        _createError = null;
        var reference = (_newReference ?? "").Trim();

        if (SelectedSeasonId <= 0) { _createError = "Bitte zuerst eine Saison wählen."; return; }
        if (reference.Length == 0) { _createError = "Bitte eine Referenz angeben."; return; }
        if (reference.Length > FlexTicketBundle.ReferenceMaxLength)
        { _createError = $"Die Referenz darf höchstens {FlexTicketBundle.ReferenceMaxLength} Zeichen lang sein."; return; }
        if (_newQuantity < 1) { _createError = "Die Anzahl muss mindestens 1 sein."; return; }

        _saving = true;
        try
        {
            if (await Bundles.ReferenceExistsAsync(SelectedSeasonId, reference))
            {
                _createError = $"Die Referenz „{reference}“ ist in dieser Saison bereits vergeben.";
                return;
            }
            await Bundles.CreateAsync(SelectedSeasonId, _newCategory, reference, _newQuantity);
            _showCreate = false;
            await ReloadBundlesAsync();
        }
        catch (DomainException ex) { _createError = ex.Message; }
        finally { _saving = false; }
    }

    // --- Edit (rename) overlay ---
    private FlexTicketBundleView? _editing;
    private string _editReference = "";
    private string? _editError;

    private void OpenEdit(FlexTicketBundleView b)
    {
        _editing = b;
        _editReference = b.Reference;
        _editError = null;
    }

    private void CancelEdit() { if (!_saving) { _editing = null; _editError = null; } }

    private async Task SaveEditAsync()
    {
        if (_editing is null) return;
        var reference = (_editReference ?? "").Trim();
        if (reference == _editing.Reference) { _editing = null; return; } // no change
        _saving = true;
        _editError = null;
        try
        {
            await BundleEditor.RenameAsync(_editing.Id, _editing.SeasonId, reference);
            _editing = null;
            await ReloadBundlesAsync();
        }
        catch (DomainException ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private static Season? CurrentSeason(IReadOnlyList<Season> seasons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return seasons.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate)
            ?? seasons.Where(s => s.StartDate <= today).MaxBy(s => s.StartDate);
    }
}
