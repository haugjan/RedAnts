@using Microsoft.AspNetCore.Components.Web
@implements IDisposable
@inject IEvents Events
@inject IVenues Venues
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="scan-app">
    @if (string.IsNullOrEmpty(_operator))
    {
        <header class="scan-app__header">
            <h1>Tickets scannen</h1>
            <p>Nur angemeldete Helfer können scannen.</p>
        </header>

        <div class="scan-login">
            <a class="scan-login__btn" href="/scan/login">Zur Helfer-Anmeldung</a>
        </div>
    }
    else if (_testMode)
    {
        <ScanView EventId="0" EventName="Testevent" Operator="@_operator" IsTest="true" OnBack="BackToList" />
    }
    else if (_selected is null)
    {
        <header class="scan-app__header scan-app__header--events">
            <div>
                <h1>Tickets scannen</h1>
                <p>Event auswählen · @_operator</p>
            </div>
            <button type="button" class="scan-app__logout" @onclick="Logout">Ausloggen</button>
        </header>

        @if (_events is null)
        {
            <p class="scan-app__hint">Lädt Events…</p>
        }
        else if (_events.Count == 0)
        {
            <p class="scan-app__hint">Keine anstehenden Events.</p>
        }
        else
        {
            <ul class="event-list">
                @for (var i = 0; i < _events.Count; i++)
                {
                    var evt = _events[i];
                    var isToday = evt.Date == _today;
                    var isNext = i == 0 && !isToday;
                    <li>
                        <button type="button"
                                class="event-card @(isToday ? "event-card--today" : "") @(isNext ? "event-card--next" : "")"
                                @onclick="() => Select(evt)">
                            @if (isToday)
                            {
                                <span class="event-card__badge event-card__badge--today">Heute</span>
                            }
                            else if (isNext)
                            {
                                <span class="event-card__badge">Nächstes Event</span>
                            }
                            <span class="event-card__date">@evt.Date.ToString("dd.MM.yyyy")@(evt.TimeUnknown ? "" : $" · {evt.StartTime:HH:mm}")</span>
                            <span class="event-card__name">@evt.Name</span>
                            <span class="event-card__meta">
                                <span class="event-card__venue">@VenueName(evt.VenueId)</span>
                                <span class="status status--@evt.Status.ToString().ToLowerInvariant()">@StatusLabel(evt.Status)</span>
                            </span>
                        </button>
                    </li>
                }
            </ul>
        }

        <button type="button" class="event-card event-card--test" @onclick="() => _testMode = true">
            <span class="event-card__badge event-card__badge--test">Test</span>
            <span class="event-card__name">Testevent</span>
            <span class="event-card__meta">Beliebiges gültiges Ticket prüfen – ohne ein- oder auszuchecken.</span>
        </button>
    }
    else
    {
        <ScanView EventId="_selected.Id" EventName="@_selected.Name" Operator="@_operator" OnBack="BackToList" />
    }

    @if (_pendingEvent is { } pend)
    {
        <div class="scan-confirm" @onclick="() => _pendingEvent = null">
            <div class="scan-confirm__box" @onclick:stopPropagation="true">
                <p class="scan-confirm__question">Dieser Anlass ist nicht heute. Bist du sicher?</p>
                <p class="scan-confirm__detail">@pend.Name · @pend.Date.ToString("dd.MM.yyyy")</p>
                <div class="scan-confirm__actions scan-confirm__actions--stack">
                    <button type="button" class="scan-confirm__btn scan-confirm__btn--yes" @onclick="() => ConfirmSelect(pend)">Ja, trotzdem scannen</button>
                    <button type="button" class="scan-confirm__btn" @onclick="() => _pendingEvent = null">Abbrechen</button>
                </div>
            </div>
        </div>
    }

    @if (_selected is null && !_testMode)
    {
        <a class="scan-app__testlink" href="/scanner-test">
            <span class="scan-app__testlink-icon" aria-hidden="true">&#9636;</span> Test QR-Code
        </a>
        <p class="scan-app__version">Scanner v@(Version)</p>
    }
</div>

<style>
    .scan-app__header--events { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.8rem; }
    .scan-app__logout {
        flex: 0 0 auto; padding: 0.5rem 0.9rem; border-radius: 8px; border: 1px solid #ccc;
        background: #fff; color: #555; font-size: 0.85rem; font-weight: 700; cursor: pointer;
    }
    .scan-login { text-align: center; padding: 1.5rem 1rem; }
    .scan-login__btn {
        display: inline-block; margin-top: 1rem; width: 100%; max-width: 320px; padding: 0.9rem;
        background: #1a7f37; color: #fff; border: none; border-radius: 10px; box-sizing: border-box;
        font-size: 1.05rem; font-weight: 800; cursor: pointer; text-decoration: none; text-align: center;
    }
    .scan-app__version {
        text-align: center; margin: 0.6rem 0 0.5rem; color: #b0b0b0;
        font-size: 0.75rem; letter-spacing: 0.04em;
    }
    .scan-app__testlink {
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        margin: 1.2rem 0 0; padding: 0.75rem 1rem; border-radius: 12px;
        border: 2px solid #0d9488; background: #f0fbfa; color: #0d9488;
        font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;
        font-size: 0.98rem; text-decoration: none;
    }
    .scan-app__testlink:hover { background: #0d9488; color: #fff; }
    .scan-app__testlink-icon { font-size: 1.2rem; line-height: 1; }

    .event-card--today { border-color: #1a7f37; border-width: 2px; box-shadow: 0 4px 16px rgba(26, 127, 55, 0.18); }
    .event-card__badge--today { background: #1a7f37; }
    .event-card--test { border: 2px dashed #0d9488; background: #f0fbfa; margin-top: 0.9rem; width: 100%; text-align: left; cursor: pointer; }
    .event-card__badge--test { background: #0d9488; }

    .scan-confirm {
        position: fixed; inset: 0; z-index: 1100; background: rgba(0,0,0,0.5);
        display: flex; align-items: center; justify-content: center; padding: 1.5rem;
    }
    .scan-confirm__box {
        background: #fff; border-radius: 14px; padding: 1.4rem 1.5rem; width: 100%; max-width: 340px;
        text-align: center; box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    }
    .scan-confirm__question { margin: 0 0 0.4rem; font-size: 1.1rem; font-weight: 700; color: #222; }
    .scan-confirm__detail { margin: 0 0 1.1rem; font-size: 0.9rem; color: #666; }
    .scan-confirm__actions { display: flex; gap: 0.6rem; }
    .scan-confirm__actions--stack { flex-direction: column; }
    .scan-confirm__btn {
        flex: 1 1 0; padding: 0.75rem; border-radius: 8px; border: 1px solid #ccc;
        background: #fff; color: #555; font-weight: 700; font-size: 0.95rem; cursor: pointer;
    }
    .scan-confirm__btn--yes { background: #1a7f37; color: #fff; border-color: #1a7f37; }
</style>

@code {
    private const string Version = "14";

    private DotNetObjectReference<TicketScanner>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("raScannerBack.register", _selfRef);
        }
    }

    [JSInvokable]
    public void HandleBack()
    {
        if (_pendingEvent is not null) { _pendingEvent = null; StateHasChanged(); return; }
        if (_selected is not null || _testMode) { BackToList(); StateHasChanged(); }
    }

    public void Dispose() => _selfRef?.Dispose();

    [Parameter] public string HelperName { get; set; } = "";
    [Parameter] public bool AllEvents { get; set; } = true;
    [Parameter] public string AllowedEventIds { get; set; } = "";

    private readonly DateOnly _today = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<Event>? _events;
    private IReadOnlyDictionary<int, string> _venues = new Dictionary<int, string>();
    private Event? _selected;
    private bool _testMode;
    private Event? _pendingEvent;
    private string? _operator;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(HelperName)) _operator = HelperName.Trim();
        _venues = (await Venues.GetAllAsync()).ToDictionary(v => v.Id, v => v.Name);
        var events = await Events.GetUpcomingForScanningAsync();
        if (!string.IsNullOrEmpty(HelperName) && !AllEvents)
        {
            var allowed = AllowedEventIds
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(s => int.TryParse(s, out var id) ? id : 0)
                .Where(id => id > 0)
                .ToHashSet();
            events = events.Where(e => allowed.Contains(e.Id)).ToList();
        }
        _events = events;
    }

    private void Logout() => Navigation.NavigateTo("/scan/logout", forceLoad: true);

    private void Select(Event evt)
    {
        if (evt.Date == _today) _selected = evt;
        else _pendingEvent = evt;
    }

    private void ConfirmSelect(Event evt)
    {
        _pendingEvent = null;
        _selected = evt;
    }

    private void BackToList() { _selected = null; _testMode = false; }

    private string VenueName(int venueId) => _venues.TryGetValue(venueId, out var name) ? name : "";

    private static string StatusLabel(EventStatus status) => status switch
    {
        EventStatus.Draft => "Entwurf",
        EventStatus.Open => "Offen",
        EventStatus.Intern => "Intern",
        EventStatus.Closed => "Geschlossen",
        _ => status.ToString()
    };
}
