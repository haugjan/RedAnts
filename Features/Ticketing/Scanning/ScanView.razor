@using RedAnts.Domain.Ticketing.Sales
@using RedAnts.Features.Ticketing.Tickets
@using Microsoft.AspNetCore.Components.Web
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ITicketTokens Tickets
@inject IAdmissionService Admission

<div class="scan-view scan-view--@ModeKey @(IsTest ? "scan-view--test" : "")">
    <header class="scan-view__header">
        <button type="button" class="scan-view__back" @onclick="OnBack">&larr; Event-Auswahl</button>
        <span class="scan-view__title">@EventName</span>
    </header>

    <div class="scan-status scan-status--@(IsTest ? "test" : ModeKey)">
        <span class="scan-status__label">@(IsTest ? "Testmodus" : (_mode == ScanMode.CheckIn ? "Einchecken" : "Auschecken"))</span>
        <span class="scan-status__who">@Operator</span>
    </div>

    @if (!IsTest && _occupancy is { } occ)
    {
        <div class="scan-cap @(occ.Full ? "scan-cap--full" : "")">
            @if (occ.Quota is null)
            {
                <span class="scan-cap__free">@occ.Inside drinnen</span>
                <span class="scan-cap__sub">Kein Einlasslimit</span>
            }
            else
            {
                <span class="scan-cap__free">@occ.Remaining frei</span>
                <span class="scan-cap__sub">@occ.Inside / @occ.Quota im Einlass</span>
            }
        </div>
    }

    <div id="qr-reader" class="qr-reader"></div>

    @if (IsTest)
    {
        <p class="scan-test-hint">Testmodus: gültige Tickets werden geprüft, ohne ein- oder auszuchecken.</p>
        <button type="button" class="scan-action scan-action--extra scan-action--full" @onclick="OpenExtras">Ticket-Nr. eingeben</button>
    }
    else
    {
        <div class="scan-actions">
            <button type="button" class="scan-action scan-action--mode scan-action--@ModeKey" @onclick="ToggleMode">
                @(_mode == ScanMode.CheckIn ? "Auschecken" : "Einchecken")
            </button>
            <button type="button" class="scan-action scan-action--extra" @onclick="OpenExtras">Zusatzfunktionen</button>
        </div>
    }

    @if (_error is not null)
    {
        <p class="scan-view__hint scan-view__hint--error">@_error</p>
    }

    @if (_showExtras)
    {
        <div class="scan-extras" @onclick="CloseExtras">
            <div class="scan-extras__box" @onclick:stopPropagation="true">
                <div class="scan-extras__head">
                    <h2 class="scan-extras__title">Zusatzfunktionen</h2>
                    <button type="button" class="scan-extras__close" @onclick="CloseExtras" aria-label="Schliessen">✕</button>
                </div>

                <div class="scan-extras__section">
                    <span class="scan-extras__label">Ticket-Nr. von Hand eingeben</span>
                    <div class="scan-manual">
                        <input class="scan-manual__input" placeholder="8 Zeichen" maxlength="8"
                               @bind="_manualCode" @bind:event="oninput" @onkeydown="OnManualKey" />
                        <button type="button" class="scan-manual__btn" @onclick="SubmitManualAsync" disabled="@_busy">Prüfen</button>
                    </div>
                </div>

                @if (!IsTest)
                {
                    <div class="scan-extras__section">
                        <span class="scan-extras__label">Freien Einlass gewähren</span>
                        <div class="scan-free-grid">
                            @foreach (var type in OfferedFreeEntryTypes)
                            {
                                var t = type;
                                <button type="button" class="scan-free-tile scan-free-tile--in"
                                        @onclick="() => GrantFreeAsync(t)" disabled="@(_busy || _occupancy?.Full == true)">
                                    @t.DisplayName()
                                </button>
                            }
                        </div>
                    </div>

                    @if (FreeInside > 0)
                    {
                        <div class="scan-extras__section">
                            <span class="scan-extras__label">Freien Einlass zurücknehmen (@FreeInside drinnen)</span>
                            <div class="scan-free-grid">
                                @foreach (var type in OfferedFreeEntryTypes)
                                {
                                    var t = type;
                                    <button type="button" class="scan-free-tile scan-free-tile--out"
                                            @onclick="() => RevokeFreeAsync(t)" disabled="@_busy">
                                        @t.DisplayName()
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (_last is { } o)
    {
        <div class="scan-result scan-result--@ResultClass(o)" @onclick="DismissAsync">
            <div class="scan-result__icon">@ResultIcon(o)</div>
            <div class="scan-result__title">@ResultTitle(o)</div>

            @if (!string.IsNullOrEmpty(o.CategoryLabel))
            {
                <div class="scan-result__category">@o.CategoryLabel</div>
            }
            @if (!string.IsNullOrEmpty(o.Holder))
            {
                <div class="scan-result__holder">@o.Holder</div>
            }

            @if (o.Outcome == AdmissionOutcome.CheckedIn && o.Occupancy is { Quota: { } cap } co && co.Inside >= cap)
            {
                <div class="scan-result__warn">⚠ Hallenkapazität @(co.Inside > cap ? "überschritten" : "erreicht") (@co.Inside / @cap)</div>
            }

            @if (!o.Ok)
            {
                <div class="scan-result__reason">@o.Reason</div>
                @if (o.PriorAt is { } at)
                {
                    <div class="scan-result__prior">
                        Bereits am @FmtTime(at)@(string.IsNullOrEmpty(o.PriorBy) ? "" : $" durch {o.PriorBy}")
                    </div>
                }
            }

            <div class="scan-result__meta">
                @if (o.Type is { } t) { @TypeLabel(t) }
                @if (!string.IsNullOrEmpty(o.Reference)) { <span> · @o.Reference</span> }
            </div>

            <button type="button" class="scan-result__next">@(o.Ok ? "Weiter" : "Verstanden – schliessen")</button>
        </div>
    }
</div>

<style>
    .scan-view { position: relative; }
    .scan-view--in { --scan-accent: #1a7f37; }
    .scan-view--out { --scan-accent: #1f5fbf; }
    .scan-view--test { --scan-accent: #0d9488; }

    .scan-status {
        display: flex; align-items: center; gap: 0.5rem; margin: 0.35rem 0 0.5rem;
        padding: 0.65rem 0.95rem; border-radius: 12px; background: var(--scan-accent); color: #fff;
    }
    .scan-status__label {
        font-size: 1.45rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: #fff;
    }
    .scan-status__who { margin-left: auto; font-size: 0.85rem; color: rgba(255,255,255,0.9); }

    .qr-reader { border: 3px solid var(--scan-accent); border-radius: 12px; overflow: hidden; max-height: 54vh; }
    .qr-reader video { max-height: calc(54vh - 6px); object-fit: cover; }

    .scan-cap {
        display: flex; flex-direction: row; align-items: baseline; justify-content: center; gap: 0.5rem;
        margin: 0.3rem 0 0.4rem; padding: 0.3rem 0.8rem; border-radius: 8px;
        background: #e7f6ec; color: #1a7f37;
    }
    .scan-cap--full { background: #fdeaea; color: #b42318; }
    .scan-cap__free { font-size: 1.1rem; font-weight: 800; line-height: 1; }
    .scan-cap__sub { font-size: 0.75rem; opacity: 0.85; }

    .scan-test-hint { margin: 0.5rem 0 0.2rem; font-size: 0.85rem; color: #0d7d72; text-align: center; }

    .scan-actions { display: grid; grid-template-columns: 1fr; gap: 0.7rem; margin: 0.7rem 0 0; }
    .scan-action {
        min-height: 4.4rem; padding: 0.9rem; border-radius: 14px; border: none;
        font-size: 1.3rem; font-weight: 800; cursor: pointer; color: #fff;
    }
    .scan-action:disabled { opacity: 0.5; cursor: default; }
    .scan-action--mode.scan-action--in { background: #1f5fbf; }
    .scan-action--mode.scan-action--out { background: #1a7f37; }
    .scan-action--extra { background: #444; }
    .scan-action--full { width: 100%; margin-top: 0.6rem; }

    .scan-extras {
        position: fixed; inset: 0; z-index: 1150; background: rgba(0,0,0,0.55);
        display: flex; align-items: flex-end; justify-content: center;
    }
    .scan-extras__box {
        background: #fff; border-radius: 18px 18px 0 0; width: 100%; max-width: 560px;
        max-height: 92vh; overflow-y: auto; padding: 1.1rem 1.1rem 1.6rem;
        box-shadow: 0 -8px 40px rgba(0,0,0,0.3);
    }
    .scan-extras__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
    .scan-extras__title { margin: 0; font-size: 1.35rem; font-weight: 800; }
    .scan-extras__close {
        border: none; background: #eee; color: #333; width: 2.4rem; height: 2.4rem;
        border-radius: 50%; font-size: 1.1rem; cursor: pointer;
    }
    .scan-extras__section { margin-top: 1rem; }
    .scan-extras__label { display: block; margin-bottom: 0.4rem; font-size: 0.9rem; font-weight: 700; color: #555; }

    .scan-manual { display: flex; gap: 0.5rem; }
    .scan-manual__input {
        flex: 1 1 auto; padding: 0.85rem 0.8rem; font-size: 1.3rem; letter-spacing: 0.14em;
        text-transform: uppercase; font-family: ui-monospace, Consolas, monospace;
        border: 2px solid #ccc; border-radius: 12px; box-sizing: border-box; min-width: 0;
    }
    .scan-manual__btn {
        flex: 0 0 auto; padding: 0 1.4rem; border-radius: 12px; border: none;
        background: var(--scan-accent, #1a7f37); color: #fff; font-weight: 800; font-size: 1.1rem; cursor: pointer;
    }
    .scan-manual__btn:disabled { opacity: 0.5; cursor: default; }

    .scan-free-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
    .scan-free-tile {
        min-height: 5rem; padding: 0.8rem 0.6rem; border-radius: 14px; border: 2px solid transparent;
        font-size: 1.2rem; font-weight: 800; cursor: pointer; line-height: 1.15;
    }
    .scan-free-tile:disabled { opacity: 0.45; cursor: default; }
    .scan-free-tile--in { background: #1a7f37; color: #fff; }
    .scan-free-tile--out { background: #fff; color: #1f5fbf; border-color: #1f5fbf; }

    .scan-result {
        position: fixed; inset: 0; z-index: 1200; display: flex; flex-direction: column;
        align-items: center; justify-content: center; text-align: center; padding: 2rem 1.5rem;
        color: #fff; cursor: pointer;
    }
    .scan-result--in { background: #1a7f37; }
    .scan-result--out { background: #1f5fbf; }
    .scan-result--fail { background: #b42318; }
    .scan-result--test { background: #0d9488; }
    .scan-result__icon { font-size: 5rem; line-height: 1; }
    .scan-result__title { font-size: 1.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.4rem; }
    .scan-result__category {
        margin-top: 1.2rem; font-size: 3rem; font-weight: 900; text-transform: uppercase;
        letter-spacing: 0.03em; line-height: 1.05; background: rgba(255,255,255,0.16);
        padding: 0.5rem 1.2rem; border-radius: 14px;
    }
    .scan-result__holder { margin-top: 0.9rem; font-size: 1.6rem; font-weight: 700; }
    .scan-result__warn {
        margin-top: 1rem; padding: 0.5rem 1rem; border-radius: 10px;
        background: rgba(255,255,255,0.22); font-size: 1.15rem; font-weight: 800;
    }
    .scan-result__reason { margin-top: 1rem; font-size: 1.25rem; font-weight: 700; }
    .scan-result__prior { margin-top: 0.5rem; font-size: 1rem; opacity: 0.95; }
    .scan-result__meta { margin-top: 1rem; font-size: 0.95rem; opacity: 0.9; }
    .scan-result__next {
        margin-top: 1.6rem; padding: 0.8rem 1.6rem; border: 2px solid #fff; border-radius: 10px;
        background: transparent; color: #fff; font-size: 1rem; font-weight: 800; cursor: pointer;
    }
</style>

@code {
    [Parameter, EditorRequired] public int EventId { get; set; }
    [Parameter, EditorRequired] public string EventName { get; set; } = "";
    [Parameter, EditorRequired] public string Operator { get; set; } = "";
    [Parameter] public bool IsTest { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private DotNetObjectReference<ScanView>? _ref;
    private Occupancy? _occupancy;
    private ScanOutcome? _last;
    private ScanMode _mode = ScanMode.CheckIn;
    private bool _showExtras;
    private string _manualCode = "";
    private bool _cameraStarted;
    private bool _cameraPaused;
    private bool _busy;
    private string? _error;

    private static readonly FreeEntryType[] OfferedFreeEntryTypes =
    [
        FreeEntryType.Official,
        FreeEntryType.SwissUnihockeyFreeCard,
        FreeEntryType.Helper
    ];

    private string ModeKey => _mode == ScanMode.CheckIn ? "in" : "out";
    private int FreeInside => _occupancy?.FreeInside ?? 0;

    protected override async Task OnInitializedAsync()
    {
        if (!IsTest) _occupancy = await Admission.GetOccupancyAsync(EventId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_cameraStarted) return;
        _cameraStarted = true;
        _ref ??= DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("ticketScanner.start", "qr-reader", _ref);
        }
        catch (JSException ex)
        {
            _error = "Kamera konnte nicht gestartet werden: " + ex.Message;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnCodeScanned(string code)
    {
        _cameraPaused = true;
        if (Tickets.TryVerify(ExtractToken(code), out var data))
        {
            _last = await Admission.ScanTicketAsync(EventId, data.Type, data.Uuid, data.ScopeId, _mode, Operator, IsTest);
            if (!IsTest) _occupancy = _last.Occupancy;
        }
        else
        {
            _last = new ScanOutcome(AdmissionOutcome.Rejected, null, Shorten(code),
                "Ungültiger oder gefälschter Code.", _occupancy ?? new Occupancy(0, null));
        }
        StateHasChanged();
        await Beep(_last.Ok);
    }

    private void OpenExtras() { _showExtras = true; _manualCode = ""; }
    private void CloseExtras() { if (!_busy) _showExtras = false; }

    private void OnManualKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = SubmitManualAsync();
    }

    private async Task SubmitManualAsync()
    {
        var code = (_manualCode ?? "").Trim();
        if (code.Length == 0 || _busy) return;
        _busy = true;
        try
        {
            _last = await Admission.ScanCodeAsync(EventId, code, _mode, Operator, IsTest);
            if (!IsTest) _occupancy = _last.Occupancy;
            if (_last.Ok) _manualCode = "";
            _showExtras = false;
            await Beep(_last.Ok);
        }
        finally { _busy = false; }
    }

    private async Task GrantFreeAsync(FreeEntryType type)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            _last = await Admission.GrantFreeEntryAsync(EventId, type, Operator);
            _occupancy = _last.Occupancy;
            _showExtras = false;
            await Beep(_last.Ok);
        }
        finally { _busy = false; }
    }

    private async Task RevokeFreeAsync(FreeEntryType type)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            _last = await Admission.RevokeFreeEntryAsync(EventId, type, Operator);
            _occupancy = _last.Occupancy;
            _showExtras = false;
            await Beep(_last.Ok);
        }
        finally { _busy = false; }
    }

    private void ToggleMode()
    {
        _mode = _mode == ScanMode.CheckIn ? ScanMode.CheckOut : ScanMode.CheckIn;
        _last = null;
    }

    private async Task Beep(bool ok)
    {
        try { await JS.InvokeVoidAsync("ticketScanner.beep", ok); }
        catch (JSException) { }
    }

    private async Task DismissAsync()
    {
        var dismissed = _last;
        _last = null;
        if (dismissed is { Outcome: AdmissionOutcome.CheckedOut } && _mode == ScanMode.CheckOut)
            _mode = ScanMode.CheckIn;
        if (_cameraPaused)
        {
            _cameraPaused = false;
            try { await JS.InvokeVoidAsync("ticketScanner.resume"); }
            catch (JSException) { }
        }
        StateHasChanged();
    }

    private static string ExtractToken(string code)
    {
        var s = (code ?? "").Trim();
        const string marker = "/ticket/";
        var idx = s.LastIndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (idx >= 0) s = s[(idx + marker.Length)..];
        var cut = s.IndexOfAny(['?', '#']);
        return cut >= 0 ? s[..cut] : s;
    }

    private static string ResultClass(ScanOutcome o) => o.Outcome switch
    {
        AdmissionOutcome.CheckedIn => "in",
        AdmissionOutcome.CheckedOut => "out",
        AdmissionOutcome.Test => "test",
        _ => "fail"
    };

    private static string ResultIcon(ScanOutcome o) => o.Outcome switch
    {
        AdmissionOutcome.CheckedIn => "✓",
        AdmissionOutcome.CheckedOut => "↩",
        AdmissionOutcome.Test => "🧪",
        _ => "✕"
    };

    private static string ResultTitle(ScanOutcome o) => o.Outcome switch
    {
        AdmissionOutcome.CheckedIn => "Eingecheckt",
        AdmissionOutcome.CheckedOut => "Ausgecheckt",
        AdmissionOutcome.Test => "Gültiges Ticket",
        _ => "Abgelehnt"
    };

    private static string TypeLabel(TicketType type) => type switch
    {
        TicketType.EventTicket => "Spielticket",
        TicketType.SeasonSingle => "Flexticket",
        TicketType.SeasonPass => "Saisonkarte",
        TicketType.MemberCard => "Mitgliederkarte",
        TicketType.FreeEntry => "Freier Einlass",
        _ => type.ToString()
    };

    private static string FmtTime(DateTime utc)
    {
        try
        {
            var tz = TimeZoneInfo.FindSystemTimeZoneById("Europe/Zurich");
            var local = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), tz);
            return local.ToString("dd.MM.yyyy HH:mm");
        }
        catch { return utc.ToString("dd.MM.yyyy HH:mm"); }
    }

    private static string Shorten(string? s) =>
        string.IsNullOrEmpty(s) ? "" : (s.Length <= 40 ? s : s[..40] + "…");

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("ticketScanner.stop"); }
        catch (JSException) { }
        catch (JSDisconnectedException) { }
        _ref?.Dispose();
    }
}
