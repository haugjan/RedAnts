@page "/scan"
@{
    Layout = null;
    var helperName = HttpContext.Items["HelperName"] as string ?? "";
    var helperAllEvents = HttpContext.Items["HelperAllEvents"] as bool? ?? true;
    var helperEventIds = HttpContext.Items["HelperEventIds"] as string ?? "";
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
    <title>Tickets scannen</title>
    <base href="/" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="stylesheet" href="/css/ticket-scanner.css" />

    <!-- PWA: installable web app -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#C8102E" />
    <link rel="apple-touch-icon" href="/icons/scanner-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="RA Scanner" />
</head>
<body>
    <component type="typeof(RedAnts.Features.Ticketing.Scanning.TicketScanner)" render-mode="Server"
               param-HelperName="@helperName"
               param-AllEvents="@helperAllEvents"
               param-AllowedEventIds="@helperEventIds" />

    <button id="pwaInstall" class="pwa-install" hidden>App installieren</button>

    <script src="/js/jsQR.js"></script>
    <script src="/js/ticket-scanner.js?v=10"></script>
    <script src="_framework/blazor.server.js"></script>

    <script>
        (function () {
            // Keep the hardware/browser back button inside the scanner. An accidental
            // back must not drop the operator to the login - trap it by re-pushing state
            // so the scanner stays open and the next ticket can be scanned.
            function guard() { try { history.pushState(null, '', location.href); } catch (e) {} }
            guard();
            window.addEventListener('popstate', guard);
        })();
    </script>

    <!-- PWA install prompt + service worker registration -->
    <script>
        (function () {
            var deferredPrompt = null;
            var btn = document.getElementById('pwaInstall');

            window.addEventListener('beforeinstallprompt', function (e) {
                // Chrome/Android: keep the event so we can trigger the prompt from the button.
                e.preventDefault();
                deferredPrompt = e;
                if (btn) btn.hidden = false;
            });

            if (btn) {
                btn.addEventListener('click', async function () {
                    btn.hidden = true;
                    if (!deferredPrompt) return;
                    deferredPrompt.prompt();
                    await deferredPrompt.userChoice;
                    deferredPrompt = null;
                });
            }

            // Hide the button once installed.
            window.addEventListener('appinstalled', function () {
                if (btn) btn.hidden = true;
                deferredPrompt = null;
            });

            if ('serviceWorker' in navigator) {
                window.addEventListener('load', function () {
                    navigator.serviceWorker.register('/scanner-sw.js', { scope: '/scan' })
                        .catch(function (err) { console.warn('SW registration failed:', err); });
                });
            }
        })();
    </script>
</body>
</html>
