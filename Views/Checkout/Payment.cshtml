@model RedAnts.Features.Ticketing.Cart.CheckoutPaymentView
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Kasse – Zahlung";
}

<a href="/kasse" class="tk-back">&larr; Adresse</a>
<h1 class="mb-1">Kasse</h1>
<p class="text-muted mb-4">Schritt 2 von 2 · Zahlungsart</p>

@if (!Model.PayrexxEnabled)
{
    <div class="alert alert-info">
        <strong>Testmodus:</strong> Es wird keine echte Zahlung ausgelöst. Der Kauf ist immer erfolgreich.
    </div>
}

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <form method="post" action="/kasse/zahlung" class="card p-4">
            @Html.AntiForgeryToken()

            <p class="mb-2 text-muted">Lieferung an <strong>@Model.Form.Email</strong></p>

            <div class="border rounded p-3 mb-2">
                <div class="fw-bold">Online-Zahlung über Payrexx</div>
                <div class="text-muted small mb-2">Das Zahlungsmittel wählst du im nächsten Schritt auf der sicheren Zahlungsseite.</div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-light text-dark border px-3 py-2">Visa</span>
                    <span class="badge bg-light text-dark border px-3 py-2">Mastercard</span>
                    <span class="badge bg-light text-dark border px-3 py-2">TWINT</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
            {
                <div class="cf-turnstile mt-3" data-sitekey="@Model.TurnstileSiteKey"></div>
            }

            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="acceptPrivacy" value="true" id="acceptPrivacy" required />
                <label class="form-check-label" for="acceptPrivacy">
                    Ich akzeptiere die <a href="/agb" target="_blank" rel="noopener">AGB</a> und die <a href="/datenschutz" target="_blank" rel="noopener">Datenschutzerklärung</a>. *
                </label>
            </div>

            <p class="text-muted small mt-3 mb-0">Alle Preise verstehen sich ohne MwSt. Der Verein ist nicht mehrwertsteuerpflichtig.</p>

            <div class="d-flex justify-content-between mt-4">
                <a href="/kasse" class="btn btn-outline-secondary">Zurück</a>
                <button type="submit" class="btn btn-danger">Kostenpflichtig bestellen</button>
            </div>
        </form>
    </div>
    <div class="col-lg-5">
        @await Html.PartialAsync("~/Views/Checkout/_Summary.cshtml", Model.Cart)
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
{
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
}
