@using RedAnts.Domain.Ticketing.Sales
@model RedAnts.Features.Ticketing.Cart.CheckoutAddressView
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Kasse";
    var f = Model.Form;
    var isCompany = f.Type == BuyerType.Company;
}

<a href="/cart" class="tk-back">&larr; Warenkorb</a>
<h1 class="mb-1">Kasse</h1>
<p class="text-muted mb-4">Rechnungsadresse &amp; Bezahlung</p>

@if (!Model.PayrexxEnabled)
{
    <div class="alert alert-info">
        <strong>Testmodus:</strong> Es wird keine echte Zahlung ausgelöst. Der Kauf ist immer erfolgreich.
    </div>
}

@if (Model.Error is not null)
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <form method="post" action="/checkout" class="card p-4">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label d-block">Käufer *</label>
                    <div class="btn-group" role="group" aria-label="Käufertyp">
                        <input type="radio" class="btn-check" name="Type" id="typePrivate" value="Private"
                               autocomplete="off" @(isCompany ? "" : "checked") onchange="raToggleBuyer()" />
                        <label class="btn btn-outline-danger" for="typePrivate">Privatperson</label>
                        <input type="radio" class="btn-check" name="Type" id="typeCompany" value="Company"
                               autocomplete="off" @(isCompany ? "checked" : "") onchange="raToggleBuyer()" />
                        <label class="btn btn-outline-danger" for="typeCompany">Firma</label>
                    </div>
                </div>
                <div class="col-12 ra-company-field" style="@(isCompany ? "" : "display:none")">
                    <label class="form-label">Firmenname *</label>
                    <input name="Company" value="@f.Company" class="form-control" />
                </div>
                <div class="col-md-6 ra-person-field" style="@(isCompany ? "display:none" : "")">
                    <label class="form-label">Vorname *</label>
                    <input name="FirstName" value="@f.FirstName" class="form-control" />
                </div>
                <div class="col-md-6 ra-person-field" style="@(isCompany ? "display:none" : "")">
                    <label class="form-label">Nachname *</label>
                    <input name="LastName" value="@f.LastName" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Strasse und Nr. *</label>
                    <input name="Street" value="@f.Street" class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Adresszusatz</label>
                    <input name="AddressLine2" value="@f.AddressLine2" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">PLZ *</label>
                    <input name="PostalCode" value="@f.PostalCode" class="form-control" required />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Ort *</label>
                    <input name="City" value="@f.City" class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Land</label>
                    <input name="Country" value="@f.Country" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">E-Mail *</label>
                    <input type="email" name="Email" value="@f.Email" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Telefon</label>
                    <input name="Phone" value="@f.Phone" class="form-control" />
                </div>
            </div>

            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="AcceptNewsletter" value="true"
                       id="acceptNewsletter" @(f.AcceptNewsletter ? "checked" : "") />
                <label class="form-check-label" for="acceptNewsletter">
                    Ich möchte den Newsletter der Red Ants abonnieren.
                </label>
            </div>

            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="acceptPrivacy" value="true" id="acceptPrivacy" required />
                <label class="form-check-label" for="acceptPrivacy">
                    Ich akzeptiere die <a href="/agb" target="_blank" rel="noopener">AGB</a> und die <a href="/datenschutz" target="_blank" rel="noopener">Datenschutzerklärung</a>. *
                </label>
            </div>

            @if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
            {
                <div class="cf-turnstile mt-4" data-sitekey="@Model.TurnstileSiteKey"></div>
            }

            <p class="text-muted small mt-3 mb-0">Alle Preise verstehen sich ohne MwSt. Der Verein ist nicht mehrwertsteuerpflichtig.</p>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-danger">Kostenpflichtig bestellen</button>
            </div>
        </form>
    </div>
    <div class="col-lg-5">
        @await Html.PartialAsync("~/Views/Checkout/_Summary.cshtml", Model.Cart)
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
{
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
}

<script>
    function raToggleBuyer() {
        var company = document.getElementById('typeCompany').checked;
        document.querySelectorAll('.ra-company-field').forEach(function (el) { el.style.display = company ? '' : 'none'; });
        document.querySelectorAll('.ra-person-field').forEach(function (el) { el.style.display = company ? 'none' : ''; });
    }
    raToggleBuyer();
</script>
