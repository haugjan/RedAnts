@model RedAnts.Features.Ticketing.Cart.CheckoutConfirmationView
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Bestellung bestätigt";
}

<div class="text-center py-3">
    <div style="font-size:3rem; line-height:1; color:#1c7c43;">&#10003;</div>
    <h1 class="mt-2">Vielen Dank!</h1>
    <p class="text-muted">Deine Bestellung war erfolgreich.</p>
</div>

<div class="card p-4">
    <div class="d-flex justify-content-between mb-1">
        <span class="text-muted">Bestellnummer</span><strong>@Model.OrderNumber</strong>
    </div>
    <div class="d-flex justify-content-between mb-1">
        <span class="text-muted">Zahlungsart</span><span>@Model.PaymentLabel</span>
    </div>
    <div class="d-flex justify-content-between">
        <span class="text-muted">Total</span><strong>CHF @Model.Total.ToString("N2")</strong>
    </div>
    <hr />
    <p class="mb-3">Deine Tickets gehen per E-Mail an <strong>@Model.Email</strong>. Du kannst die QR-Codes auch direkt hier am Eingang scannen lassen:</p>

    <h2 class="h5 mb-2">Deine Tickets</h2>
    <div class="row g-3">
        @foreach (var t in Model.Tickets)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="border rounded p-3 text-center h-100">
                    <img src="/ticket/@t.Token/qr.png" alt="Ticket-QR" width="160" height="160" class="img-fluid" style="max-width:160px;" />
                    <div class="fw-bold small mt-2">@t.EventName</div>
                    <div class="text-muted small">@t.CategoryName</div>
                    <a class="btn btn-sm btn-outline-danger mt-2" href="/ticket/@t.Token" target="_blank" rel="noopener">Ticket anzeigen</a>
                </div>
            </div>
        }
    </div>
    @if (Model.AddOnInfoTexts.Count > 0)
    {
        <hr />
        <h2 class="h5 mb-2">Zu deinen Zusatzoptionen</h2>
        @foreach (var info in Model.AddOnInfoTexts)
        {
            <div class="alert alert-info small mb-2" style="white-space:pre-line;">@info</div>
        }
    }
</div>

<div class="mt-4">
    <a href="/" class="btn btn-outline-secondary">Zur Startseite</a>
</div>
