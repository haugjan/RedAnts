@model RedAnts.Features.Ticketing.Cart.CheckoutPayrexxView
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Zahlung";
}

<div class="card p-4 text-center">
    <h1 class="h4 mb-2">Zahlung</h1>
    <p class="text-muted mb-1">Bestellung @Model.OrderNumber</p>
    <p class="mb-3"><strong>Total: CHF @Model.Total.ToString("N2")</strong></p>

    <p id="pay-hint" class="mb-3">Das Bezahlfenster öffnet sich automatisch …</p>

    <button type="button" id="pay-open" class="btn btn-danger">Zahlung öffnen</button>

    <p class="mt-3 mb-0 small">
        <a id="pay-fallback" href="@Model.GatewayLink">Fenster öffnet nicht? Hier direkt bezahlen</a>
    </p>
    <p class="mt-2 mb-0 small">
        <a href="@Model.CancelUrl">Zurück zur Kasse</a>
    </p>
</div>

<script src="https://media.payrexx.com/modal/v1.1/payrexx-modal.min.js"></script>
<script>
(function () {
    var link = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GatewayLink));

    function openModal() {
        if (window.Payrexx && window.Payrexx.Modal) {
            window.Payrexx.Modal.open({ href: link });
            return true;
        }
        return false;
    }

    var openBtn = document.getElementById('pay-open');
    if (openBtn) {
        openBtn.addEventListener('click', function () {
            if (!openModal()) window.location.href = link;
        });
    }

    var tries = 0;
    var timer = setInterval(function () {
        tries++;
        if (openModal()) {
            clearInterval(timer);
        } else if (tries >= 25) {
            clearInterval(timer);
            window.location.href = link;
        }
    }, 200);
}());
</script>
