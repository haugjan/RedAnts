@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using RedAnts.Domain.Ticketing
@using RedAnts.Features.Ticketing.Public
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
    var status = Model.Value<string>("status");
    var providedSecret = Context.Request.Query["secret"].ToString();
    var accessSecret = Model.Key.ToString().Split('-')[0];
    var statusEnum = Enum.TryParse<EventStatus>(status, out var s) ? s : EventStatus.Draft;
    // Open = öffentlich; Intern = nur mit passendem ?secret; Draft/Closed = 404.
    var blocked = !AccessGate.EventOk(statusEnum, accessSecret, providedSecret);
    if (blocked) { Context.Response.StatusCode = 404; }
    ViewBag.PageTitle = Model.Name + " – Red Ants Winterthur";

    var start = Model.Value<DateTime>("start");
    var venue = Model.Value<IPublishedContent>("venue");
    var image = Model.Value<IPublishedContent>("eventImage")?.Url();
    var homeLogo = Model.Value<IPublishedContent>("homeTeamLogo")?.Url();
    var awayLogo = Model.Value<IPublishedContent>("awayTeamLogo")?.Url();
    var text = Model.Value<string>("text");
    // Back to the parent node (the season lists its events).
    var backHref = Model.Parent?.Url() ?? "/";
}

@section Head {
    <style>
        .evt-wrap { max-width: 860px; margin: 0 auto; padding: 2.5rem 2.5rem 5rem; }
        .evt-back {
            font-family: var(--display); font-size: 1rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase;
            text-decoration: none; color: var(--red);
        }
        .evt-back:hover { color: var(--red-dark); }
        .evt-image {
            width: 100%; max-height: 380px; object-fit: cover;
            border-radius: 4px; margin: 1.25rem 0 1.75rem;
        }
        .evt-logos { display: flex; align-items: center; gap: 1.5rem; margin: 1.5rem 0; }
        .evt-logos img { height: 72px; width: auto; }
        .evt-logos .vs {
            font-family: var(--display); font-size: 1.6rem; font-weight: 700;
            text-transform: uppercase; color: var(--ink-light);
        }
        .evt-title {
            font-family: var(--display); font-weight: 700;
            font-size: clamp(2.6rem, 7vw, 4.5rem); line-height: 0.9;
            letter-spacing: 0.01em; text-transform: uppercase; color: var(--ink);
            margin-top: 0.5rem;
        }
        .evt-meta {
            font-size: 0.95rem; letter-spacing: 0.04em;
            color: var(--ink-light); margin-top: 0.6rem;
        }
        .evt-text { margin-top: 1.75rem; line-height: 1.7; font-size: 1.02rem; }
        .evt-text p { margin-bottom: 1rem; }
        .evt-actions { margin-top: 2.5rem; }
        .evt-btn {
            display: inline-flex; align-items: center; gap: 0.5rem;
            font-family: var(--display); font-size: 1.25rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
            padding: 0.6rem 1.8rem; background: var(--red); color: #fff;
            border: 1.5px solid var(--red); transition: background 0.15s, border-color 0.15s;
        }
        .evt-btn:hover { background: var(--red-dark); border-color: var(--red-dark); color: #fff; }
        .evt-alert {
            margin: 2rem 0; padding: 1rem 1.25rem;
            background: #fdeaec; border-left: 4px solid var(--red); color: var(--ink);
        }
    </style>
}

<main class="flexpage-main" style="padding-top:66px;">
    <div class="evt-wrap">
        @if (blocked)
        {
            <div class="evt-alert">Dieser Anlass ist nicht verfügbar.</div>
        }
        else
        {
            <a href="@backHref" class="evt-back">&larr; Übersicht</a>

            @if (!string.IsNullOrEmpty(image))
            {
                <img src="@image" class="evt-image" alt="@Model.Name" />
            }

            @if (!string.IsNullOrEmpty(homeLogo) || !string.IsNullOrEmpty(awayLogo))
            {
                <div class="evt-logos">
                    @if (!string.IsNullOrEmpty(homeLogo)) { <img src="@homeLogo" alt="Heimteam" /> }
                    <span class="vs">vs</span>
                    @if (!string.IsNullOrEmpty(awayLogo)) { <img src="@awayLogo" alt="Auswärtsteam" /> }
                </div>
            }

            <h1 class="evt-title">@Model.Name</h1>
            <p class="evt-meta">
                @start.ToString("dd.MM.yyyy, HH:mm") Uhr
                @if (venue is not null) { <text> · @venue.Name</text> }
            </p>

            @if (!string.IsNullOrEmpty(text))
            {
                <div class="evt-text">@Html.Raw(text)</div>
            }
        }
    </div>
</main>
