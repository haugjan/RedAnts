@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject RedAnts.Features.Ticketing.Ports.IEventPricing Pricing
@using Umbraco.Cms.Core.Models.PublishedContent
@using RedAnts.Domain.Ticketing
@using RedAnts.Features.Ticketing.Public
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
    var status = Model.Value<string>("status");
    var providedSecret = Context.Request.Query["secret"].ToString();
    var accessSecret = Model.Key.ToString().Split('-')[0];
    var statusEnum = Enum.TryParse<EventStatus>(status, out var s) ? s : EventStatus.Draft;
    var blocked = !AccessGate.EventOk(statusEnum, accessSecret, providedSecret);
    if (blocked) { Context.Response.StatusCode = 404; }
    ViewBag.PageTitle = Model.Name + " – Red Ants Winterthur";
    ViewBag.TransparentNav = !blocked;

    var start = Model.Value<DateTime>("start");
    var venue = Model.Value<IPublishedContent>("venue");
    var image = Model.Value<IPublishedContent>("eventImage")?.Url();
    var homeLogo = Model.Value<IPublishedContent>("homeTeamLogo")?.Url();
    var awayLogo = Model.Value<IPublishedContent>("awayTeamLogo")?.Url();
    var text = Model.Value<string>("text");
    var backHref = Model.Parent?.Url() ?? "/";
}

@section Head {
    <style>
        .page-header { position: relative; background-size: cover; background-position: center; min-height: 300px; display: flex; align-items: flex-end; }
        .page-header--plain { background: #101010; }
        .page-header-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(16,16,16,.15) 0%, rgba(16,16,16,.75) 100%); }
        .page-header-inner { position: relative; z-index: 1; width: 100%; max-width: 1100px; margin: 0 auto; padding: 0 24px 40px; }
        .page-header-title { font-family: 'Oswald', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #fff; font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1; margin: 0; }
        .page-header-title::after { content: ""; display: block; width: 64px; height: 5px; background: #C8102E; margin-top: 16px; }
        .page-header-date { color: rgba(255,255,255,.85); margin: 14px 0 0; font-size: .98rem; }
        .evt-wrap { max-width: 860px; margin: 0 auto; padding: 2.5rem 2.5rem 5rem; }
        .evt-back {
            font-family: var(--display); font-size: 1rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase;
            text-decoration: none; color: var(--red);
        }
        .evt-back:hover { color: var(--red-dark); }
        .evt-logos { display: flex; align-items: center; gap: 1.5rem; margin: 1.5rem 0; }
        .evt-logos img { height: 72px; width: auto; }
        .evt-logos .vs {
            font-family: var(--display); font-size: 1.6rem; font-weight: 700;
            text-transform: uppercase; color: var(--ink-light);
        }
        .evt-text { margin-top: 1.75rem; line-height: 1.7; font-size: 1.02rem; }
        .evt-text p { margin-bottom: 1rem; }
        .evt-alert {
            margin: 2rem 0; padding: 1rem 1.25rem;
            background: #fdeaec; border-left: 4px solid var(--red); color: var(--ink);
        }
        .evt-tickets { margin-top: 2.75rem; }
        .evt-tickets h2 {
            font-family: var(--display); text-transform: uppercase;
            font-size: 1.9rem; letter-spacing: 0.03em; margin-bottom: 0.75rem;
        }
        .evt-cat {
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; padding: 0.9rem 0; border-bottom: 1px solid #eee; flex-wrap: wrap;
        }
        .evt-cat__name { font-weight: 700; }
        .evt-cat__price { color: var(--ink-light); margin-left: 0.5rem; font-weight: 400; }
        .evt-cat form { display: flex; align-items: center; gap: 0.5rem; }
        .evt-cat input[type=number] {
            width: 4.5rem; padding: 0.45rem; border: 1px solid #ccc; border-radius: 4px; font: inherit;
        }
        .evt-addbtn {
            font-family: var(--display); text-transform: uppercase; letter-spacing: 0.05em;
            font-weight: 600; font-size: 1rem; background: var(--red); color: #fff; border: none;
            padding: 0.5rem 1.15rem; cursor: pointer; transition: background 0.15s;
        }
        .evt-addbtn:hover { background: var(--red-dark); }
        .evt-empty { color: var(--ink-light); }
        .evt-soldout {
            font-family: var(--display); text-transform: uppercase; letter-spacing: 0.05em;
            font-weight: 600; font-size: 0.95rem; color: var(--ink-light);
        }
        .evt-addbtn:disabled { opacity: 0.75; cursor: default; }
        .evt-addbtn.is-added { background: #1c7c43; }
        .evt-add-status {
            font-size: 0.85rem; font-weight: 600; color: #1c7c43; white-space: nowrap;
        }
        .evt-add-status.is-error { color: var(--red); }
        @@keyframes evtBadgeBump { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 100% { transform: scale(1); } }
        .nav-cart-badge.badge-bump { animation: evtBadgeBump 0.35s ease; }
    </style>
}

@if (blocked)
{
    <main class="flexpage-main" style="padding-top:66px;">
        <div class="evt-wrap"><div class="evt-alert">Dieser Anlass ist nicht verfügbar.</div></div>
    </main>
}
else
{
    <main class="flexpage-main">
        <section class="page-header @(string.IsNullOrEmpty(image) ? "page-header--plain" : "")"
                 style="@(string.IsNullOrEmpty(image) ? "" : $"background-image:url('{image}');")">
            @if (!string.IsNullOrEmpty(image))
            {
                <div class="page-header-overlay"></div>
            }
            <div class="page-header-inner">
                <h1 class="page-header-title">@Model.Name</h1>
                <p class="page-header-date">@(start.ToString("dd.MM.yyyy, HH:mm") + " Uhr" + (venue is not null ? " · " + venue.Name : ""))</p>
            </div>
        </section>

        <div class="evt-wrap">
            <a href="@backHref" class="evt-back">&larr; Übersicht</a>

            @if (!string.IsNullOrEmpty(homeLogo) || !string.IsNullOrEmpty(awayLogo))
            {
                <div class="evt-logos">
                    @if (!string.IsNullOrEmpty(homeLogo)) { <img src="@homeLogo" alt="Heimteam" /> }
                    <span class="vs">vs</span>
                    @if (!string.IsNullOrEmpty(awayLogo)) { <img src="@awayLogo" alt="Auswärtsteam" /> }
                </div>
            }

            @if (!string.IsNullOrEmpty(text))
            {
                <div class="evt-text">@Html.Raw(text)</div>
            }

            <div class="evt-tickets">
                <h2>Tickets</h2>
                @{
                    var cats = await Pricing.GetAvailableAsync(Model.Id);
                    var returnUrl = Context.Request.Path + Context.Request.QueryString;
                }
                @if (cats.Count == 0)
                {
                    <p class="evt-empty">Für diesen Anlass sind aktuell keine Tickets verfügbar.</p>
                }
                else
                {
                    foreach (var cat in cats)
                    {
                        <div class="evt-cat">
                            <div>
                                <span class="evt-cat__name">@cat.Name</span>
                                <span class="evt-cat__price">CHF @cat.Price.ToString("N2")</span>
                            </div>
                            @if (cat.Available)
                            {
                                <form method="post" action="/warenkorb/add" class="evt-add-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@Model.Id" />
                                    <input type="hidden" name="category" value="@((int)cat.Category)" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <input type="number" name="quantity" value="1" min="1" aria-label="Menge" />
                                    <button type="submit" class="evt-addbtn">In den Warenkorb</button>
                                    <span class="evt-add-status" role="status" aria-live="polite"></span>
                                </form>
                            }
                            else
                            {
                                <span class="evt-soldout">Ausverkauft</span>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </main>
}

@section Scripts {
<script>
(function () {
    function bumpBadge(total) {
        var link = document.querySelector('.nav-cart');
        if (!link) return;
        var badge = link.querySelector('.nav-cart-badge');
        if (total > 0) {
            if (!badge) {
                badge = document.createElement('span');
                badge.className = 'nav-cart-badge';
                link.appendChild(badge);
            }
            badge.textContent = total;
            badge.classList.remove('badge-bump');
            void badge.offsetWidth;
            badge.classList.add('badge-bump');
        } else if (badge) {
            badge.remove();
        }
    }

    document.querySelectorAll('.evt-add-form').forEach(function (form) {
        var btn = form.querySelector('.evt-addbtn');
        var status = form.querySelector('.evt-add-status');
        var label = btn ? btn.textContent : '';
        var revert;

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            clearTimeout(revert);
            btn.disabled = true;
            if (status) { status.textContent = ''; status.classList.remove('is-error'); }

            fetch('/warenkorb/add', {
                method: 'POST',
                headers: { 'X-Requested-With': 'fetch' },
                body: new FormData(form)
            })
            .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
            .then(function (data) {
                if (data.ok) {
                    btn.textContent = '✓ Hinzugefügt';
                    btn.classList.add('is-added');
                    if (status) status.textContent = 'Zum Warenkorb hinzugefügt';
                    bumpBadge(data.totalQuantity);
                } else {
                    if (status) { status.textContent = 'Nicht mehr verfügbar'; status.classList.add('is-error'); }
                }
            })
            .catch(function () {
                if (status) { status.textContent = 'Fehler, bitte erneut versuchen'; status.classList.add('is-error'); }
            })
            .finally(function () {
                revert = setTimeout(function () {
                    btn.disabled = false;
                    btn.textContent = label;
                    btn.classList.remove('is-added');
                    if (status) { status.textContent = ''; status.classList.remove('is-error'); }
                }, 1600);
            });
        });
    });
}());
</script>
}
