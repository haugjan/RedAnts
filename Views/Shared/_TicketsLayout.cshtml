@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Red Ants Ticketing")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f6f7f9; }
        .ra-header { background: #C8102E; color: #fff; }
        .ra-header a { color: #fff; text-decoration: none; font-weight: 800; letter-spacing: .5px; text-transform: uppercase; }
        .card-event:hover { box-shadow: 0 .25rem .75rem rgba(0,0,0,.1); }
    </style>
</head>
<body>
    <header class="ra-header py-3 mb-4">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/tickets">Red Ants Ticketing</a>
        </div>
    </header>
    <main class="container pb-5">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
