@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject RedAnts.Features.Ticketing.Cart.ICartService Cart
@using System.Linq
@using Umbraco.Cms.Core.Models.PublishedContent
@{
    var home = Umbraco.ContentAtRoot()?.FirstOrDefault(c => c.ContentType.Alias == "flexPage");
    var cartCount = Cart.Get().TotalQuantity;
    var navPages = home?.Children()?
        .Where(c => c.ContentType.Alias == "flexPage" && c.IsPublished())
        .ToList() ?? new List<IPublishedContent>();

    var logoUrl = "https://redants.ch/uploads/232/admin/website_header/RA_Logo_transparent_300ppi.png";

    var transparentNav = ViewBag.TransparentNav as bool? ?? false;
    var pageTitle = ViewBag.PageTitle as string ?? "Red Ants Winterthur";
    var navBg = transparentNav ? "rgba(255,255,255,0)" : "rgba(255,255,255,0.97)";
    var navBorder = transparentNav ? "transparent" : "#f0f0f0";
}
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@pageTitle</title>
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css?v=2" />
  <style>
    .nav-cart { display: inline-flex; align-items: center; gap: 0.4rem; }
    .nav-cart-badge {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 1.25rem; height: 1.25rem; padding: 0 0.35rem;
      border-radius: 999px; background: var(--red); color: #fff;
      font-family: Verdana, sans-serif; font-size: 0.72rem; font-weight: 700; line-height: 1;
    }
  </style>
  @RenderSection("Head", required: false)
</head>
<body>
<nav class="site-nav" id="siteNav"
     style="background:@navBg; border-bottom-color:@navBorder; @(transparentNav ? "" : "box-shadow:0 1px 12px rgba(0,0,0,0.06);")">
  <div class="site-nav-inner">
    <a href="@(home?.Url() ?? "/")" class="site-nav-logo" aria-label="Startseite">
      <img src="@logoUrl" alt="Red Ants Winterthur"
           onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
      <span class="site-nav-logo-fallback" style="display:none;">Red Ants</span>
    </a>
    <ul class="nav-links">
      @foreach (var item in navPages)
      {
        var isActive = Context.Request.Path.Value?.TrimEnd('/').Equals(item.Url()?.TrimEnd('/'), StringComparison.OrdinalIgnoreCase) ?? false;
        <li><a href="@item.Url()" class="nav-link @(isActive ? "is-active" : "")"
               style="@(transparentNav ? "color:rgba(255,255,255,0.85);" : "")">@item.Name</a></li>
      }
      <li>
        <a href="/warenkorb" class="nav-link nav-cart" aria-label="Warenkorb"
           style="@(transparentNav ? "color:rgba(255,255,255,0.85);" : "")">
          <span>Warenkorb</span>@if (cartCount > 0) { <span class="nav-cart-badge">@cartCount</span> }
        </a>
      </li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Navigation">
      <svg width="22" height="18" fill="none" stroke="@(transparentNav ? "white" : "currentColor")" stroke-width="2" stroke-linecap="square" id="navToggleIcon">
        <line x1="0" y1="2" x2="22" y2="2"/><line x1="0" y1="9" x2="22" y2="9"/><line x1="0" y1="16" x2="22" y2="16"/>
      </svg>
    </button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <ul>
      @foreach (var item in navPages)
      {
        <li><a href="@item.Url()">@item.Name</a></li>
      }
      <li><a href="/warenkorb"><span>Warenkorb</span>@if (cartCount > 0) { <text> (@cartCount)</text> }</a></li>
    </ul>
  </div>
</nav>

@RenderBody()

@RenderSection("Scripts", required: false)

<script>
(function () {
  var nav = document.getElementById('siteNav');
  var transparent = @(transparentNav ? "true" : "false");
  if (transparent) {
    var onScroll = function () {
      var past = window.scrollY > 60;
      nav.style.background = past ? 'rgba(255,255,255,0.97)' : 'rgba(255,255,255,0)';
      nav.style.borderBottomColor = past ? '#f0f0f0' : 'transparent';
      nav.style.boxShadow = past ? '0 1px 12px rgba(0,0,0,0.06)' : 'none';
      nav.querySelectorAll('.nav-link').forEach(function (a) {
        a.style.color = past ? '' : 'rgba(255,255,255,0.85)';
      });
      var icon = document.getElementById('navToggleIcon');
      if (icon) icon.setAttribute('stroke', past ? 'currentColor' : 'white');
    };
    window.addEventListener('scroll', onScroll);
    onScroll();
  }
  var toggle = document.getElementById('navToggle');
  if (toggle) {
    toggle.addEventListener('click', function () {
      document.getElementById('mobileMenu').classList.toggle('is-open');
    });
  }
}());
</script>
</body>
</html>
