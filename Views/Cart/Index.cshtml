@model RedAnts.Features.Ticketing.Cart.Cart
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Warenkorb";
}

<h1 class="mb-4">Warenkorb</h1>

@if (Model.IsEmpty)
{
    <div class="alert alert-secondary">Dein Warenkorb ist leer.</div>
    <a href="/" class="btn btn-outline-secondary">Weiter einkaufen</a>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Anlass</th>
                    <th>Kategorie</th>
                    <th class="text-end">Preis</th>
                    <th style="width:9rem;">Menge</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.EventName</td>
                        <td>@item.CategoryName</td>
                        <td class="text-end">CHF @item.UnitPrice.ToString("N2")</td>
                        <td>
                            <form method="post" action="/warenkorb/update" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="key" value="@item.Key" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0"
                                       class="form-control form-control-sm" style="width:5rem;"
                                       onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td class="text-end">CHF @item.LineTotal.ToString("N2")</td>
                        <td class="text-end">
                            <form method="post" action="/warenkorb/remove">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="key" value="@item.Key" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Entfernen">&times;</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="4" class="text-end">Gesamt</th>
                    <th class="text-end">CHF @Model.TotalAmount.ToString("N2")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mt-3">
        <a href="/" class="btn btn-outline-secondary">Weiter einkaufen</a>
        <div class="d-flex gap-2">
            <form method="post" action="/warenkorb/clear">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Warenkorb leeren</button>
            </form>
            <a href="/kasse" class="btn btn-danger">Zur Kasse</a>
        </div>
    </div>
}
