@model RedAnts.Features.Ticketing.Cart.Cart
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = "Warenkorb";
}

<style>
    @@media (max-width: 575px) {
        .cart-table thead, .cart-table tfoot { display: none; }
        .cart-table, .cart-table tbody, .cart-table tbody tr, .cart-table tbody td { display: block; width: 100%; }
        .cart-table tbody tr {
            position: relative; background: #fff; border: 1px solid #e9e9eb; border-radius: 10px;
            padding: .65rem .85rem; margin-bottom: .8rem;
        }
        .cart-table tbody td { border: 0; padding: .18rem 0; white-space: normal; }
        .cart-table td.cart-name { font-weight: 700; padding-right: 2.4rem; font-size: 1.02rem; }
        .cart-table td[data-label] { display: flex; justify-content: space-between; align-items: center; gap: .8rem; }
        .cart-table td[data-label]::before { content: attr(data-label); color: #6b6b6b; font-size: .85rem; }
        .cart-table td.cart-remove { position: absolute; top: .45rem; right: .55rem; width: auto; padding: 0; }
        .cart-mobile-total {
            display: flex; justify-content: space-between; align-items: center;
            font-weight: 700; font-size: 1.05rem; padding: .4rem .2rem .2rem;
            border-top: 2px solid #e9e9eb;
        }
    }
    @@media (min-width: 576px) {
        .cart-mobile-total { display: none; }
    }
    .cart-addons { list-style: none; margin: .25rem 0 0; padding: 0; font-weight: 400; font-size: .82rem; color: #666; }
    .cart-addon-once { display: inline-block; margin-left: .4rem; padding: .05rem .4rem; border-radius: 999px; background: #eee; color: #777; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; vertical-align: middle; }
</style>

@if (TempData["CartError"] is string cartError)
{
    <div class="alert alert-danger">@cartError</div>
}

@if (Model.IsEmpty)
{
    <div class="alert alert-secondary">Dein Warenkorb ist leer.</div>
    <a href="/" class="btn btn-outline-secondary">Weiter einkaufen</a>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle cart-table">
            <thead>
                <tr>
                    <th>Anlass</th>
                    <th>Kategorie</th>
                    <th class="text-end">Preis</th>
                    <th style="width:9rem;">Menge</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="cart-name">
                            @item.EventName
                            @if (item.AddOns.Count > 0)
                            {
                                <ul class="cart-addons">
                                    @foreach (var a in item.AddOns)
                                    {
                                        <li>+ @a.Label (CHF @MoneyFormat.Chf(a.Price))</li>
                                    }
                                </ul>
                            }
                        </td>
                        <td data-label="Kategorie">@item.CategoryName</td>
                        <td data-label="Preis" class="text-end">CHF @MoneyFormat.Chf(item.UnitPrice)</td>
                        <td data-label="Menge">
                            <form method="post" action="/cart/update" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="key" value="@item.Key" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0"
                                       class="form-control form-control-sm" style="width:5rem;"
                                       onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td data-label="Total" class="text-end">CHF @MoneyFormat.Chf(item.LineTotal)</td>
                        <td class="cart-remove text-end">
                            <form method="post" action="/cart/remove">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="key" value="@item.Key" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Entfernen">&times;</button>
                            </form>
                        </td>
                    </tr>
                }
                @foreach (var a in Model.OrderAddOns)
                {
                    <tr>
                        <td class="cart-name">@a.Label <span class="cart-addon-once">einmalig</span></td>
                        <td data-label="Kategorie">Zusatzoption</td>
                        <td data-label="Preis" class="text-end">CHF @MoneyFormat.Chf(a.Price)</td>
                        <td data-label="Menge">1</td>
                        <td data-label="Total" class="text-end">CHF @MoneyFormat.Chf(a.Price)</td>
                        <td class="cart-remove text-end">
                            <form method="post" action="/cart/remove-addon">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="addOnId" value="@a.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Entfernen">&times;</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="4" class="text-end">Gesamt</th>
                    <th class="text-end">CHF @MoneyFormat.Chf(Model.TotalAmount)</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="cart-mobile-total"><span>Gesamt</span><span>CHF @MoneyFormat.Chf(Model.TotalAmount)</span></div>

    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mt-3">
        <a href="/" class="btn btn-outline-secondary">Weiter einkaufen</a>
        <div class="d-flex gap-2">
            <form method="post" action="/cart/clear">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Warenkorb leeren</button>
            </form>
            <a href="/checkout" class="btn btn-danger">Zur Kasse</a>
        </div>
    </div>
}
