@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using RedAnts.Features.Ticketing.Ports
@using RedAnts.Domain.Ticketing.Sales
@inject ISeasonPassPricing PassPricing
@inject RedAnts.Features.Ticketing.Ports.ISeasons Seasons
@inject ISeasonAddOns SeasonAddOns
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";

    var headerText = Model.Value<string>("headerText");
    var headerImage = Model.Value<IPublishedContent>("headerImage")?.Url();
    var bodyHtml = Model.Value<string>("bodyText");
    var title = string.IsNullOrWhiteSpace(headerText) ? "Saisonkarten" : headerText;
    ViewBag.PageTitle = title + " – Red Ants Winterthur";
    ViewBag.TransparentNav = true;

    var passOffers = new List<(int SeasonId, string SeasonName, List<AvailableTicketCategory> Categories, List<SeasonAddOn> AddOns)>();
    foreach (var season in await Seasons.GetPublicOpenAsync())
    {
        var cats = (await PassPricing.GetAvailableAsync(season.Id)).Where(c => c.Available).ToList();
        if (cats.Count == 0) continue;
        var addOns = (await SeasonAddOns.GetBySeasonAsync(season.Id)).Where(a => a.Active).ToList();
        passOffers.Add((season.Id, season.Name, cats, addOns));
    }
}

<main class="flexpage-main">
    <section class="page-header @(string.IsNullOrEmpty(headerImage) ? "page-header--plain" : "")"
             style="@(string.IsNullOrEmpty(headerImage) ? "" : $"background-image:url('{headerImage}');")">
        @if (!string.IsNullOrEmpty(headerImage))
        {
            <div class="page-header-overlay"></div>
        }
        <div class="page-header-inner">
            <h1 class="page-header-title">@title</h1>
        </div>
    </section>

    <section class="promo-body">
        <div class="promo-inner">
            <a class="promo-back" href="/ticketing/">← Zurück zur Hauptübersicht</a>

            @if (!string.IsNullOrWhiteSpace(bodyHtml))
            {
                <div class="promo-text">@Html.Raw(bodyHtml)</div>
            }

            @if (passOffers.Count == 0)
            {
                <p class="promo-empty">Zurzeit sind keine Saisonkarten im Verkauf.</p>
            }
            else
            {
                <ul class="pass-offer-list">
                    @foreach (var (seasonId, seasonName, cats, addOns) in passOffers)
                    {
                        <li class="pass-offer">
                            <div class="pass-offer-head">
                                <span class="pass-offer-season">@seasonName</span>
                            </div>
                            <ul class="pass-offer-cats">
                                @foreach (var cat in cats)
                                {
                                    <li class="pass-offer-cat">
                                        <div class="pass-offer-cat-top">
                                            <span class="pass-offer-cat-name">@cat.Name</span>
                                            <span class="pass-offer-price">CHF @MoneyFormat.Amount(cat.Price)</span>
                                        </div>
                                        <form method="post" action="/warenkorb/add-saisonkarte" class="pass-add-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="seasonId" value="@seasonId" />
                                            <input type="hidden" name="category" value="@((int)cat.Category)" />
                                            <input type="hidden" name="returnUrl" value="/saisons/" />
                                            @if (addOns.Count > 0)
                                            {
                                                <div class="pass-addons">
                                                    <span class="pass-addons-title">Zusatzoptionen</span>
                                                    @foreach (var a in addOns)
                                                    {
                                                        <label class="pass-addon">
                                                            <input type="checkbox" name="addOns" value="@a.Id" />
                                                            <span class="pass-addon-label">@a.Label@(a.Scope == AddOnScope.PerOrder ? " (einmalig pro Bestellung)" : "")</span>
                                                            <span class="pass-addon-price">+CHF @MoneyFormat.Amount(a.Price)</span>
                                                        </label>
                                                    }
                                                </div>
                                            }
                                            <button type="submit" class="pass-add-btn">In den Warenkorb</button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </li>
                    }
                </ul>
            }
        </div>
    </section>
</main>

<style>
    .page-header { position: relative; background-size: cover; background-position: center; min-height: 300px; display: flex; align-items: flex-end; }
    .page-header--plain { background: #101010; }
    .page-header-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(16,16,16,.15) 0%, rgba(16,16,16,.75) 100%); }
    .page-header-inner { position: relative; z-index: 1; width: 100%; max-width: 1100px; margin: 0 auto; padding: 0 24px 40px; }
    .page-header-title { font-family: 'Oswald', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #fff; font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1; margin: 0; }
    .page-header-title::after { content: ""; display: block; width: 64px; height: 5px; background: #C8102E; margin-top: 16px; }

    .promo-body { padding: 40px 20px 64px; background: #f6f7f9; }
    .promo-inner { max-width: 900px; margin: 0 auto; }
    .promo-back { display: inline-block; margin-bottom: 20px; color: #666; text-decoration: none; font-weight: 700; font-size: .9rem; }
    .promo-back:hover { color: #C8102E; }
    .promo-text { background: #fff; border: 1px solid #e6e6e6; border-radius: 10px; padding: 24px 28px; margin-bottom: 24px; line-height: 1.7; }
    .promo-text h2, .promo-text h3 { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
    .promo-empty { color: #666; }

    .pass-offer-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
    .pass-offer { background: #fff; border: 1px solid #e6e6e6; border-radius: 10px; padding: 14px 18px; }
    .pass-offer-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 6px; }
    .pass-offer-season { font-family: 'Oswald', sans-serif; font-size: 1.3rem; text-transform: uppercase; letter-spacing: .04em; color: #101010; }
    .pass-offer-cats { list-style: none; margin: 0; padding: 0; }
    .pass-offer-cats li { padding: 10px 0; border-top: 1px solid #f3f3f3; font-size: .92rem; }
    .pass-offer-cat-top { display: flex; align-items: center; gap: 1rem; }
    .pass-offer-cat-name { flex: 1 1 auto; }
    .pass-offer-price { font-weight: 700; white-space: nowrap; }
    .pass-add-form { margin: 8px 0 0; display: flex; flex-direction: column; align-items: flex-start; gap: 8px; }
    .pass-addons { display: flex; flex-direction: column; gap: 5px; width: 100%; max-width: 420px; background: #f6f7f9; border: 1px solid #ececec; border-radius: 6px; padding: 8px 10px; }
    .pass-addons-title { font-size: .7rem; text-transform: uppercase; letter-spacing: .04em; color: #888; }
    .pass-addon { display: flex; align-items: center; gap: .5rem; cursor: pointer; }
    .pass-addon-label { flex: 1 1 auto; }
    .pass-addon-price { font-weight: 600; color: #444; white-space: nowrap; }
    .pass-add-btn { font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: .05em; font-weight: 600; font-size: .82rem; background: #C8102E; color: #fff; border: none; padding: .4rem .9rem; cursor: pointer; border-radius: 4px; text-align: center; white-space: nowrap; }
    .pass-add-btn:hover { background: #a50d25; }
    .pass-add-btn:disabled { opacity: .75; cursor: default; }
    .pass-add-btn.is-added { background: #1c7c43; }
    .pass-add-btn.is-error { background: #6c757d; }
    @@keyframes passBadgeBump { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 100% { transform: scale(1); } }
    .nav-cart-badge.badge-bump { animation: passBadgeBump .35s ease; }
</style>

@section Scripts {
<script>
(function () {
    function bumpBadge(total) {
        document.querySelectorAll('.nav-cart, .nav-cart-mobile').forEach(function (link) {
            var badge = link.querySelector('.nav-cart-badge');
            if (total > 0) {
                if (!badge) {
                    badge = document.createElement('span');
                    badge.className = 'nav-cart-badge';
                    link.appendChild(badge);
                }
                badge.textContent = total;
                badge.classList.remove('badge-bump');
                void badge.offsetWidth;
                badge.classList.add('badge-bump');
            } else if (badge) {
                badge.remove();
            }
        });
    }

    document.querySelectorAll('.pass-add-form').forEach(function (form) {
        var btn = form.querySelector('.pass-add-btn');
        var label = btn ? btn.textContent : '';
        var revert;

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            clearTimeout(revert);
            if (!btn.style.minWidth) btn.style.minWidth = btn.offsetWidth + 'px';
            btn.disabled = true;

            fetch('/warenkorb/add-saisonkarte', {
                method: 'POST',
                headers: { 'X-Requested-With': 'fetch' },
                body: new FormData(form)
            })
            .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
            .then(function (data) {
                if (data.ok) {
                    btn.textContent = '✓ Hinzugefügt';
                    btn.classList.add('is-added');
                    bumpBadge(data.totalQuantity);
                } else {
                    btn.textContent = 'Nicht verfügbar';
                    btn.classList.add('is-error');
                }
            })
            .catch(function () {
                btn.textContent = 'Nicht möglich';
                btn.classList.add('is-error');
            })
            .finally(function () {
                revert = setTimeout(function () {
                    btn.disabled = false;
                    btn.textContent = label;
                    btn.classList.remove('is-added');
                    btn.classList.remove('is-error');
                }, 1600);
            });
        });
    });
}());
</script>
}