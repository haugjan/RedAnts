@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using RedAnts.Features.Ticketing.Ports
@inject ISeasonPassPricing PassPricing
@inject RedAnts.Features.Ticketing.Ports.ISeasons Seasons
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";

    var headerText = Model.Value<string>("headerText");
    var headerImage = Model.Value<IPublishedContent>("headerImage")?.Url();
    var bodyHtml = Model.Value<string>("bodyText");
    var title = string.IsNullOrWhiteSpace(headerText) ? "Saisonkarten" : headerText;
    ViewBag.PageTitle = title + " – Red Ants Winterthur";
    ViewBag.TransparentNav = true;

    var passOffers = new List<(int SeasonId, string SeasonName, List<AvailableTicketCategory> Categories)>();
    foreach (var season in await Seasons.GetPublicOpenAsync())
    {
        var cats = (await PassPricing.GetAvailableAsync(season.Id)).Where(c => c.Available).ToList();
        if (cats.Count == 0) continue;
        passOffers.Add((season.Id, season.Name, cats));
    }
}

<main class="flexpage-main">
    <section class="page-header @(string.IsNullOrEmpty(headerImage) ? "page-header--plain" : "")"
             style="@(string.IsNullOrEmpty(headerImage) ? "" : $"background-image:url('{headerImage}');")">
        @if (!string.IsNullOrEmpty(headerImage))
        {
            <div class="page-header-overlay"></div>
        }
        <div class="page-header-inner">
            <h1 class="page-header-title">@title</h1>
        </div>
    </section>

    <section class="promo-body">
        <div class="promo-inner">
            <a class="promo-back" href="/ticketing/">← Zurück zur Hauptübersicht</a>

            @if (!string.IsNullOrWhiteSpace(bodyHtml))
            {
                <div class="promo-text">@Html.Raw(bodyHtml)</div>
            }

            @if (passOffers.Count == 0)
            {
                <p class="promo-empty">Zurzeit sind keine Saisonkarten im Verkauf.</p>
            }
            else
            {
                <div class="pass-panel">
                    <h2 class="pass-title">Saisonkarten</h2>
                    @foreach (var (seasonId, seasonName, cats) in passOffers)
                    {
                        <div class="pass-offer">
                            @if (passOffers.Count > 1)
                            {
                                <div class="pass-offer-head">
                                    <span class="pass-offer-season">@seasonName</span>
                                </div>
                            }
                            <ul class="pass-offer-cats">
                                @foreach (var cat in cats)
                                {
                                    <li class="pass-offer-cat">
                                        @if (!string.IsNullOrWhiteSpace(cat.ActionText))
                                        {
                                            <span class="pass-offer-action">@cat.ActionText</span>
                                        }
                                        <div class="pass-offer-cat-row">
                                            <div class="pass-offer-cat-info">
                                                <span class="pass-offer-cat-name">@(string.IsNullOrWhiteSpace(cat.ShortName) ? cat.Name : cat.ShortName)</span>
                                                <span class="pass-offer-price">
                                                    @if (cat.OriginalPrice is { } orig)
                                                    {
                                                        <span class="pass-offer-price-orig">CHF @MoneyFormat.Amount(orig)</span>
                                                    }
                                                    <span class="pass-offer-price-now @(cat.OriginalPrice is not null ? "is-promo" : "")">CHF @MoneyFormat.Amount(cat.Price)</span>
                                                </span>
                                                @if (cat.Remaining is { } rem)
                                                {
                                                    <span class="pass-offer-stock @(rem <= 10 ? "is-low" : "")">@(rem <= 10 ? $"Nur noch {rem} verfügbar" : $"Noch {rem} verfügbar")</span>
                                                }
                                                @if (cat.AvailableUntil is { } until)
                                                {
                                                    <span class="pass-offer-note">bis @until.ToString("dd.MM.yyyy")</span>
                                                }
                                            </div>
                                            <form method="post" action="/cart/add-season-pass" class="pass-add-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="seasonId" value="@seasonId" />
                                                <input type="hidden" name="tierId" value="@cat.TierId" />
                                                <input type="hidden" name="returnUrl" value="/seasons/" />
                                                <input type="number" name="quantity" value="1" min="1" aria-label="Menge" />
                                                <button type="submit" class="pass-add-btn">In den Warenkorb</button>
                                            </form>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</main>

<style>
    .page-header { position: relative; background-size: cover; background-position: center; min-height: 300px; display: flex; align-items: flex-end; }
    .page-header--plain { background: #101010; }
    .page-header-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(16,16,16,.15) 0%, rgba(16,16,16,.75) 100%); }
    .page-header-inner { position: relative; z-index: 1; width: 100%; max-width: 1100px; margin: 0 auto; padding: 0 24px 40px; }
    .page-header-title { font-family: 'Oswald', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #fff; font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1; margin: 0; }
    .page-header-title::after { content: ""; display: block; width: 64px; height: 5px; background: #C8102E; margin-top: 16px; }

    .promo-body { padding: 40px 20px 64px; background: #f6f7f9; }
    .promo-inner { max-width: 900px; margin: 0 auto; }
    .promo-back { display: inline-block; margin-bottom: 20px; font-family: var(--display); font-size: 1rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; color: var(--red); }
    .promo-back:hover { color: var(--red-dark); }
    .promo-text { background: #fff; border: 1px solid #e6e6e6; border-radius: 10px; padding: 24px 28px; margin-bottom: 24px; line-height: 1.7; }
    .promo-text h2, .promo-text h3 { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
    .promo-empty { color: #666; }

    .pass-panel { background: #fff; border: 1px solid #e6e6e6; border-radius: 10px; padding: 22px 26px 10px; }
    .pass-title { font-family: 'Oswald', sans-serif; text-transform: uppercase; font-size: 1.9rem; letter-spacing: .03em; margin: 0 0 .4rem; color: #101010; }
    .pass-offer-head { margin: 16px 0 2px; }
    .pass-offer-season { font-family: 'Oswald', sans-serif; font-size: 1.15rem; text-transform: uppercase; letter-spacing: .04em; color: #555; }
    .pass-offer-cats { list-style: none; margin: 0; padding: 0; }
    .pass-offer-cat {
        display: flex; flex-direction: column; gap: .35rem;
        padding: 12px 0; border-bottom: 1px solid #eee; font-size: .92rem;
    }
    .pass-offer-cat-row {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap;
    }
    .pass-offer-cat-info { display: flex; align-items: center; flex-wrap: wrap; gap: .35rem .9rem; flex: 1 1 auto; min-width: 0; }
    .pass-offer-cat-name { font-weight: 700; }
    .pass-offer-action {
        align-self: flex-start;
        font-family: var(--display, inherit); text-transform: uppercase; letter-spacing: .03em;
        font-size: .72rem; font-weight: 700; color: #fff; background: #C8102E;
        padding: .1rem .5rem; border-radius: 999px;
    }
    .pass-offer-price { white-space: nowrap; }
    .pass-offer-price-orig { color: #999; text-decoration: line-through; margin-right: .4rem; }
    .pass-offer-price-now { color: var(--ink-light); }
    .pass-offer-price-now.is-promo { color: #C8102E; font-weight: 700; }
    .pass-offer-note { font-size: .8rem; color: #555; }
    .pass-offer-stock {
        display: inline-block; font-family: var(--display, inherit);
        font-size: .8rem; font-weight: 600; color: #3f8f5c;
    }
    .pass-offer-stock.is-low {
        padding: .15rem .6rem; border-radius: 999px;
        background: #fdecea; color: #c0392b; font-weight: 700;
    }
    .pass-add-form { margin: 0; display: flex; align-items: center; gap: .5rem; flex: 0 0 auto; }
    .pass-add-form input[type=number] {
        width: 4.5rem; padding: .45rem; border: 1px solid #ccc; border-radius: 4px; font: inherit;
    }
    .pass-add-btn { font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: .05em; font-weight: 600; font-size: 1rem; background: #C8102E; color: #fff; border: none; padding: .5rem 1.15rem; cursor: pointer; transition: background .15s; text-align: center; white-space: nowrap; }
    .pass-add-btn:hover { background: #a50d25; }
    .pass-add-btn:disabled { opacity: .75; cursor: default; }
    .pass-add-btn.is-added { background: #1c7c43; }
    .pass-add-btn.is-error { background: #6c757d; }
    @@keyframes passBadgeBump { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 100% { transform: scale(1); } }
    .nav-cart-badge.badge-bump { animation: passBadgeBump .35s ease; }
</style>

@section Scripts {
<script>
(function () {
    function bumpBadge(total) {
        document.querySelectorAll('.nav-cart, .nav-cart-mobile').forEach(function (link) {
            var badge = link.querySelector('.nav-cart-badge');
            if (total > 0) {
                if (!badge) {
                    badge = document.createElement('span');
                    badge.className = 'nav-cart-badge';
                    link.appendChild(badge);
                }
                badge.textContent = total;
                badge.classList.remove('badge-bump');
                void badge.offsetWidth;
                badge.classList.add('badge-bump');
            } else if (badge) {
                badge.remove();
            }
        });
    }

    document.querySelectorAll('.pass-add-form').forEach(function (form) {
        var btn = form.querySelector('.pass-add-btn');
        var label = btn ? btn.textContent : '';
        var revert;

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            clearTimeout(revert);
            if (!btn.style.minWidth) btn.style.minWidth = btn.offsetWidth + 'px';
            btn.disabled = true;

            fetch('/cart/add-season-pass', {
                method: 'POST',
                headers: { 'X-Requested-With': 'fetch' },
                body: new FormData(form)
            })
            .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
            .then(function (data) {
                if (data.ok) {
                    btn.textContent = '✓ Hinzugefügt';
                    btn.classList.add('is-added');
                    bumpBadge(data.totalQuantity);
                } else {
                    btn.textContent = 'Nicht verfügbar';
                    btn.classList.add('is-error');
                }
            })
            .catch(function () {
                btn.textContent = 'Nicht möglich';
                btn.classList.add('is-error');
            })
            .finally(function () {
                revert = setTimeout(function () {
                    btn.disabled = false;
                    btn.textContent = label;
                    btn.classList.remove('is-added');
                    btn.classList.remove('is-error');
                }, 1600);
            });
        });
    });
}());
</script>
}