@model RedAnts.Features.Ticketing.Tickets.ScannerTestViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Scanner-Test – Red Ants Winterthur</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto+Mono:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/ticket-card.css?v=6" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; background: #f4f4f5; color: #14171A; font-family: Verdana, Geneva, Tahoma, sans-serif; text-align: center; padding: 2.4rem 1.2rem 3rem; -webkit-font-smoothing: antialiased; }
        h1 { font-family: 'Oswald', Impact, sans-serif; text-transform: uppercase; font-size: 1.6rem; margin: 0 0 .5rem; }
        .accent { height: 5px; width: 64px; background: #C8102E; margin: 0 auto 1.2rem; }
        .intro { max-width: 480px; margin: 0 auto 2.2rem; color: #555; line-height: 1.6; }
        .grid { display: flex; flex-wrap: wrap; gap: 1.8rem; justify-content: center; align-items: flex-start; }
        .st-card { width: 100%; max-width: 340px; text-align: left; }
        .st-card .rtk-card { --rtk-notch: #f4f4f5; }
    </style>
</head>
<body>
    <h1>Scanner-Test</h1>
    <div class="accent"></div>
    <p class="intro">Beispiel-Tickets in echter Darstellung. Scanne einen QR-Code mit dem Ticket-Scanner: für jede Ticketversion erscheint die grüne Bestätigung mit dem passenden Typ. Die Angaben (z.B. „Max Muster") sind Beispiele, es wird kein echtes Ticket eingecheckt.</p>
    <div class="grid">
        @foreach (var card in Model.Cards)
        {
            <div class="st-card">
                <partial name="~/Views/Partials/_TicketCard.cshtml" model="card" />
            </div>
        }
    </div>
</body>
</html>
