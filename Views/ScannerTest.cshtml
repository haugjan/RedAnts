@model RedAnts.Features.Ticketing.Tickets.ScannerTestViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Scanner-Test – Red Ants Winterthur</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <style>
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; background: #f4f4f4; color: #1a1a1a; text-align: center; padding: 2.4rem 1.2rem; }
        h1 { font-size: 1.6rem; margin: 0 0 .5rem; }
        .accent { height: 5px; width: 64px; background: #C8102E; margin: 0 auto 1.2rem; }
        .intro { max-width: 460px; margin: 0 auto 2rem; color: #555; line-height: 1.6; }
        .grid { display: flex; flex-wrap: wrap; gap: 1.4rem; justify-content: center; align-items: flex-start; }
        .ticket { width: min(88vw, 300px); background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 14px rgba(0,0,0,.08); }
        .ticket__head { padding: 12px 16px; text-align: left; color: #fff; }
        .ticket__kicker { display: block; font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; opacity: .9; }
        .ticket__type { display: block; font-size: 1.15rem; font-weight: 700; line-height: 1.2; }
        .ticket__qr { padding: 18px; }
        .ticket__qr svg { width: 100%; height: auto; display: block; }
    </style>
</head>
<body>
    <h1>Scanner-Test</h1>
    <div class="accent"></div>
    <p class="intro">Scanne die Codes mit dem Ticket-Scanner. Für jede Ticketversion erscheint die grüne Bestätigung mit dem passenden Typ. Es wird kein echtes Ticket eingecheckt.</p>
    <div class="grid">
        @foreach (var item in Model.Items)
        {
            <div class="ticket">
                <div class="ticket__head" style="background:@item.AccentHex;">
                    <span class="ticket__kicker">@item.Kicker</span>
                    <span class="ticket__type">@item.Label</span>
                </div>
                <div class="ticket__qr">@Html.Raw(item.QrSvg)</div>
            </div>
        }
    </div>
</body>
</html>
