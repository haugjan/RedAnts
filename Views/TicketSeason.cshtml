@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using RedAnts.Domain.Ticketing
@using RedAnts.Features.Ticketing.Public
@{
    // Same look as the public website homepage: the site nav (_SiteLayout) plus the website's
    // own hero + event-list building blocks (styled by site.css / the eventListElement styles).
    Layout = "~/Views/Shared/_SiteLayout.cshtml";

    var status = Model.Value<string>("status");
    var providedSecret = Context.Request.Query["secret"].ToString();
    var accessSecret = Model.Key.ToString().Split('-')[0];
    var statusEnum = Enum.TryParse<SeasonStatus>(status, out var st) ? st : SeasonStatus.Draft;
    // Open = öffentlich; Intern = nur mit passendem ?secret; Draft/Closed = 404.
    var blocked = !AccessGate.SeasonOk(statusEnum, accessSecret, providedSecret);
    if (blocked) { Context.Response.StatusCode = 404; }

    ViewBag.PageTitle = Model.Name + " – Red Ants Winterthur";
    // Solid nav: the page opens with a compact header image band, not a full-screen hero.
    ViewBag.TransparentNav = false;

    var start = Model.Value<DateTime>("startDate");
    var end = Model.Value<DateTime>("endDate");
    var image = Model.Value<IPublishedContent>("image")?.Url();
    var events = (Model.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(c => c.ContentType.Alias == "event"
            && c.Value<string>("status") == "Open"
            && c.Value<DateTime>("start") >= DateTime.Today)
        .OrderBy(c => c.Value<DateTime>("start"))
        .ToList();
}

@if (blocked)
{
    <main class="flexpage-main" style="padding-top:66px;">
        <div style="max-width:900px;margin:3rem auto;padding:0 20px;color:#666;">
            Diese Saison ist nicht verfügbar.
        </div>
    </main>
}
else
{
    <main class="flexpage-main" style="padding-top:66px;">
        <header class="season-header @(string.IsNullOrEmpty(image) ? "season-header--empty" : "")"
                style="@(string.IsNullOrEmpty(image) ? "" : $"background-image:url('{image}');")">
            <div class="season-header-inner">
                <h1 class="season-header-title">@Model.Name</h1>
                <p class="season-header-date">@start.ToString("dd.MM.yyyy") – @end.ToString("dd.MM.yyyy")</p>
            </div>
        </header>

        <section class="event-list">
            <div class="event-list-inner">
                <h2 class="event-list-title">Anstehende Anlässe</h2>

                @if (events.Count == 0)
                {
                    <p class="event-list-empty">Zurzeit sind keine Anlässe im Verkauf.</p>
                }
                else
                {
                    <ul class="event-list-items">
                        @foreach (var evt in events)
                        {
                            var evStart = evt.Value<DateTime>("start");
                            var venue = evt.Value<IPublishedContent>("venue");
                            var evImage = evt.Value<IPublishedContent>("eventImage");
                            <li class="event-item">
                                <a class="event-item-link" href="@evt.Url()">
                                    @if (evImage != null)
                                    {
                                        <span class="event-item-thumb" style="background-image:url('@evImage.Url()');"></span>
                                    }
                                    <span class="event-item-body">
                                        <span class="event-item-date">@evStart.ToString("dd.MM.yyyy") · @evStart.ToString("HH:mm") Uhr</span>
                                        <span class="event-item-name">@evt.Name</span>
                                        @if (venue != null) { <span class="event-item-venue">@venue.Name</span> }
                                    </span>
                                    <span class="event-item-cta">Tickets →</span>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </section>
    </main>

    <style>
        /* Compact header image band (not a full-screen hero): fixed height, title + date over it. */
        .season-header {
            position: relative; height: clamp(220px, 34vw, 320px);
            display: flex; align-items: flex-end;
            background-size: cover; background-position: center 40%; background-color: #0d0d0d;
        }
        .season-header--empty {
            background-image: radial-gradient(120% 120% at 75% 10%, rgba(200,16,46,0.6) 0%, rgba(200,16,46,0) 55%), linear-gradient(180deg, #1c1c1e 0%, #0a0a0b 100%);
        }
        .season-header::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(0,0,0,0.6) 100%);
        }
        .season-header-inner { position: relative; z-index: 1; max-width: 900px; width: 100%; margin: 0 auto; padding: 0 20px 22px; }
        .season-header-title { font-family: 'Oswald', sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: .01em; line-height: .95; color: #fff; font-size: clamp(2rem, 6vw, 3.4rem); margin: 0; }
        .season-header-date { margin: 6px 0 0; color: rgba(255,255,255,.85); font-size: .95rem; }

        /* Same event-list styling as the homepage's eventListElement block. */
        .event-list { padding: 56px 20px; background: #f6f7f9; }
        .event-list-inner { max-width: 900px; margin: 0 auto; }
        .event-list-title { font-family: 'Oswald', sans-serif; font-size: 2.4rem; text-transform: uppercase; letter-spacing: .5px; margin: 0 0 24px; color: #101010; }
        .event-list-empty { color: #666; }
        .event-list-items { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
        .event-item-link { display: flex; align-items: center; gap: 16px; background: #fff; border: 1px solid #e6e6e6; border-radius: 10px; padding: 14px 18px; text-decoration: none; color: inherit; transition: box-shadow .15s, transform .15s; }
        .event-item-link:hover { box-shadow: 0 6px 18px rgba(0,0,0,.08); transform: translateY(-1px); }
        .event-item-thumb { flex: 0 0 auto; width: 72px; height: 72px; border-radius: 8px; background-size: cover; background-position: center; }
        .event-item-body { display: flex; flex-direction: column; flex: 1 1 auto; min-width: 0; }
        .event-item-date { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; color: #C8102E; }
        .event-item-name { font-family: 'Oswald', sans-serif; font-size: 1.5rem; line-height: 1.1; color: #101010; }
        .event-item-venue { font-size: .9rem; color: #666; }
        .event-item-cta { flex: 0 0 auto; font-weight: 700; color: #C8102E; white-space: nowrap; }
        @@media (max-width: 560px) { .event-item-cta { display: none; } .event-item-thumb { width: 56px; height: 56px; } }
    </style>
}
