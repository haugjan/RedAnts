@model RedAnts.Features.Ticketing.Tickets.WebTicketViewModel
@using RedAnts.Features.Ticketing.Tickets
@{
    Layout = null;
    var title = Model.Found ? $"{Model.TypeLabel} – {Model.ScopeName}" : "Ticket";
    var card = Model.Found
        ? new TicketCardModel(
            Kicker: Model.Kicker,
            TypeLabel: Model.TypeLabel,
            ScopeName: Model.ScopeName,
            DateText: Model.DateText,
            CategoryLabel: (!string.IsNullOrEmpty(Model.CategoryLabel) && Model.CategoryLabel != Model.TypeLabel) ? Model.CategoryLabel : null,
            HolderName: Model.HolderName,
            Serial: Model.TicketRef,
            QrMarkup: Model.QrSvg,
            Invalid: !Model.Valid,
            VenueName: Model.VenueName)
        : null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto+Mono:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/ticket-card.css" asp-append-version="true" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; background: #f4f4f5; color: #14171A; font-family: Verdana, Geneva, Tahoma, sans-serif; display: flex; align-items: center; justify-content: center; padding: 1rem; -webkit-font-smoothing: antialiased; }
        .wt-wrap { width: 100%; max-width: 340px; }
        .wt-wrap .rtk-card { --rtk-notch: #f4f4f5; }
        .wt-actions { display: flex; flex-direction: column; gap: .5rem; margin-top: 1rem; }
        .wt-btn { display: flex; align-items: center; justify-content: center; text-decoration: none; font-family: 'Oswald', Impact, sans-serif; text-transform: uppercase; letter-spacing: .04em; font-weight: 600; font-size: .92rem; padding: .62rem 1rem; border-radius: 10px; }
        .wt-btn--pdf { background: #14171A; color: #fff; }
        .wt-btn--pdf:hover { background: #2a2e33; }
        .wt-empty { background: #fff; border: 1px solid #e6e8ec; border-radius: 16px; text-align: center; padding: 2.5rem 1.4rem; }
        .wt-empty h1 { font-family: 'Oswald', Impact, sans-serif; text-transform: uppercase; font-size: 1.4rem; margin: 0 0 .5rem; }
        .wt-empty p { color: #6b7178; margin: 0; font-size: .95rem; line-height: 1.5; }
        @@media print { .wt-actions { display: none; } body { background: #fff; padding: 0; } }
    </style>
</head>
<body>
    <div class="wt-wrap">
        @if (!Model.Found)
        {
            <div class="wt-empty">
                <h1>Ticket ungültig</h1>
                <p>Dieser Ticket-Link ist ungültig oder abgelaufen. Bitte den Link aus deiner Bestellbestätigung verwenden.</p>
            </div>
        }
        else
        {
            <partial name="~/Views/Partials/_TicketCard.cshtml" model="card!" />
            <div class="wt-actions">
                <a class="wt-btn wt-btn--pdf" href="/ticket/@Model.Token/pdf">Als PDF herunterladen</a>
            </div>
        }
    </div>
</body>
</html>
