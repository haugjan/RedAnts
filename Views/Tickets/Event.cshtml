@model EventPurchaseModel
@{
    Layout = "~/Views/Shared/_TicketsLayout.cshtml";
    ViewData["Title"] = Model.Event.Name;
    var availablePrices = Model.Event.Prices.ToList();
}

@if (!string.IsNullOrEmpty(Model.Event.ImageUrl))
{
    <img src="@Model.Event.ImageUrl" class="img-fluid rounded mt-2 mb-3" alt="@Model.Event.Name" style="max-height:320px;width:100%;object-fit:cover;" />
}

@if (!string.IsNullOrEmpty(Model.Event.HomeTeamLogoUrl) || !string.IsNullOrEmpty(Model.Event.AwayTeamLogoUrl))
{
    <div class="d-flex align-items-center gap-3 my-3">
        @if (!string.IsNullOrEmpty(Model.Event.HomeTeamLogoUrl))
        {
            <img src="@Model.Event.HomeTeamLogoUrl" alt="Heimteam" style="height:64px;width:auto;" />
        }
        <span class="fw-bold text-muted">vs</span>
        @if (!string.IsNullOrEmpty(Model.Event.AwayTeamLogoUrl))
        {
            <img src="@Model.Event.AwayTeamLogoUrl" alt="Auswärtsteam" style="height:64px;width:auto;" />
        }
    </div>
}

<h1 class="mt-2 mb-1">@Model.Event.Name</h1>
<p class="text-muted">
    @Model.Event.Date.ToString("dd.MM.yyyy"), @Model.Event.StartTime.ToString("HH\\:mm") Uhr
    @if (Model.Venue is not null) { <text> · @Model.Venue.Name</text> }
    · @Model.SeasonName
</p>

@if (!string.IsNullOrWhiteSpace(Model.Event.Text))
{
    <p>@Model.Event.Text</p>
}

@if (Model.Error is not null)
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (availablePrices.Count == 0)
{
    <div class="alert alert-warning">Für diesen Anlass sind keine Preise hinterlegt.</div>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <form method="post" action="/tickets/event/@Model.Sqid/kauf">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Secret" value="@Model.Secret" />

                <h6>Ticket-Kategorie</h6>
                <select class="form-select" name="PriceCategory" required>
                    @foreach (var price in availablePrices)
                    {
                        <option value="@price.Category">@Labels.PriceCategory(price.Category) — CHF @price.Amount.ToString("N2")</option>
                    }
                </select>

                <partial name="_BillingFields" />

                @if (Model.TurnstileSiteKey is not null)
                {
                    <input type="hidden" name="CaptchaToken" id="captcha-token" />
                    <div class="cf-turnstile mt-3" data-sitekey="@Model.TurnstileSiteKey" data-callback="onCaptcha"></div>
                    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
                    <script>function onCaptcha(t){document.getElementById('captcha-token').value=t;}</script>
                }

                <button type="submit" class="btn btn-danger mt-4">Weiter zur Zahlung</button>
            </form>
        </div>
    </div>
}
