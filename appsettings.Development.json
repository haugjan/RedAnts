{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "_comment": "Local dev connects to the shared DEV Azure SQL. The real DSN (with password) is in user secrets (dotnet user-secrets set ConnectionStrings:umbracoDbDSN ...); no SQLite.",
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
  },
  "Umbraco": {
    "CMS": {
      "RuntimeMode": "BackofficeDevelopment",
      "Global": {
        "UseHttps": false
      },
      "Hosting": {
        "Debug": true
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@localhost.dev",
        "UnattendedUserPassword": "Admin1234!"
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "https://localhost:44370"
      }
    }
  },
  "Turnstile": {
    "SiteKey": "1x00000000000000000000AA",
    "SecretKey": "1x0000000000000000000000000000000AA"
  },
  "Payrexx": {
    "Instance": "",
    "ApiSecret": ""
  }
}
